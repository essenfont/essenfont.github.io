---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { loadAllBlocks, slugifyBlockName } from '../../../lib/unicode';

export async function getStaticPaths() {
  const data = JSON.parse(await import('node:fs').then(fs => fs.readFileSync('public/planes.json', 'utf-8')));
  const planes = data.planes || [];
  return planes.map(p => ({ params: { hex: p.code }, props: { plane: p } }));
}

import fs from 'node:fs';
const allBlocks = loadAllBlocks();

const { plane } = Astro.props;
const planeBlocks = allBlocks.filter(b => {
  const cp = b.start;
  return cp >= plane.start && cp <= plane.end;
});
---
<BaseLayout
  title={`${plane.label} — ${plane.full} — Essenfont`}
  description={`${plane.full} (${plane.range}): ${planeBlocks.length} blocks, ${plane.assignedCount?.toLocaleString() || ''} assigned codepoints.`}
  canonical={`/unicode/plane/${plane.code}`}
>
  <div class="plane-page">
    <header class="page-head">
      <h1>{plane.full}</h1>
      <div class="plane-meta">
        <span class="range">{plane.range}</span>
        <span>{planeBlocks.length} blocks</span>
        <span>{plane.assignedCount?.toLocaleString() || ''} codepoints</span>
      </div>
    </header>
    <div class="block-list">
      {planeBlocks.map(block => (
        <a href={`/unicode/block/${slugifyBlockName(block.name)}`} class="block-link">
          <span class="block-name">{block.displayName || block.name}</span>
          <span class="block-cp-count">{block.end - block.start + 1} cp</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
<style>
.plane-page { max-width: 900px; margin: 0 auto; padding: 3rem 1.5rem 6rem; }
.page-head { margin-bottom: 2rem; }


h1 { font-family: var(--spec-font-display); font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0.5rem 0; }
.plane-meta { display: flex; gap: 1.5rem; font-size: 0.875rem; opacity: 0.7; }
.range { font-family: var(--spec-font-mono); }
.block-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 0.5rem; }
.block-link { display: flex; justify-content: space-between; padding: 0.5rem 0.75rem; border-radius: 4px; text-decoration: none; color: inherit; transition: background 0.1s; }
.block-link:hover { background: rgba(191,78,106,0.08); }
.block-name { font-weight: 500; font-size: 0.875rem; }
.block-cp-count { font-family: var(--spec-font-mono); font-size: 0.7rem; opacity: 0.5; }
</style>
