---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadAllBlocks, getPlanes, slugifyBlockName, loadUnicodeVersion } from '../../lib/unicode';

const allBlocks = loadAllBlocks();
const version = loadUnicodeVersion();
const planes = getPlanes(allBlocks);
const totalAssigned = planes.reduce((sum, p) => sum + p.blocks.length, 0);
---
<BaseLayout
  title="Unicode Browser — Essenfont"
  description="Explore every Unicode 17 plane, block, and codepoint. Real glyphs rendered from the Essenfont."
  canonical="/unicode"
>
  <div class="uc">
    <header class="uc-header">
      <h1>Unicode Browser</h1>
      <p>Every Unicode {version.version} plane, every block, every assigned codepoint.</p>
      <p class="uc-sub">All glyphs render with the Essenfont — install it locally for the same view everywhere.</p>
    </header>

    <div class="uc-stats">
      <div class="uc-stat">
        <span class="uc-stat-num">{planes.length}</span>
        <span class="uc-stat-label">planes</span>
      </div>
      <div class="uc-stat">
        <span class="uc-stat-num">{totalAssigned.toLocaleString()}</span>
        <span class="uc-stat-label">blocks</span>
      </div>
      <div class="uc-stat">
        <span class="uc-stat-num">{version.charCount.toLocaleString()}</span>
        <span class="uc-stat-label">assigned codepoints</span>
      </div>
    </div>

    {planes.map(plane => (
      <section class="plane-section" id={plane.key}>
        <div class="plane-header">
          <h2>
            <span class="plane-roman">{plane.range.split('–')[0].replace('U+', '')}</span>
            {plane.name}
          </h2>
          <span class="plane-range">{plane.range}</span>
          <span class="plane-count">{plane.blocks.length} blocks</span>
        </div>
        <div class="block-list">
          {plane.blocks.map(block => (
            <a href={`/unicode/block/${slugifyBlockName(block.name)}`} class="block-link">
              <span class="block-name">{block.displayName || block.name}</span>
              <span class="block-cp-count">{block.end - block.start + 1} cp</span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
.uc { padding: 3rem 0; }
.uc-header { text-align: center; margin-bottom: 3rem; }
.uc-header h1 {
  font-family: var(--spec-font-display);
  font-size: clamp(2rem, 5vw, 3rem);
  margin: 0 0 0.5rem;
}
.uc-stats {
  display: flex;
  justify-content: center;
  gap: 3rem;
  margin-bottom: 3rem;
  flex-wrap: wrap;
}
.uc-stat { text-align: center; }
.uc-stat-num {
  display: block;
  font-family: var(--spec-font-display);
  font-size: 2rem;
  color: var(--ef-rose, #bf4e6a);
}
.uc-stat-label {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  opacity: 0.6;
}
.plane-section { margin-bottom: 3rem; }
.plane-header {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid rgba(128, 128, 128, 0.2);
}
.plane-header h2 {
  font-family: var(--spec-font-display);
  font-size: 1.5rem;
  margin: 0;
}
.plane-roman {
  font-family: var(--spec-font-mono);
  font-size: 0.75rem;
  color: var(--ef-rose, #bf4e6a);
  margin-right: 0.5rem;
}
.plane-range {
  font-family: var(--spec-font-mono);
  font-size: 0.75rem;
  opacity: 0.6;
}
.plane-count {
  font-size: 0.75rem;
  opacity: 0.5;
  margin-left: auto;
}
.block-list {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  gap: 0.5rem;
}
.block-link {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.5rem 0.75rem;
  border-radius: 4px;
  text-decoration: none;
  color: inherit;
  transition: background 0.1s;
}
.block-link:hover {
  background: rgba(191, 78, 106, 0.08);
}
.block-name {
  font-size: 0.875rem;
  font-weight: 500;
}
.block-cp-count {
  font-family: var(--spec-font-mono);
  font-size: 0.7rem;
  opacity: 0.5;
}
</style>
