---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadAllBlocks, getPlanes, loadUnicodeVersion } from '../../lib/unicode';
import { loadStats } from '../../lib/stats';
import RandomCodepoint from '../../components/RandomCodepoint.vue';
import CoverageHeatmap from '../../components/CoverageHeatmap.astro';
import UnicodeTimeline from '../../components/UnicodeTimeline.astro';

const allBlocks = loadAllBlocks();
const version = loadUnicodeVersion();
const planes = getPlanes(allBlocks);
const stats = loadStats();

const totalAssigned = stats.unicode?.assignedCodepointCount ?? 0;
const totalCovered = stats.coverage?.totals?.covered ?? stats.coverage?.overall?.covered ?? 0;
const coveragePct = totalAssigned > 0 ? ((totalCovered / totalAssigned) * 100).toFixed(1) : '0';

const PLANE_CODES: Record<string, string> = {
  bmp: '0', smp: '1', sip: '2', tip: '3', ssp: 'E', spua_a: 'F', spua_b: '10',
};
---

<BaseLayout
  title="Unicode Browser — Essenfont"
  description="Explore every Unicode 17 plane, block, and codepoint. Real glyphs rendered from the Essenfont."
  canonical="/unicode"
>
  <div class="uc">
    <header class="uc-hero">
      <span class="uc-eyebrow">Unicode {version.version}</span>
      <h1>Every assigned<br/>codepoint, covered.</h1>
      <p class="uc-lede">
        Essenfont renders <strong>{totalCovered.toLocaleString()}</strong> of the
        <strong>{totalAssigned.toLocaleString()}</strong> codepoints the Unicode Standard
        has assigned across {version.version} — from Basic Latin to Tangut, from
        Egyptian Hieroglyphs to CJK Extension J.
      </p>
      <div class="uc-hero-actions">
        <RandomCodepoint client:idle />
      </div>
    </header>

    <div class="uc-coverage-stat">
      <div class="uc-cov-num">{coveragePct}<span class="uc-cov-pct">%</span></div>
      <div class="uc-cov-text">
        <span class="uc-cov-label">of all assigned Unicode {version.version} codepoints</span>
        <span class="uc-cov-sub mono">Private Use Areas are not assigned by Unicode and are excluded</span>
      </div>
    </div>

    <section class="uc-section">
      <UnicodeTimeline />
    </section>

    <section class="uc-section">
      <CoverageHeatmap />
    </section>

    <section class="uc-section">
      <h2 class="uc-section-title">Browse by plane</h2>
      <div class="uc-plane-grid">
        {planes.map(plane => (
          <a href={`/unicode/plane/${PLANE_CODES[plane.key] ?? '0'}`} class="uc-plane-card">
            <span class="uc-plane-roman">{plane.range.split('–')[0].replace('U+', '')}</span>
            <span class="uc-plane-info">
              <span class="uc-plane-name">{plane.name}</span>
              <span class="uc-plane-range mono">{plane.range}</span>
            </span>
            <span class="uc-plane-blocks">{plane.blocks.length} blocks →</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .uc { padding: 2rem 0; }

  .uc-hero {
    text-align: center;
    margin-bottom: 3rem;
    padding-top: 1rem;
  }
  .uc-eyebrow {
    font-family: var(--spec-font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--ef-accent);
    display: block;
    margin-bottom: 0.75rem;
  }
  .uc-hero h1 {
    font-family: var(--spec-font-display);
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 600;
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0 0 1.25rem;
    color: var(--ef-text);
  }
  .uc-lede {
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.6;
    max-width: 580px;
    margin: 0 auto 1.5rem;
    color: var(--ef-text-2);
  }
  .uc-lede strong { color: var(--ef-text); font-weight: 600; }

  .uc-coverage-stat {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    padding: 1.5rem 2rem;
    margin: 0 auto 3rem;
    max-width: 640px;
    background: var(--ef-surface);
    border: 1px solid var(--ef-rule-strong);
    border-radius: var(--ef-radius);
  }
  .uc-cov-num {
    font-family: var(--spec-font-display);
    font-size: clamp(3rem, 8vw, 4.5rem);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--ef-accent);
  }
  .uc-cov-pct { font-size: 0.45em; }
  .uc-cov-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    text-align: left;
  }
  .uc-cov-label {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ef-text);
  }
  .uc-cov-sub {
    font-size: 0.68rem;
    color: var(--ef-text-3);
    letter-spacing: 0.03em;
    line-height: 1.4;
  }

  .uc-section { margin-bottom: 3rem; }
  .uc-section-title {
    font-family: var(--spec-font-display);
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 1rem;
    color: var(--ef-text);
  }

  .uc-plane-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
  }
  .uc-plane-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--ef-rule);
    border-radius: var(--ef-radius-sm);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
  }
  .uc-plane-card:hover {
    border-color: var(--ef-accent);
    transform: translateY(-2px);
    box-shadow: var(--ef-shadow-sm);
  }
  .uc-plane-roman {
    font-family: var(--spec-font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--ef-accent);
    min-width: 3ch;
  }
  .uc-plane-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    flex: 1;
  }
  .uc-plane-name {
    font-family: var(--spec-font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--ef-text);
  }
  .uc-plane-range {
    font-size: 0.68rem;
    color: var(--ef-text-3);
  }
  .uc-plane-blocks {
    font-family: var(--spec-font-mono);
    font-size: 0.72rem;
    color: var(--ef-text-2);
    white-space: nowrap;
  }

  .mono { font-family: var(--spec-font-mono); }

  @media (max-width: 640px) {
    .uc-coverage-stat { flex-direction: column; text-align: center; }
    .uc-cov-text { text-align: center; align-items: center; }
  }
</style>
