---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadAllBlocks, getPlanes, slugifyBlockName, loadUnicodeVersion } from '../../lib/unicode';

const allBlocks = loadAllBlocks();
const version = loadUnicodeVersion();
const planes = getPlanes(allBlocks);
const totalAssigned = planes.reduce((sum, p) => sum + p.blocks.length, 0);

// Each plane gets a "specimen glyph" — its most iconic character.
const planeSpecimens: Record<string, number> = {
  bmp: 0x0041,        // A
  smp: 0x1F4A9,       // 💩
  sip: 0x20000,       // CJK Ext B
  tip: 0x30F4D,       // CJK Ext G (recovered!)
  ssp: 0xE0001,       // Language tag
  spua_a: 0xF0000,    // Private Use
  spua_b: 0x100000,   // Private Use
};

function safeGlyph(cp: number | undefined): string {
  if (!cp) return '·';
  try { return String.fromCodePoint(cp); } catch { return '·'; }
}
---

<BaseLayout
  title="Browse — Essenfont"
  description="Explore every Unicode 17 plane, block, and codepoint. Real glyphs rendered from Essenfont."
  canonical="/unicode"
  active="browse"
>
  <!-- Section header -->
  <section class="section browse-head">
    <div class="container">
      <div class="browse-head-grid">
        <div class="browse-meta rise-1">
          <p class="eyebrow">§ Atlas</p>
          <p class="folio" style="margin-top: 1rem;">Vol. {version.version}</p>
        </div>
        <div class="browse-pitch rise-2">
          <h1>The universal<br/><em class="text-ochre">atlas</em>.</h1>
          <p class="lede" style="margin-top: 2rem;">
            {planes.length} planes · {totalAssigned.toLocaleString()} blocks · {version.charCount.toLocaleString()} codepoints.
            Every assigned Unicode {version.version} character, each one click away from its specimen page.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Planes -->
  {planes.map((plane, idx) => (
    <section class:list={["section", "plane-section", idx % 2 === 1 && "plane-section-alt"]}>
      <div class="container">
        <div class="plane-grid">
          <aside class="plane-sidebar">
            <p class="eyebrow">Plane {idx + 1} of {planes.length}</p>
            <div class="plane-glyph glyph">{safeGlyph(planeSpecimens[plane.key])}</div>
            <p class="folio" style="margin-top: 1rem;">specimen</p>
          </aside>
          <div class="plane-body">
            <header class="plane-header">
              <h2 class="plane-name">
                {plane.name}
              </h2>
              <div class="plane-meta-row">
                <span class="mono">{plane.range}</span>
                <span class="folio">·</span>
                <span class="folio">{plane.blocks.length} block{plane.blocks.length === 1 ? '' : 's'}</span>
              </div>
            </header>
            <ul class="block-list">
              {plane.blocks.map(block => (
                <li>
                  <a href={`/unicode/block/${slugifyBlockName(block.name)}`} class="block-link">
                    <span class="block-name">{block.displayName || block.name}</span>
                    <span class="block-range mono">U+{block.start.toString(16).toUpperCase()}–U+{block.end.toString(16).toUpperCase()}</span>
                    <span class="block-count mono">{block.end - block.start + 1} cp</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  ))}
</BaseLayout>

<style>
  .browse-head { padding-block: clamp(3rem, 8vw, 5rem); }
  .browse-head-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: clamp(1rem, 3vw, 2.5rem);
  }
  .browse-meta { grid-column: 1 / span 2; }
  .browse-pitch {
    grid-column: 4 / span 9;
    padding-top: 1rem;
  }
  .browse-pitch h1 {
    font-family: var(--font-display);
    font-weight: 300;
    font-variation-settings: "opsz" 144, "SOFT" 40;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.035em;
  }
  .browse-pitch h1 em {
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
  }

  /* Plane section */
  .plane-section { padding-block: clamp(3rem, 6vw, 5rem); }
  .plane-section-alt { background: var(--ef-paper-2); }
  .plane-grid {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .plane-sidebar {
    position: sticky;
    top: calc(var(--nav-h) + 2rem);
  }
  .plane-glyph {
    font-family: var(--font-glyph);
    font-size: clamp(4rem, 6vw, 5.5rem);
    line-height: 1;
    color: var(--ef-ochre);
    margin-top: 0.5rem;
  }

  .plane-name {
    font-family: var(--font-display);
    font-weight: 350;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ef-ink);
  }
  .plane-meta-row {
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
    margin-top: 0.75rem;
    color: var(--ef-ink-3);
    flex-wrap: wrap;
  }
  .plane-meta-row .mono { font-size: 0.8125rem; letter-spacing: 0.08em; }

  /* Block list */
  .block-list {
    list-style: none;
    margin-top: 2rem;
    border-top: 1px solid var(--ef-rule);
  }
  .block-list li { border-bottom: 1px solid var(--ef-rule); }
  .block-link {
    display: grid;
    grid-template-columns: 1.4fr 1.1fr 0.5fr;
    gap: 1rem;
    align-items: baseline;
    padding-block: 0.875rem;
    text-decoration: none;
    color: var(--ef-ink);
    border: none;
    transition: color 0.2s, padding-left 0.2s;
  }
  .block-link:hover {
    color: var(--ef-ochre);
    padding-left: 0.5rem;
  }
  .block-name {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1.0625rem;
  }
  .block-range {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--ef-ink-3);
  }
  .block-count {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    color: var(--ef-ink-3);
    text-transform: uppercase;
    text-align: right;
  }
  .block-link:hover .block-name { color: var(--ef-ochre); }
  .block-link:hover .block-range,
  .block-link:hover .block-count { color: var(--ef-ink-2); }

  @media (max-width: 900px) {
    .browse-pitch { grid-column: 1 / span 12; }
    .browse-meta { grid-column: 1 / span 12; }
    .plane-grid { grid-template-columns: 1fr; }
    .plane-sidebar { position: static; }
    .block-link {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
    .block-range, .block-count { text-align: left; }
  }
</style>
