---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadAllBlocks, getPlanes, slugifyBlockName, loadUnicodeVersion } from '../../lib/unicode';
import RandomCodepoint from '../../components/RandomCodepoint.vue';
import CoverageHeatmap from '../../components/CoverageHeatmap.astro';
import UnicodeTimeline from '../../components/UnicodeTimeline.astro';

const allBlocks = loadAllBlocks();
const version = loadUnicodeVersion();
const planes = getPlanes(allBlocks);
const totalAssigned = planes.reduce((sum, p) => sum + p.blocks.length, 0);
---
<BaseLayout
  title="Unicode Browser — Essenfont"
  description="Explore every Unicode 17 plane, block, and codepoint. Real glyphs rendered from the Essenfont."
  canonical="/unicode"
>
  <div class="uc">
    <header class="uc-header">
      <h1>Unicode Browser</h1>
      <p>Every Unicode {version.version} plane, every block, every assigned codepoint.</p>
      <p class="uc-sub">All glyphs render with the Essenfont — install it locally for the same view everywhere.</p>
      <div class="uc-actions">
        <RandomCodepoint client:idle />
      </div>
    </header>

// Each plane gets a "specimen glyph" — its most iconic character.
const planeSpecimens: Record<string, number> = {
  bmp: 0x0041,        // A
  smp: 0x1F4A9,       // 💩
  sip: 0x20000,       // CJK Ext B
  tip: 0x30F4D,       // CJK Ext G (recovered!)
  ssp: 0xE0001,       // Language tag
  spua_a: 0xF0000,    // Private Use
  spua_b: 0x100000,   // Private Use
};

function safeGlyph(cp: number | undefined): string {
  if (!cp) return '·';
  try { return String.fromCodePoint(cp); } catch { return '·'; }
}
---

<BaseLayout
  title="Browse — Essenfont"
  description="Explore every Unicode 17 plane, block, and codepoint. Real glyphs rendered from Essenfont."
  canonical="/unicode"
  active="browse"
>
  <!-- Section header -->
  <section class="section browse-head">
    <div class="container">
      <div class="browse-head-grid">
        <div class="browse-meta rise-1">
          <p class="eyebrow">§ Atlas</p>
          <p class="folio" style="margin-top: 1rem;">Vol. {version.version}</p>
        </div>
        <div class="browse-pitch rise-2">
          <h1>The universal<br/><em class="text-ochre">atlas</em>.</h1>
          <p class="lede" style="margin-top: 2rem;">
            {planes.length} planes · {totalAssigned.toLocaleString()} blocks · {version.charCount.toLocaleString()} codepoints.
            Every assigned Unicode {version.version} character, each one click away from its specimen page.
          </p>
        </div>
      </div>
    </div>
  </section>

    <CoverageHeatmap />

    <UnicodeTimeline />

    {planes.map(plane => (
      <section class="plane-section" id={plane.key}>
        <div class="plane-header">
          <h2>
            <span class="plane-roman">{plane.range.split('–')[0].replace('U+', '')}</span>
            {plane.name}
          </h2>
          <span class="plane-range">{plane.range}</span>
          <span class="plane-count">{plane.blocks.length} blocks</span>
        </div>
      </div>
    </section>
  ))}
</BaseLayout>

<style>
.uc { padding: 3rem 0; }
.uc-header { text-align: center; margin-bottom: 3rem; }
.uc-header h1 {
  font-family: var(--spec-font-display);
  font-size: clamp(2rem, 5vw, 3rem);
  margin: 0 0 0.5rem;
}
.uc-stats {
  display: flex;
  justify-content: center;
  gap: 3rem;
  margin-bottom: 3rem;
  flex-wrap: wrap;
}
.uc-stat { text-align: center; }
.uc-stat-num {
  display: block;
  font-family: var(--spec-font-display);
  font-weight: 600;
  font-size: clamp(2.5rem, 5vw, 3.25rem);
  font-variation-settings: "opsz" 96, "SOFT" 50;
  font-feature-settings: "lnum" 1, "tnum" 1;
  line-height: 1;
  letter-spacing: -0.02em;
  color: var(--ef-accent, #2a5c8a);
}
.uc-stat-label {
  display: block;
  margin-top: 0.5rem;
  font-family: var(--spec-font-mono);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  opacity: 0.55;
}
.plane-section { margin-bottom: 3rem; }
.plane-header {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid rgba(128, 128, 128, 0.2);
}
.plane-header h2 {
  font-family: var(--spec-font-display);
  font-size: 1.5rem;
  margin: 0;
}
.plane-roman {
  font-family: var(--spec-font-mono);
  font-size: 0.75rem;
  color: var(--ef-rose, #bf4e6a);
  margin-right: 0.5rem;
}
.plane-range {
  font-family: var(--spec-font-mono);
  font-size: 0.75rem;
  opacity: 0.6;
}
.plane-count {
  font-size: 0.75rem;
  opacity: 0.5;
  margin-left: auto;
}
.block-list {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  gap: 0.5rem;
}
.block-link {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.5rem 0.75rem;
  border-radius: 4px;
  text-decoration: none;
  color: inherit;
  transition: background 0.1s;
}
.block-link:hover {
  background: rgba(191, 78, 106, 0.08);
}
.block-name {
  font-size: 0.875rem;
  font-weight: 500;
}
.block-cp-count {
  font-family: var(--spec-font-mono);
  font-size: 0.7rem;
  opacity: 0.5;
}
</style>
