---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  loadAllBlocks,
  loadBlockCharacters,
  loadUnihanForCodepoint,
  slugifyBlockName,
  PLANES,
  blockDisplayName,
  categoryName,
  scriptDisplayName,
  bidiClassName,
  combiningClassName,
  isControlChar,
  controlAbbrev,
  controlName,
  cEscape,
} from '../../../lib/unicode';
import { UNIHAN_CATEGORIES } from '../../../lib/unicode/constants';
import { unihanLabel } from '../../../lib/unicode/unihan-labels';
import * as esc from '../../../lib/unicode/escapes';
import { blockNameToId, blockToDonorSlug, loadDonorDetail } from '../../../lib/donors';
import type { UnicodeBlock, UnicodeCharacter } from '../../../lib/unicode';
import Tabs from '../../../components/Tabs.vue';
import DonorBadge from '../../../components/DonorBadge.astro';

interface CharPageProps {
  char: UnicodeCharacter;
  block: UnicodeBlock;
  hex: string;
  prevHex: string | null;
  nextHex: string | null;
}

export async function getStaticPaths() {
  const blocks = loadAllBlocks();
  const paths: Array<{ params: { hex: string }; props: CharPageProps }> = [];

  for (const block of blocks) {
    const slug = slugifyBlockName(block.name);
    const chars = loadBlockCharacters(slug);
    for (let i = 0; i < chars.length; i++) {
      const ch = chars[i];
      const urlHex = ch.cp.toString(16).toUpperCase().padStart(4, '0');
      const prev = i > 0 ? chars[i - 1].cp.toString(16).toUpperCase().padStart(4, '0') : null;
      const next = i < chars.length - 1 ? chars[i + 1].cp.toString(16).toUpperCase().padStart(4, '0') : null;
      paths.push({
        params: { hex: urlHex },
        props: { char: ch, block, hex: urlHex, prevHex: prev, nextHex: next },
      });
    }
  }

  return paths;
}

const { char, block, hex, prevHex, nextHex } = Astro.props;
const cp = char.cp;
const planeKey = block.plane;
const plane = PLANES.find(p => p.key === planeKey);

const isControl = isControlChar(char.category, cp);
const abbrev = controlAbbrev(cp);
const ctrlName = controlName(cp);
const displayName = isControl && ctrlName ? `<${ctrlName}>` : char.name;
const blockSlug = slugifyBlockName(block.name);

// Donor attribution — map this block to a specific donor page (e.g. CJK
// → /donors/full-sung). Falls back to the generic /donors registry.
const donorSlug = blockToDonorSlug().get(blockNameToId(block.name));
const donorHref = donorSlug ? `/donors/${donorSlug}` : '/donors';
const donorFamilyName = donorSlug
  ? donorSlug.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')
  : null;
const donorDetail = donorSlug ? loadDonorDetail(donorSlug) : null;

// Unihan data for CJK ideographs (readings, radical/stroke, definition, etc).
const unihan = loadUnihanForCodepoint(cp, blockSlug);

// Build the tab list from conditional sections. Adding a new section =
// appending here + wrapping it in <section data-tab="new-id">.
const charTabs = [
  { id: 'classification', label: 'Classification' },
  { id: 'encodings', label: 'Encodings' },
  { id: 'provenance', label: 'Provenance' },
  ...(char.simpleUppercase || char.simpleLowercase || char.simpleTitlecase ? [{ id: 'case', label: 'Case' }] : []),
  ...(char.decomposition ? [{ id: 'decomposition', label: 'Decomposition' }] : []),
  ...(unihan ? [{ id: 'unihan', label: 'Unihan' }] : []),
];

const utf8 = esc.utf8(cp);
const utf16 = esc.utf16(cp);
const utf32 = esc.utf32(cp);
const urlEnc = esc.urlEncoded(cp);
const pyEsc = esc.pythonEscape(cp);
const jsEsc = esc.jsEscape(cp);
const cssEsc = esc.cssEscape(cp);
const htmlDec = esc.htmlDecimal(cp);
const htmlHex = esc.htmlHex(cp);
const escapeSeq = cEscape(cp);

// Human-readable labels for Unihan field codes — see lib/unicode/unihan-labels.ts

---
<BaseLayout
  title={`U+${hex} ${char.name} — Essenfont`}
  description={`${char.name} (U+${hex}). ${char.category === '' ? '' : 'Category: ' + char.category + '. '}${plane ? 'Plane ' + plane.shortName + '. ' : ''}Rendered with the Essenfont universal Unicode 17 font.`}
  canonical={`/unicode/char/${hex}`}
>
  <article class="ucp" data-pagefind-body>
    <nav class="ucp-crumbs">
      <a href="/unicode">Unicode</a>
      <span>›</span>
      <a href={`/unicode/plane/${planeKey}`}>{plane?.shortName}</a>
      <span>›</span>
      <a href={`/unicode/block/${blockSlug}`}>{blockDisplayName(block.name)}</a>
      <span>›</span>
      <span class="ucp-crumb-current">U+{hex}</span>
    </nav>

    <div class="ucp-nav">
      {prevHex ? (
        <a href={`/unicode/char/${prevHex}`} class="ucp-nav-btn ucp-prev">
          <span aria-hidden="true">←</span>
          <span class="ucp-nav-hex">U+{prevHex}</span>
        </a>
      ) : (
        <span class="ucp-nav-spacer"></span>
      )}

      <span class="ucp-nav-current">U+{hex}</span>

      {nextHex ? (
        <a href={`/unicode/char/${nextHex}`} class="ucp-nav-btn ucp-next">
          <span class="ucp-nav-hex">U+{nextHex}</span>
          <span aria-hidden="true">→</span>
        </a>
      ) : (
        <span class="ucp-nav-spacer"></span>
      )}
    </div>

    <div class="ucp-glyph-area">
      <button
        class="ucp-compare-toggle"
        type="button"
        data-ucp-compare
        title="Toggle system font (rare scripts may tofu)"
        aria-pressed="false"
      >
        <span class="ucp-compare-dot"></span>
        <span data-ucp-compare-label>essenfont</span>
      </button>

      {!isControl ? (
        <div class="ucp-glyph-stage" data-ucp-stage>
          <div class="ucp-guides" aria-hidden="true">
            <span class="ucp-guide ucp-guide--cap"></span>
            <span class="ucp-guide ucp-guide--xheight"></span>
            <span class="ucp-guide ucp-guide--baseline"></span>
          </div>
          <span class="ucp-glyph" data-ucp-glyph>{char.char || '·'}</span>
        </div>
      ) : (
        <span class="ucp-control-box">{abbrev}</span>
      )}
    </div>

    <h1 class="ucp-name">
      {displayName}
      {isControl && abbrev && <span class="ucp-name-abbrev">({abbrev})</span>}
    </h1>
    <code class="ucp-hex">U+{hex}</code>

    {donorDetail && (
      <div class="ucp-donor-banner">
        <DonorBadge donor={donorDetail} block={blockDisplayName(block.name)} />
      </div>
    )}

    <Tabs client:load tabs={charTabs}>
      <section class="ucp-section" data-tab="classification" data-tab-label="Classification">
        <h2>Classification</h2>
        <dl>
          {block.unicodeVersion && (
            <>
              <dt>Unicode</dt>
              <dd>{block.unicodeVersion}</dd>
            </>
          )}
          {char.category && (
            <>
              <dt>Category</dt>
              <dd>
                <a href={`/unicode/category/${char.category}`}>{categoryName(char.category)}</a>
                <code>{char.category}</code>
              </dd>
            </>
          )}
          {char.script && (
            <>
              <dt>Script</dt>
              <dd><a href={`/unicode/scripts/${char.script}`}>{scriptDisplayName(char.script)}</a></dd>
            </>
          )}
          <dt>Block</dt>
          <dd><a href={`/unicode/block/${blockSlug}`}>{blockDisplayName(block.name)}</a></dd>
          <dt>Plane</dt>
          <dd><a href={`/unicode/plane/${planeKey}`}>{plane?.name} ({plane?.shortName})</a></dd>
          {char.bidiClass && (
            <>
              <dt>Bidirectional</dt>
              <dd>
                <a href={`/unicode/bidiclass/${char.bidiClass}`}>{bidiClassName(char.bidiClass)}</a>
                <code>{char.bidiClass}</code>
              </dd>
            </>
          )}
          <dt>Combining Class</dt>
          <dd>
            <a href={`/unicode/combining/${char.combiningClass || 0}`}>{combiningClassName(char.combiningClass || 0)}</a>
            <code>{char.combiningClass || 0}</code>
          </dd>
          {char.mirrored && (
            <>
              <dt>Mirrored</dt>
              <dd>Yes</dd>
            </>
          )}
          {escapeSeq && (
            <>
              <dt>Escape</dt>
              <dd><code>{escapeSeq}</code></dd>
            </>
          )}
        </dl>
      </section>

      <section class="ucp-section" data-tab="encodings" data-tab-label="Encodings" hidden>
        <h2>Encodings</h2>
        <dl>
          <dt>HTML Dec</dt>
          <dd>
            <code>{htmlDec}</code>
            <button class="ucp-copy" data-copy={htmlDec} type="button">copy</button>
          </dd>
          <dt>HTML Hex</dt>
          <dd>
            <code>{htmlHex}</code>
            <button class="ucp-copy" data-copy={htmlHex} type="button">copy</button>
          </dd>
          <dt>CSS</dt>
          <dd>
            <code>\{hex}</code>
            <button class="ucp-copy" data-copy={cssEsc} type="button">copy</button>
          </dd>
          <dt>JavaScript</dt>
          <dd>
            <code>{jsEsc}</code>
            <button class="ucp-copy" data-copy={jsEsc} type="button">copy</button>
          </dd>
          <dt>Python</dt>
          <dd>
            <code>{pyEsc}</code>
            <button class="ucp-copy" data-copy={pyEsc} type="button">copy</button>
          </dd>
          <dt>URL</dt>
          <dd>
            <code>{urlEnc}</code>
            <button class="ucp-copy" data-copy={urlEnc} type="button">copy</button>
          </dd>
          <dt>UTF-8</dt>
          <dd><code>{utf8}</code></dd>
          <dt>UTF-16</dt>
          <dd><code>{utf16}</code></dd>
          <dt>UTF-32</dt>
          <dd><code>{utf32}</code></dd>
        </dl>
      </section>

      <section class="ucp-section ucp-provenance" data-tab="provenance" data-tab-label="Provenance" hidden>
        <h2>Provenance</h2>
        <dl>
          <dt>Donor</dt>
          <dd>
            <a href={donorHref} class="ucp-donor-link">
              {donorFamilyName
                ? <>Donor font for {blockDisplayName(block.name)} — {donorFamilyName} →</>
                : <>Donor font for {blockDisplayName(block.name)} →</>}
            </a>
          </dd>
          <dt>SVG outline</dt>
          <dd>
            <a
              href={`https://github.com/essenfont/essenfont/releases/latest/download/svg/U+${hex}.svg`}
              target="_blank"
              rel="noopener"
              class="ucp-svg-link"
            >Download .svg <span class="ucp-link-arrow">↗</span></a>
          </dd>
          <dt>Share</dt>
          <dd>
            <button
              class="ucp-copy"
              data-copy={`https://essenfont.github.io/unicode/char/${hex}`}
              type="button"
            >copy link</button>
          </dd>
        </dl>
        <p class="ucp-provenance-note">
          Every glyph in essenfont is vector-extracted from a canonical
          OFL-licensed donor font. The donor attribution per block lives
          in <a href="/donors">/donors</a>; per-codepoint donor mapping
          is coming in a future release.
        </p>
      </section>

      {(char.simpleUppercase || char.simpleLowercase || char.simpleTitlecase) && (
        <section class="ucp-section" data-tab="case" data-tab-label="Case" hidden>
          <h2>Case Mappings</h2>
          <dl>
            {char.simpleUppercase && (
              <>
                <dt>Uppercase</dt>
                <dd>
                  <a href={`/unicode/char/${char.simpleUppercase}`}>
                    {String.fromCodePoint(parseInt(char.simpleUppercase, 16))} U+{char.simpleUppercase}
                  </a>
                </dd>
              </>
            )}
            {char.simpleLowercase && (
              <>
                <dt>Lowercase</dt>
                <dd>
                  <a href={`/unicode/char/${char.simpleLowercase}`}>
                    {String.fromCodePoint(parseInt(char.simpleLowercase, 16))} U+{char.simpleLowercase}
                  </a>
                </dd>
              </>
            )}
            {char.simpleTitlecase && (
              <>
                <dt>Title Case</dt>
                <dd>
                  <a href={`/unicode/char/${char.simpleTitlecase}`}>
                    {String.fromCodePoint(parseInt(char.simpleTitlecase, 16))} U+{char.simpleTitlecase}
                  </a>
                </dd>
              </>
            )}
          </dl>
        </section>
      )}

      {char.decomposition && (
        <section class="ucp-section" data-tab="decomposition" data-tab-label="Decomposition" hidden>
          <h2>Decomposition</h2>
          <dl>
            <dt>Decomposes To</dt>
            <dd>
              {char.decomposition.split(' ').map((part, i, arr) => (
                <>
                  {/^[0-9A-Fa-f]+$/.test(part) ? (
                    <a href={`/unicode/char/${part}`}>{String.fromCodePoint(parseInt(part, 16))}</a>
                  ) : (
                    <code>{part}</code>
                  )}
                  {i < arr.length - 1 && <span> </span>}
                </>
              ))}
            </dd>
          </dl>
        </section>
      )}

      {unihan && (
        <section class="ucp-section ucp-unihan" data-tab="unihan" data-tab-label="Unihan" hidden>
          <h2>Unihan</h2>
          <dl>
            {UNIHAN_CATEGORIES.map(cat => {
              const fields = unihan[cat.key];
              if (!fields || fields.length === 0) return null;
              return (
                <>
                  {fields.map(f => (
                    <>
                      <dt>{unihanLabel(f.name)}</dt>
                      <dd>
                        {cat.render === 'variant' && f.values.every(v => /^U\+[0-9A-Fa-f]+$/.test(v)) ? (
                          f.values.map((v, i) => (
                            <>
                              {i > 0 && <span>, </span>}
                              <a href={`/unicode/char/${v.slice(2)}`}>{String.fromCodePoint(parseInt(v.slice(2), 16))}</a>
                              <code class="ucp-unihan-cp">{v}</code>
                            </>
                          ))
                        ) : (
                          f.values.map((v, i) => (
                            <>
                              {i > 0 && <span>, </span>}
                              <span>{v}</span>
                            </>
                          ))
                        )}
                      </dd>
                    </>
                  ))}
                </>
              );
            })}
          </dl>
        </section>
      )}
    </Tabs>
  </article>
</BaseLayout>

<script>
  const btn = document.querySelector<HTMLButtonElement>('[data-ucp-compare]');
  const glyph = document.querySelector<HTMLElement>('[data-ucp-glyph]');
  const label = document.querySelector<HTMLElement>('[data-ucp-compare-label]');
  if (btn && glyph && label) {
    btn.addEventListener('click', () => {
      const systemOn = glyph.classList.toggle('ucp-glyph-system');
      btn.setAttribute('aria-pressed', String(systemOn));
      label.textContent = systemOn ? 'system font' : 'essenfont';
    });
  }
</script>

<style>
.ucp { padding: 1.5rem 0 4rem; max-width: 900px; margin: 0 auto; }

.ucp-crumbs {
  display: flex; align-items: center; gap: 0.5rem;
  font-family: var(--spec-font-mono);
  font-size: 0.78rem;
  margin-bottom: 1rem;
  flex-wrap: wrap;
  color: var(--ef-text-3);
}
.ucp-crumbs a { color: var(--ef-accent); text-decoration: none; }
.ucp-crumbs a:hover { text-decoration: underline; }
.ucp-crumb-current { color: var(--ef-text) !important; font-weight: 500; }

.ucp-nav {
  display: flex; align-items: center; justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1.5rem;
  padding: 0 0.5rem;
}
.ucp-nav-btn {
  display: inline-flex; align-items: center; gap: 0.5rem;
  padding: 0.45rem 0.85rem;
  border: 1px solid var(--ef-rule);
  border-radius: 8px;
  background: var(--ef-bg);
  color: var(--ef-text);
  text-decoration: none;
  transition: border-color 0.15s, color 0.15s;
}
.ucp-nav-btn:hover {
  border-color: var(--ef-accent);
  color: var(--ef-accent);
  text-decoration: none;
}
.ucp-nav-hex {
  font-family: var(--spec-font-mono);
  font-size: 0.72rem;
  color: var(--ef-text-3);
}
.ucp-nav-btn:hover .ucp-nav-hex { color: var(--ef-accent); }
.ucp-nav-current {
  font-family: var(--spec-font-mono);
  font-size: 0.85rem;
  color: var(--ef-text-3);
}
.ucp-nav-spacer { width: 80px; }

.ucp-glyph-area {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4rem 1rem 2.5rem;
  background: var(--ef-surface);
  border: 1px solid var(--ef-rule);
  border-radius: 12px;
  margin-bottom: 1.5rem;
  position: relative;
  min-height: 220px;
}
.ucp-glyph-stage {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 8rem;
  padding: 0.5rem 3rem;
}
.ucp-guides { position: absolute; inset: 0; pointer-events: none; }
.ucp-guide { position: absolute; left: 0; right: 0; height: 0; }
.ucp-guide--cap { top: 12%; border-top: 1px dashed rgba(0,0,0,0.18); }
.ucp-guide--xheight { top: 32%; border-top: 1px dashed rgba(0,0,0,0.14); }
.ucp-guide--baseline { bottom: 18%; border-top: 2px solid rgba(184,71,95,0.40); }

.ucp-glyph {
  position: relative;
  z-index: 1;
  font-family: var(--spec-font-glyph);
  font-size: 6.5rem;
  line-height: 1;
  color: var(--ef-text);
}
.ucp-glyph-system {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif !important;
}

.ucp-control-box {
  font-family: var(--spec-font-mono);
  font-size: 2.5rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  color: var(--ef-text-3);
  padding: 1rem 2rem;
  border: 2px dashed var(--ef-rule-strong);
  border-radius: 8px;
  background: var(--ef-bg);
}

.ucp-compare-toggle {
  position: absolute;
  top: 1rem;
  right: 1rem;
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-family: var(--spec-font-mono);
  font-size: 0.66rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.35rem 0.7rem;
  background: var(--ef-bg);
  border: 1px solid var(--ef-rule);
  border-radius: 999px;
  color: var(--ef-text-2);
  cursor: pointer;
  transition: all 0.15s;
}
.ucp-compare-toggle:hover { border-color: var(--ef-accent); color: var(--ef-accent); }
.ucp-compare-toggle[aria-pressed="true"] {
  background: var(--ef-text);
  color: var(--ef-bg);
  border-color: var(--ef-text);
}
.ucp-compare-dot {
  display: inline-block;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: currentColor;
  opacity: 0.7;
}

.ucp-name {
  font-family: var(--spec-font-display);
  font-size: 1.6rem;
  font-weight: 600;
  margin: 0 0 0.3rem;
  color: var(--ef-text);
  letter-spacing: -0.01em;
}
.ucp-name-abbrev {
  font-family: var(--spec-font-mono);
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--ef-text-3);
  margin-left: 0.5rem;
}
.ucp-hex {
  font-family: var(--spec-font-mono);
  font-size: 1.1rem;
  color: var(--ef-accent);
}

.ucp-donor-banner {
  margin: 1rem 0 0.5rem;
}

/* The Tabs container replaces the old .ucp-sections grid. Panels
   stack vertically; the tabstrip handles horizontal navigation.
   Each panel is full-width on its own — denser than the old grid
   but matches the long-form char-page pattern. */
.ucp-section { max-width: 720px; }
.ucp-section h2 {
  font-family: var(--spec-font-mono);
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--ef-accent);
  margin: 0 0 0.75rem;
  padding-bottom: 0.4rem;
  border-bottom: 1px solid var(--ef-rule);
}
.ucp-section dl {
  display: grid;
  grid-template-columns: max-content 1fr;
  gap: 0.5rem 1rem;
  margin: 0;
  font-size: 0.88rem;
}
.ucp-section dt {
  font-family: var(--spec-font-mono);
  font-size: 0.7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--ef-text-3);
  white-space: nowrap;
  padding-top: 0.18rem;
}
.ucp-section dd {
  margin: 0;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
  color: var(--ef-text);
}
.ucp-section dd a { color: var(--ef-accent); text-decoration: none; }
.ucp-section dd a:hover { text-decoration: underline; }
.ucp-section dd code {
  font-family: var(--spec-font-mono);
  font-size: 0.75rem;
  background: var(--ef-surface);
  padding: 0.1rem 0.35rem;
  border-radius: 3px;
  color: var(--ef-text-2);
}

.ucp-copy {
  font-family: var(--spec-font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.15rem 0.5rem;
  background: transparent;
  border: 1px solid var(--ef-rule);
  border-radius: 2px;
  color: var(--ef-text-2);
  cursor: pointer;
  transition: all 0.15s;
}
.ucp-copy:hover { border-color: var(--ef-accent); color: var(--ef-accent); }

.ucp-provenance-note {
  grid-column: 1 / -1;
  font-family: var(--spec-font-display);
  font-size: 0.88rem;
  font-style: italic;
  line-height: 1.5;
  color: var(--ef-text-2);
  margin: 1rem 0 0;
  padding-top: 0.8rem;
  border-top: 1px dashed var(--ef-rule);
}
.ucp-provenance-note a { color: var(--ef-accent); text-decoration: none; }
.ucp-provenance-note a:hover { text-decoration: underline; }

.ucp-donor-link, .ucp-svg-link {
  font-family: var(--spec-font-mono);
  font-size: 0.85rem;
  color: var(--ef-accent) !important;
  text-decoration: none;
}
.ucp-donor-link:hover, .ucp-svg-link:hover { text-decoration: underline; }
.ucp-link-arrow { opacity: 0.6; margin-left: 0.2em; }

@media (max-width: 600px) {
  .ucp-glyph { font-size: 4.5rem; }
  .ucp-glyph-area { padding: 3rem 1rem 2rem; min-height: 180px; }
  .ucp-nav { padding: 0; }
