---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadStats } from '../../lib/stats';
import { formatBytes, formatNumber } from '../../lib/ssr';

const stats = loadStats();

const useCases = [
  {
    no: 'Plate I',
    persona: 'Operating-system user',
    goal: 'I want my OS to never show tofu, in any app that respects the system font fallback chain.',
    pick: 'Essenfont-Regular.ttc',
    pickWhy: 'The canonical install. macOS Font Book, Windows Font Settings, and Linux fontconfig all enumerate the five faces inside the collection.',
    how: [
      `<strong>macOS.</strong> Double-click the TTC → Font Book lists five faces (BMP, SMP, SIP, TIP, SSP) → "Install All".`,
      `<strong>Windows.</strong> Right-click → "Install for all users". Faces appear individually in app font menus.`,
      `<strong>Linux.</strong> <code>cp Essenfont-Regular.ttc ~/.local/share/fonts/ &amp;&amp; fc-cache -fv</code>.`,
    ],
    considerations: [
      'Some older apps cannot enumerate TTC faces — they see only the first face (BMP). For those, install per-plane TTFs alongside.',
      "Font Book shows five faces; pick the one that matches the script you need, or just enable all five.",
      'After install, set Essenfont as the last item in every app font list — it activates only when no earlier entry covers the codepoint.',
    ],
  },
  {
    no: 'Plate II',
    persona: 'Web developer',
    goal: 'I want any character a visitor types or pastes to render — even if their device has no local font for it.',
    pick: 'Per-block WOFF2 with <code>unicode-range</code>',
    pickWhy: '209 small subsets, one per Unicode block. The browser fetches only the blocks the page actually renders. Cyrillic page = ~30 KB downloaded, not the full 95 MB catalog.',
    how: [
      'Link the catalog CSS: <code>&lt;link rel="stylesheet" href="https://essenfont.github.io/fonts.css"&gt;</code>',
      'Or self-host by cloning <code>public/fonts/</code> and matching subset rules to your own <code>@font-face</code>.',
      'Add <code>font-display: swap</code> to every rule so the fallback renders first and Essenfont swaps in when ready.',
    ],
    considerations: [
      '<strong>Bandwidth.</strong> A page using only one script block downloads ~30 KB of font data. With five CSS rules (per-plane) the visitor downloads ~12 MB minimum even if no rare characters appear.',
      '<strong>Hosting.</strong> Per-block WOFF2s must be served from a CDN or web server that supports ranged responses. GitHub Pages serves them fine.',
      "<strong>Fallback chain.</strong> Pair with <code>\"Noto Sans\", system-ui, sans-serif</code> — without that fallback, a network failure shows unstyled glyphs instead of whatever the OS would have rendered.",
      '<strong>CORS.</strong> Self-hosted WOFF2s may need <code>Access-Control-Allow-Origin</code> set on your CDN if you also load them cross-origin.',
    ],
  },
  {
    no: 'Plate III',
    persona: 'Desktop application developer',
    goal: 'I bundle a font with my application so users get full Unicode coverage without installing anything system-wide.',
    pick: 'Per-plane TTFs',
    pickWhy: 'Five single-face fonts your installer can drop into the platform-appropriate font directory. The TTC is unreachable to apps that enumerate fonts via direct file reads; TTFs work everywhere.',
    how: [
      'macOS app bundle: <code>MyApp.app/Contents/Resources/Fonts/Essenfont-BMP.ttf</code> + register with <code>CTFontManagerRegisterFontsForURL</code> on first launch.',
      'Windows installer: copy TTFs to <code>%LOCALAPPDATA%\\MyApp\\Fonts\\</code> and add to the per-user font registry.',
      "Linux Flatpak/Snap: bundle as part of the sandbox's font directory.",
    ],
    considerations: [
      '<strong>BMP alone is ~12 MB.</strong> Bundling all five planes pushes to ~50 MB. Pick the planes your user base actually needs — most desktop apps never see Tangut (TIP) or CJK Ext J (TIP).',
      "<strong>License.</strong> Bundling is redistribution under OFL terms — include <code>LICENSE.txt</code> in your installer and link to the project's name-table attribution. See Plate&nbsp;VI.",
      '<strong>Registration vs runtime.</strong> Better to register once at install time than to load via <code>QFontDatabase::addApplicationFont</code> on every launch.',
    ],
  },
  {
    no: 'Plate IV',
    persona: 'PDF or document author',
    goal: 'I need a font embedded in a PDF or Office document that survives copy-archive, e-mail, and re-render across reader apps.',
    pick: 'Per-plane TTF (PDF ≤ 1.7) or per-plane WOFF2 (PDF 2.0)',
    pickWhy: 'PDF readers must embed the actual font — they cannot pull a fallback at view time. Per-plane is the smallest defensible bundle.',
    how: [
      'Generators like LaTeX, pdfTeX, InDesign: add the TTFs to your font directory and load via <code>\\usepackage{fontspec}</code> or the equivalent.',
      'LaTeX <code>\\setmainfont{Essenfont}</code> auto-loads every face referenced by glyph commands; use <code>Renderer=HarfBuzz</code> for Unicode 17 block support.',
      'For Office / DOCX: convert TTFs to OTF with <code>fonttools</code> and embed. Be aware some Office builds reject files larger than ~30 MB.',
    ],
    considerations: [
      '<strong>Subsetting matters.</strong> Most PDF generators subset embedded fonts to only the glyphs the document uses. A PDF containing only Cyrillic would carry only 118 glyphs of Essenfont — not 62,000.',
      '<strong>PDF/X, PDF/A.</strong> Compliance profiles often require fonts to be fully embedded and readable. Distribute the full TTF, not a name-table-only stub.',
      '<strong>glyf vs CFF2.</strong> The Essenfont TTC ships glyf outlines, which every PDF reader accepts. If you bring your own CFF2 build, expect older readers (pre-2024) to refuse it.',
    ],
  },
  {
    no: 'Plate V',
    persona: 'System administrator',
    goal: 'I push fonts to a few hundred workstations via Ansible / Puppet / Munki / Intune and want one artifact that registers everywhere.',
    pick: 'Essenfont-Regular.ttc',
    pickWhy: 'One file deploy. fontconfig (Linux), Windows Font Service, and macOS Profile Manager all enumerate the TTC and register each face. One install packet, five registered fonts.',
    how: [
      "Ansible: ship via <code>fontist install</code> on each host — Idempotent, registers via the OS's preferred path.",
      "macOS: deploy the .ttc through Profile Manager as a managed font — ships as a managed-by-org install.",
      "Linux fleet: place in <code>/usr/share/fonts/</code> and run <code>fc-cache -fv</code>. Or use the <code>fonts-essenfont</code> package on distros that carry it.",
    ],
    considerations: [
      "<strong>fc-cache invalidation.</strong> Existing fontconfig caches don't pick up the new faces until <code>fc-cache -fv</code> runs. Bake it into your puppet/ansible task chain.",
      '<strong>Conflict with other fallbacks.</strong> If users already have a Last-Resort Font or similar universal fallback registered, you may want to remove those first to avoid duplicate coverage in font lists.',
      '<strong>Tagged releases.</strong> Pin your config management to a specific <code>v0.X</code> tag — not <code>latest</code> — so OS image rebuilds get reproducible font versions.',
    ],
  },
  {
    no: 'Plate VI',
    persona: 'Package author (npm / Cargo / PyPI)',
    goal: "I publish a library that ships a font asset alongside its logic, and I want tree-shaking to keep the payload small.",
    pick: 'Per-plane WOFF2 (or subset WOFF2 built specifically for the use case)',
    pickWhy: 'WOFF2 gives ~50% smaller files than TTF and is universally supported by modern bundlers. Users get one dependency; tree-shaking or subpath imports let them grab only the plane they need.',
    how: [
      'Bundle the per-plane WOFF2s into your package, expose subpath imports (e.g. <code>@yourorg/yourpkg/font-bmp</code>), and let consumers pick by need.',
      'For a UI component library that needs only Latin + common symbols, ship <code>basic-latin.woff2</code> + <code>general-punctuation.woff2</code> as default assets and let other scripts be optional.',
      "Document the license in your package — OFL on the BinaryFont.woff2 assets, FSung non-commercial restriction on the CJK portion.",
    ],
    considerations: [
      '<strong>Cache busting.</strong> Hash the WOFF2 filenames and rewrite CSS to pull the hashed path — avoids stale asset bugs that versions alone cannot catch.',
      '<strong>TypeScript types.</strong> If you expose a TypeScript API, ship a <code>.d.ts</code> that points at the font path so consumers get autocomplete on the asset URL.',
      '<strong>Bundler limit.</strong> Webpack 5, Vite, and Rollup all have a 4 GB default asset size cap. The full ~95 MB of per-block WOFF2s would trigger it — exclude fonts from the standard bundler pipeline and ship them as separate downloads.',
    ],
  },
];

const matrix = [
  // [format, browser, desktop, pdf, code-embed, sizeperfile, relnote]
  ['Whole TTC (.ttc)',         { browser: '✗', desktop: '✓', pdf: '✓', embed: '✓', size: formatBytes(stats.fontBinaries.ttcSizeBytes), note: 'all 5 faces; canonical install' }],
  ['Per-plane TTF (×5)',       { browser: '△', desktop: '✓', pdf: '✓', embed: '✓', size: '~3–14 MB each', note: 'legacy PDF, app bundles' }],
  ['Per-plane WOFF2 (×5)',     { browser: '✓', desktop: '✗', pdf: '△', embed: '✓', size: '~2–7 MB each', note: '@font-face whole-plane' }],
  ['Per-block WOFF2 (×209)',   { browser: '✓', desktop: '✗', pdf: '✗', embed: '✓', size: formatBytes(stats.websiteSubsets.woff2TotalBytes) + ' total', note: 'this site uses these' }],
];

const formats = [
  { code: 'ttc', name: 'TrueType Collection — .ttc (canonical)', desc: 'Five glyf subfonts in one container. Install once, registered as five faces. The desktop canonical form.', gotcha: "Older font pickers in legacy apps can't enumerate TTC and only see the first face." },
  { code: 'pttf', name: 'Per-plane TTF — ×5', desc: 'Five single-face TTFs, one per Unicode plane. BMP / SMP / SIP / TIP / SSP.', gotcha: 'The plane naming on the font\'s `name` table is what your app\'s font picker displays — verify on macOS that "Essenfont BMP" matches what you expect.' },
  { code: 'pwoff2', name: 'Per-plane WOFF2 — ×5', desc: 'Five plane-wide WOFF2s for @font-face. Coverage per CSS rule = one whole plane. Larger but simpler than per-block.', gotcha: 'BMP.web2 is ~2 MB compressed; SIP is ~14 MB. A four-plane site downloads ~25 MB minimum even if no rare characters render.' },
  { code: 'bwoff2', name: 'Per-block WOFF2 — ×209', desc: '209 small WOFF2s, one per Unicode block. Each one matches a single block in fonts.css with unicode-range. Optimal bandwidth.', gotcha: "The catalog is large (209 CSS rules). Minify the CSS and serve from a CDN with compression-on to keep payload reasonable." },
];

const troubleshooting = [
  {
    problem: 'A character renders as a tofu box in Chrome even though you linked the per-block CSS.',
    cause: "Chrome's OpenType Sanitizer (OTS) rejected the WOFF2 silently. The network panel shows 200 OK; document.fonts.load() rejects with 'A network error occurred'.",
    fix: "Re-encode the WOFF2 through `fontisan convert file.ttf --to woff2` — it handles OTS constraints (head.modified timestamp outside 1-hour window, per-glyph padding to 4-byte boundary, Brotli mode = :font, CFF2 IndexBuilder offset packing) that bespoke encoders silently violate. See /engineering/coverage for the full list.",
  },
  {
    problem: "Your CSS lists `unicode-range: U+4E00-9FFF` but the browser fetches every per-block WOFF2.",
    cause: "If a per-block WOFF2's true cmap range is broader than the unicode-range you declared, the browser uses yours and still considers the file for fallback.",
    fix: "Inspect the per-block cmap with `fonttools ttLib --tables cmap file.woff2` and tighten your CSS unicode-range to match.",
  },
  {
    problem: "An app only sees the BMP face from your TTC install.",
    cause: "The app doesn't enumerate TTC containers — it reads TTF/OTF files individually.",
    fix: 'Install the per-plane TTFs alongside the TTC. Most modern apps enumerate TTC first; legacy apps fall back to the first matching single-face file.',
  },
  {
    problem: "PDF generators refuse the CFF2 TTC with 'unsupported font format'.",
    cause: "PDF generators below late 2023 can't parse CFF2 charstrings in embedded subsets.",
    fix: 'Use the per-plane TTFs (glyf) for PDFs — universally accepted, smaller per file, and what every PDF reader expects.',
  },
];
---
<BaseLayout
  title="How to use Essenfont — Docs"
  description="Which Essenfont format to use (TTC, per-plane TTF, per-plane WOFF2, per-block WOFF2), when to use each, and how to wire it into your OS, website, app, PDF, fleet, or npm package. With diagrams and a decision matrix."
  canonical="/docs/usage"
>
  <article class="usage">
    <header class="usage-hero">
      <p class="eyebrow">Docs · I</p>
      <h1>How to use Essenfont</h1>
      <p class="lede">
        The build ships four artifacts — one whole TTC (canonical), five per-plane TTFs, five per-plane WOFF2s, and 209 per-block WOFF2 subsets. Which one you grab depends on what you're trying to do. This page walks you through the six common scenarios, the tradeoffs of each format, and the gotchas that surface when you wire it in.
      </p>
    </header>

    <!-- ─────────────── Quick start ─────────────── -->
    <section class="quickstart" id="quickstart">
      <h2>Quick start</h2>
      <p class="qs-intro">
        Three questions, three answers. Pick the one that matches your situation; everything below is the deep dive.
      </p>
      <div class="qs-grid">
        <a href="#plate-i" class="qs-card">
          <span class="qs-num">A</span>
          <h3>I want my computer to never show tofu</h3>
          <p>Download the TTC, install via Font Book / Font Settings / <code>fc-cache</code>.</p>
          <code class="qs-cmd">fontist install "Essenfont"</code>
          <span class="qs-cta">Plate I →</span>
        </a>
        <a href="#plate-ii" class="qs-card">
          <span class="qs-num">B</span>
          <h3>I'm building a website</h3>
          <p>Link the catalog CSS. The browser fetches per-block WOFF2 subsets on demand.</p>
          <code class="qs-cmd">&lt;link rel="stylesheet" href="https://essenfont.github.io/fonts.css"&gt;</code>
          <span class="qs-cta">Plate II →</span>
        </a>
        <a href="#plate-iii" class="qs-card">
          <span class="qs-num">C</span>
          <h3>I'm a developer (app / PDF / npm)</h3>
          <p>Pick per-plane TTFs for app bundles and PDFs, per-plane WOFF2s for npm packages.</p>
          <code class="qs-cmd">npm install essenfont</code>
          <span class="qs-cta">Plates III–VI →</span>
        </a>
      </div>
    </section>

    <!-- ─────────────── What Essenfont does ─────────────── -->
    <section class="renders" aria-label="What Essenfont does">
      <svg class="diagram reliability" viewBox="0 0 680 200" role="img" aria-labelledby="reliability-title">
        <title id="reliability-title">Render reliability — tofu to glyph</title>
        <desc>Two panels separated by an arrow. Left: "Without Essenfont" showing a tofu box with hex codepoint label "U+1200C". Right: "With Essenfont" showing the actual Egyptian hieroglyph rendered.</desc>

        <g font-family="IBM Plex Mono, monospace" font-size="11" fill="var(--spec-ink, #1c1a18)">
          <text x="170" y="20" text-anchor="middle" font-weight="600" opacity="0.6">WITHOUT ESSENFONT</text>
          <rect x="100" y="40" width="140" height="120" fill="none" stroke="var(--spec-ink, #1c1a18)" stroke-width="1.5" stroke-dasharray="4 3" opacity="0.6"/>
          <text x="170" y="105" text-anchor="middle" font-size="36" font-family="Spectral, serif" opacity="0.4">▢</text>
          <text x="170" y="135" text-anchor="middle" font-size="10" opacity="0.6">U+1200C</text>
          <text x="170" y="180" text-anchor="middle" font-style="italic" opacity="0.55">tofu box, no glyph</text>
        </g>

        <g>
          <line x1="290" y1="100" x2="380" y2="100" stroke="var(--ef-rose, #bf4e6a)" stroke-width="2" marker-end="url(#arrow-reliability)"/>
          <text x="335" y="92" text-anchor="middle" font-family="IBM Plex Mono, monospace" font-size="9" fill="var(--ef-rose, #bf4e6a)">install</text>
        </g>

        <g font-family="IBM Plex Mono, monospace" font-size="11" fill="var(--spec-ink, #1c1a18)">
          <text x="510" y="20" text-anchor="middle" font-weight="600" fill="var(--ef-rose, #bf4e6a)">WITH ESSENFONT</text>
          <rect x="440" y="40" width="140" height="120" fill="rgba(191,78,106,0.06)" stroke="var(--ef-rose, #bf4e6a)" stroke-width="1.5"/>
          <text x="510" y="115" text-anchor="middle" font-size="56" font-family="Spectral, serif" fill="var(--spec-ink, #1c1a18)">𓀌</text>
          <text x="510" y="135" text-anchor="middle" font-size="10" opacity="0.6">U+1200C</text>
          <text x="510" y="180" text-anchor="middle" font-style="italic" fill="var(--ef-rose, #bf4e6a)">real glyph, donor-derived</text>
        </g>

        <defs>
          <marker id="arrow-reliability" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto">
            <path d="M0,0 L10,5 L0,10 Z" fill="var(--ef-rose, #bf4e6a)"/>
          </marker>
        </defs>
      </svg>
      <p class="cap">What Essenfont does in one picture: replaces the universal tofu box with the donor's real outline. The OS font fallback chain handles the routing.</p>
    </section>

    <!-- ─────────────── I. Format zoo ─────────────── -->
    <section class="chap" id="zoo">
      <p class="chap-num">I</p>
      <h2>The format zoo</h2>
      <p>
        One Ruby build (<a href="/engineering/pipeline">/engineering/pipeline</a>) produces four shapes of the same font. Each targets a different audience:
      </p>

      <svg class="diagram anatomy" viewBox="0 0 680 380" role="img" aria-labelledby="anatomy-title">
        <title id="anatomy-title">Anatomy of Essenfont-Regular.ttc</title>
        <desc>A rounded rectangle labelled "Essenfont-Regular.ttc" containing five stacked sub-rects, each labelled with plane, Unicode range, and approximate codepoint count.</desc>
        <rect x="10" y="10" width="660" height="360" rx="6" ry="6"
              fill="none" stroke="var(--spec-ink, #1c1a18)" stroke-width="2"/>
        <rect x="10" y="10" width="660" height="44" rx="6" ry="6"
              fill="var(--spec-ink, #1c1a18)"/>
        <rect x="10" y="46" width="660" height="8" fill="var(--spec-ink, #1c1a18)"/>
        <text x="30" y="38" fill="var(--spec-paper, #f1ece1)" font-family="IBM Plex Mono, monospace" font-size="14" font-weight="600">Essenfont-Regular.ttc  ·  TrueType Collection</text>
        <text x="566" y="38" fill="var(--spec-paper, #f1ece1)" font-family="IBM Plex Mono, monospace" font-size="11">format</text>

        <g font-family="Spectral, serif" fill="var(--spec-ink, #1c1a18)">
          {[
            { y: 80,  code: 'BMP', name: 'Basic Multilingual Plane',         range: 'U+0000 – U+FFFF',     cps: '~62,098 codepoints', note: 'Latin, Cyrillic, Arabic, CJK BMP, common symbols' },
            { y: 140, code: 'SMP', name: 'Supplementary Multilingual Plane',  range: 'U+10000 – U+1FFFF',   cps: '~9,012 codepoints',  note: 'Emoji, music, math, historical scripts' },
            { y: 200, code: 'SIP', name: 'Supplementary Ideographic Plane',  range: 'U+20000 – U+2FFFF',   cps: '~60,219 codepoints', note: 'CJK Extensions B/C/D/E/F/I' },
            { y: 260, code: 'TIP', name: 'Tertiary Ideographic Plane',       range: 'U+30000 – U+3FFFF',   cps: '~6,003 codepoints',  note: 'CJK Ext C+J, Tangut, Khitan' },
            { y: 320, code: 'SSP', name: 'Supplementary Special-purpose Plane', range: 'U+E0000 – U+EFFFF', cps: '~99 codepoints',     note: 'Language tags' },
          ].map(plane => (
            <g>
              <rect x="34" y={plane.y} width="612" height="48" rx="3" ry="3"
                    fill="none" stroke="var(--spec-ink, #1c1a18)" stroke-width="1.2"/>
              <rect x="34" y={plane.y} width="58" height="48" rx="3" ry="3"
                    fill="var(--ef-rose, #bf4e6a)"/>
              <text x="63" y={plane.y + 30} text-anchor="middle" fill="var(--spec-paper, #f1ece1)"
                    font-family="IBM Plex Mono, monospace" font-size="14" font-weight="600">{plane.code}</text>
              <text x="110" y={plane.y + 20} font-size="13" font-weight="600">{plane.name}</text>
              <text x="110" y={plane.y + 38} font-family="IBM Plex Mono, monospace" font-size="10" fill="var(--spec-ink, #1c1a18)" opacity="0.7">{plane.range}  ·  {plane.cps}</text>
              <text x="640" y={plane.y + 30} text-anchor="end" font-size="10" font-style="italic" fill="var(--spec-ink, #1c1a18)" opacity="0.6">{plane.note}</text>
            </g>
          ))}
        </g>
      </svg>
      <p class="cap">Anatomy of one TTC envelope. Five plane subfonts, each under the 65,535-glyph cap. Down-stream consumers see either one font (if they enumerate collections) or only the first face (if they don't).</p>

      <ul class="format-list">
        {formats.map(f => (
          <li>
            <strong>{f.name}.</strong> {f.desc} <em class="gotcha">Gotcha — {f.gotcha}</em>
          </li>
        ))}
      </ul>
    </section>

    <!-- ─────────────── II. Pick your scenario ─────────────── -->
    <section class="chap" id="scenarios">
      <p class="chap-num">II</p>
      <h2>Pick your scenario</h2>
      <p>
        Six common personas, each with a recommended format, the install/wiring steps, and the considerations that come with that choice. Pick the one that maps to what you are.
      </p>

      <svg class="diagram tree" viewBox="0 0 680 280" role="img" aria-labelledby="tree-title">
        <title id="tree-title">Decision tree — which format for which goal</title>
        <desc>A tree starting from "What do you want to do?" branching into six goals, each pointing to the recommended format.</desc>

        <g font-family="IBM Plex Mono, monospace" font-size="10" fill="var(--spec-ink, #1c1a18)">
          <rect x="240" y="10" width="200" height="36" rx="4" ry="4" fill="var(--spec-ink, #1c1a18)"/>
          <text x="340" y="33" text-anchor="middle" fill="var(--spec-paper, #f1ece1)" font-weight="600">What do you want to do?</text>

          <line x1="340" y1="46" x2="340" y2="68" stroke="var(--spec-ink, #1c1a18)" stroke-width="1.5"/>
          <line x1="50" y1="68" x2="650" y2="68" stroke="var(--spec-ink, #1c1a18)" stroke-width="1.5"/>
          {[
            { x: 50,  goal: 'Install on my OS',           fmt: 'TTC' },
            { x: 150, goal: 'Embed in a website',         fmt: 'Per-block WOFF2' },
            { x: 270, goal: 'Bundle with my app',         fmt: 'Per-plane TTF' },
            { x: 380, goal: 'Embed in a PDF / document',  fmt: 'Per-plane TTF' },
            { x: 490, goal: 'Deploy across a fleet',      fmt: 'TTC' },
            { x: 590, goal: 'Ship via npm',               fmt: 'Per-plane WOFF2' },
          ].map(b => (
            <g>
              <line x1={b.x + 30} y1="68" x2={b.x + 30} y2="100" stroke="var(--spec-ink, #1c1a18)" stroke-width="1.5"/>
              <rect x={b.x} y="100" width="100" height="56" rx="3" ry="3" fill="none" stroke="var(--spec-ink, #1c1a18)" stroke-width="1.2"/>
              <text x={b.x + 50} y="124" text-anchor="middle">{b.goal}</text>
              <line x1={b.x + 50} y1="156" x2={b.x + 50} y2="186" stroke="var(--ef-rose, #bf4e6a)" stroke-width="1.5" stroke-dasharray="3 3"/>
              <rect x={b.x - 10} y="186" width="120" height="32" rx="3" ry="3" fill="var(--ef-rose, #bf4e6a)"/>
              <text x={b.x + 50} y="206" text-anchor="middle" fill="var(--spec-paper, #f1ece1)" font-weight="700">{b.fmt}</text>
            </g>
          ))}
          <text x="340" y="252" text-anchor="middle" font-size="9" font-style="italic" opacity="0.55">dashed lines = pick the format that maps to your goal · the plates below walk through each one</text>
        </g>
      </svg>
      <p class="cap">Decision tree. Start at the top, find your goal, follow the dashed line to the recommended format.</p>

      <div class="plates">
        {useCases.map(uc => (
          <article class="plate" id={'plate-' + uc.no.toLowerCase().replace(/[^a-z]+/g, '-')}>
            <header class="plate-head">
              <span class="plate-num">{uc.no}</span>
              <h3>{uc.persona}</h3>
            </header>
            <p class="plate-goal"><em>"{uc.goal}"</em></p>
            <div class="plate-pick">
              <span class="plate-label">Pick</span>
              <code>{uc.pick}</code>
            </div>
            <p class="plate-pick-why">{uc.pickWhy}</p>
            <details>
              <summary><span class="plate-label">How</span></summary>
              <ul>
                {uc.how.map(h => <li set:html={h} />)}
              </ul>
            </details>
            <details>
              <summary><span class="plate-label">Considerations</span></summary>
              <ul>
                {uc.considerations.map(c => <li set:html={c} />)}
              </ul>
            </details>
          </article>
        ))}
      </div>
    </section>

    <!-- ─────────────── III. Decision matrix ─────────────── -->
    <section class="chap" id="matrix">
      <p class="chap-num">III</p>
      <h2>Decision matrix</h2>
      <p>
        Cross-reference for the six formats. ✓ = first-class support. △ = depends on consumer (declared in note). ✗ = not supported.
      </p>
      <div class="matrix-wrap">
        <table class="matrix">
          <thead>
            <tr>
              <th>Format</th>
              <th>Browser</th>
              <th>Desktop</th>
              <th>PDF</th>
              <th>App / pkg</th>
              <th>File size</th>
              <th>Notes</th>
            </tr>
          </thead>
          <tbody>
            {matrix.map(([fmt, m]) => (
              <tr>
                <th scope="row">{fmt}</th>
                <td class={'cell-' + (m.browser === '✓' ? 'yes' : m.browser === '△' ? 'some' : 'no')}>{m.browser}</td>
                <td class={'cell-' + (m.desktop === '✓' ? 'yes' : m.desktop === '△' ? 'some' : 'no')}>{m.desktop}</td>
                <td class={'cell-' + (m.pdf === '✓' ? 'yes' : m.pdf === '△' ? 'some' : 'no')}>{m.pdf}</td>
                <td class={'cell-' + (m.embed === '✓' ? 'yes' : m.embed === '△' ? 'some' : 'no')}>{m.embed}</td>
                <td class="num">{m.size}</td>
                <td>{m.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <svg class="diagram sizes" viewBox="0 0 680 240" role="img" aria-labelledby="sizes-title">
        <title id="sizes-title">File size comparison on a log scale</title>
        <desc>Horizontal bar chart comparing the four formats' representative payload. Per-block WOFF2 has tiny individual files but the full catalog adds up.</desc>
        <g font-family="IBM Plex Mono, monospace" font-size="11" fill="var(--spec-ink, #1c1a18)">
          {[
            { y: 25,  label: 'Whole TTC',                width: 480, value: '~99 MB',         shade: 'var(--ef-rose, #bf4e6a)' },
            { y: 65,  label: 'Per-plane TTF (×5)',       width: 130, value: '~3–14 MB each',  shade: '#8a8478' },
            { y: 105, label: 'Per-plane WOFF2 (×5)',     width: 75,  value: '~2–7 MB each',   shade: '#8a8478' },
            { y: 145, label: 'Per-block TOTAL (×209)',   width: 460, value: '~95 MB',         shade: '#8a8478' },
            { y: 185, label: 'Per-block ONE file',       width: 6,   value: '~30 KB',         shade: 'var(--ef-rose, #bf4e6a)' },
          ].map(b => (
            <g>
              <text x="0" y={b.y + 4}>{b.label}</text>
              <rect x="170" y={b.y - 8} width={b.width} height="14" fill={b.shade} opacity="0.85"/>
              <text x={180 + b.width} y={b.y + 4}>{b.value}</text>
            </g>
          ))}
        </g>
      </svg>
      <p class="cap">File-size comparison. Per-block WOFF2 looks small per file but the full catalog approaches the TTC's size — the win is per-page download, not total payload.</p>
    </section>

    <!-- ─────────────── IV. Embedding patterns ─────────────── -->
    <section class="chap" id="patterns">
      <p class="chap-num">IV</p>
      <h2>Embedding patterns</h2>
      <p>
        The most common reason people land here: "I want to put Essenfont on a website, what's the right shape and the right CSS?" Three answers follow — pick whichever tradeoff fits your situation.
      </p>

      <h3>Pattern A · Per-block with <code>unicode-range</code> (best for most sites)</h3>
      <p>
        The browser fetches only the blocks the page actually renders. Cyrillic page = ~30 KB download. A multilingual forum might download eight blocks (~250 KB total). No code in your routes changes — the CSS handles everything.
      </p>

      <svg class="diagram fetch" viewBox="0 0 680 280" role="img" aria-labelledby="fetch-title">
        <title id="fetch-title">Per-block WOFF2 fetch sequence</title>
        <desc>Sequence diagram showing the browser fetching only the blocks it needs: HTML → /fonts.css → /fonts/Cyrillic.woff2 → glyph renders.</desc>
        <g font-family="IBM Plex Mono, monospace" font-size="11">
          <line x1="90" y1="20" x2="90" y2="260" stroke="var(--spec-ink, #1c1a18)" stroke-dasharray="3 3"/>
          <line x1="340" y1="20" x2="340" y2="260" stroke="var(--spec-ink, #1c1a18)" stroke-dasharray="3 3"/>
          <line x1="590" y1="20" x2="590" y2="260" stroke="var(--spec-ink, #1c1a18)" stroke-dasharray="3 3"/>
          <text x="90" y="14" text-anchor="middle" fill="var(--spec-ink, #1c1a18)" font-weight="600">Visitor</text>
          <text x="340" y="14" text-anchor="middle" fill="var(--spec-ink, #1c1a18)" font-weight="600">essenfont.github.io</text>
          <text x="590" y="14" text-anchor="middle" fill="var(--spec-ink, #1c1a18)" font-weight="600">Browser</text>

          <g>
            <line x1="90" y1="40" x2="340" y2="40" stroke="var(--ef-rose, #bf4e6a)" stroke-width="1.6" marker-end="url(#arrow)"/>
            <text x="215" y="34" text-anchor="middle" fill="var(--spec-ink, #1c1a18)">GET /unicode/cyrillic</text>
          </g>
          <g>
            <line x1="340" y1="65" x2="90" y2="65" stroke="var(--spec-ink, #1c1a18)" stroke-width="1.6" marker-end="url(#arrow)"/>
            <text x="215" y="59" text-anchor="middle" fill="var(--spec-ink, #1c1a18)">HTML referencing /fonts.css</text>
          </g>
          <g>
            <line x1="90" y1="95" x2="340" y2="95" stroke="var(--ef-rose, #bf4e6a)" stroke-width="1.6" marker-end="url(#arrow)"/>
            <text x="215" y="89" text-anchor="middle" fill="var(--spec-ink, #1c1a18)">GET /fonts.css (~6 KB, 209 rules)</text>
          </g>
          <g>
            <line x1="340" y1="120" x2="90" y2="120" stroke="var(--spec-ink, #1c1a18)" stroke-width="1.6" marker-end="url(#arrow)"/>
            <text x="215" y="114" text-anchor="middle" fill="var(--spec-ink, #1c1a18)">fonts.css with 209 @font-face rules</text>
          </g>
          <g>
            <line x1="90" y1="160" x2="590" y2="160" stroke="var(--ef-rose, #bf4e6a)" stroke-width="1.6" marker-end="url(#arrow)"/>
            <text x="340" y="154" text-anchor="middle" fill="var(--spec-ink, #1c1a18)">browser parses page, sees codepoints in Cyrillic block</text>
          </g>
          <g>
            <line x1="590" y1="190" x2="340" y2="190" stroke="var(--spec-ink, #1c1a18)" stroke-width="1.6" marker-end="url(#arrow)"/>
            <text x="465" y="184" text-anchor="middle" fill="var(--spec-ink, #1c1a18)">GET /fonts/Cyrillic.woff2 only</text>
          </g>
          <g>
            <line x1="340" y1="220" x2="590" y2="220" stroke="var(--ef-rose, #bf4e6a)" stroke-width="1.6" marker-end="url(#arrow)"/>
            <text x="465" y="214" text-anchor="middle" fill="var(--spec-ink, #1c1a18)">118 codepoints, ~30 KB</text>
          </g>
          <g>
            <line x1="590" y1="248" x2="90" y2="248" stroke="var(--spec-ink, #1c1a18)" stroke-width="1.6" marker-end="url(#arrow)"/>
            <text x="340" y="242" text-anchor="middle" fill="var(--spec-ink, #1c1a18)" font-weight="600">"Б" renders via Cyrillic.woff2</text>
          </g>
        </g>
        <defs>
          <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M0,0 L10,5 L0,10 Z" fill="var(--spec-ink, #1c1a18)"/>
          </marker>
        </defs>
      </svg>
      <p class="cap">The browser fetches one WOFF2 per Unicode block the page uses. Other 208 rules sit waiting in the stylesheet; never downloaded unless a page actually renders them.</p>

      <p>
        Wire it in three lines:
      </p>
      <pre class="code-block"><code>&lt;link rel="stylesheet" href="https://essenfont.github.io/fonts.css"&gt;
&lt;style&gt;
  body &#123; font-family: "Essenfont", "Noto Sans", system-ui, sans-serif; &#125;
&lt;/style&gt;</code></pre>
      <p>
        See <a href="/docs/css">/docs/css</a> for the full CSS reference (self-hosting, CORS, <code>font-display</code>, fallback chains).
      </p>

      <h3>Pattern B · Per-plane WOFF2 (simpler, larger)</h3>
      <p>
        Five CSS rules, one per plane, no <code>unicode-range</code> math. Whole font embedded, larger minimum payload.
      </p>
      <pre class="code-block"><code>@font-face &#123;
  font-family: 'essenfont';
  src: url('/fonts/Essenfont-BMP.woff2') format('woff2');
  unicode-range: U+0000-FFFF;
&#125;
@font-face &#123;
  font-family: 'essenfont';
  src: url('/fonts/Essenfont-SMP.woff2') format('woff2');
  unicode-range: U+10000-1FFFF;
&#125;
/* repeat for SIP, TIP, SSP */

body &#123;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif, 'essenfont';
&#125;</code></pre>
      <p>
        Best when every page is likely to use several scripts and you don't want to think about per-block cached file counts. Less optimal when most pages are single-script.
      </p>

      <h3>Pattern C · CSS font-stack (no embed)</h3>
      <p>
        The cleanest fallback pattern for sites where most visitors have noto/system-ui already: list Essenfont last in the stack, declare <code>unicode-range</code> per subset so the browser knows when to fetch, and trust system fontconfig/OS picker to have a TTC installed for the rest.
      </p>
      <pre class="code-block"><code>/* If Essenfont is installed locally on the user's OS — perfect: */
/* no download happens, all codepoints render from the TTC. */
/* If it isn't, individual @font-face subsets fill in. */

font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif, 'Essenfont';</code></pre>
      <p class="considerations">
        The CSS in <a href="/docs/css">/docs/css</a> implements this: it lists a <code>"Essenfont"</code> family whose families are the per-block subsets, with <code>unicode-range</code> per block. The OS-installed TTC names itself differently per face (BMP/SMP/SIP/TIP/SSP), so the stack needs a system rule to pick them up if the visitor installed the font.
      </p>
    </section>

