---
import BaseLayout from '../../layouts/BaseLayout.astro';

const CDN_BASE = 'https://github.com/essenfont/essenfont/releases/latest/download';
const FONTIST_SNIPPET = `# Install the Fontist gem
gem install fontist

# Install Essenfont (downloads the TTC + registers it locally)
fontist install "Essenfont"`;

const NPM_SNIPPET = `# Add to package.json
npm install essenfont
# or yarn / pnpm / bun equivalent`;

const CURL_SNIPPET = `# macOS / Linux
curl -L -o Essenfont-Regular.ttc ${CDN_BASE}/Essenfont-Regular.ttc

# Windows (PowerShell)
Invoke-WebRequest ${CDN_BASE}/Essenfont-Regular.ttc -OutFile Essenfont-Regular.ttc`;

const PLANES = [
  { code: 'BMP', range: 'U+0000–U+FFFF',   file: 'Essenfont-BMP.woff2' },
  { code: 'SMP', range: 'U+10000–U+1FFFF', file: 'Essenfont-SMP.woff2' },
  { code: 'SIP', range: 'U+20000–U+2FFFF', file: 'Essenfont-SIP.woff2' },
  { code: 'TIP', range: 'U+30000–U+3FFFF', file: 'Essenfont-TIP.woff2' },
  { code: 'SSP', range: 'U+E0000–U+EFFFF', file: 'Essenfont-SSP.woff2' },
];
---
<BaseLayout
  title="Install — Docs — Essenfont"
  description="Install Essenfont via Fontist, npm, CDN, or direct download."
  canonical="/docs/install"
>
  <section class="container docs-page">
    <header class="docs-head">
      <p class="eyebrow">Docs · I</p>
      <h1>Install Essenfont</h1>
    </header>

    <p>
      Essenfont ships as a single TrueType Collection (TTC) containing
      CFF2 outlines + CBDT color bitmaps. It's also available as a
      TrueType Collection (TTC) fallback for tooling that doesn't yet
      support CFF2, and as per-block WOFF2 subsets for the web.
    </p>

    <h2 id="fontist">Fontist (recommended for tooling)</h2>
    <p>
      <a href="https://github.com/fontist/fontist">Fontist</a> is the
      Ruby-based font package manager. It downloads the TTC, registers
      it with the local font system, and tracks updates via
      <code>fontist update</code>.
    </p>
    <pre class="code-block"><code>{FONTIST_SNIPPET}</code></pre>

    <h2 id="npm">npm (for build pipelines)</h2>
    <p>
      Pull the TTC into any Node-based build (Vite, Astro, Next.js).
      The package exports the font path and TypeScript types.
    </p>
    <pre class="code-block"><code>{NPM_SNIPPET}</code></pre>

    <h2 id="direct">Direct download</h2>
    <p>
      Latest release binaries live at GitHub Releases. The TTC, per-plane TTFs,
      and per-plane TTFs are all there.
    </p>
    <pre class="code-block"><code>{CURL_SNIPPET}</code></pre>

    <h2 id="planes">Per-plane WOFF2 (web embed)</h2>
    <p>
      For sites that don't want the full TTC, the build also emits
      per-plane WOFF2 subsets. Each one covers its plane's entire
      assigned range via a single <code>@font-face</code> entry.
    </p>
    <table class="planes-table">
      <thead>
        <tr><th>Plane</th><th>Range</th><th>File</th></tr>
      </thead>
      <tbody>
        {PLANES.map(p => (
          <tr>
            <td>{p.code}</td>
            <td class="mono">{p.range}</td>
            <td class="mono">{p.file}</td>
          </tr>
        ))}
      </tbody>
    </table>

    <p class="next">
      Next: <a href="/docs/css">CSS integration →</a>
    </p>
  </section>
</BaseLayout>

<style>
  .docs-page { max-width: 760px; padding: 3rem 1.5rem 6rem; }
  .docs-head { margin-bottom: 2.5rem; }
  .eyebrow {
    font-family: var(--spec-font-mono, monospace);
    font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--ef-rose, #0d7377); margin: 0 0 0.5rem;
  }
  h1 {
    font-family: var(--spec-font-display);
    font-size: clamp(2rem, 5vw, 3rem); margin: 0;
  }
  p { line-height: 1.65; margin: 1rem 0; }
  h2 {
    font-family: var(--spec-font-display);
    font-size: 1.5rem;
    margin: 2.5rem 0 0.75rem;
    border-bottom: 1px solid var(--ef-rule, rgba(26, 24, 21, 0.08));
    padding-bottom: 0.5rem;
  }
  code {
    font-family: var(--spec-font-mono, monospace);
    font-size: 0.875em;
    background: var(--ef-surface, #f2efe9);
    padding: 0.1em 0.4em;
    border-radius: 2px;
  }
  .code-block {
    background: var(--ef-surface, #f2efe9);
    border: 1px solid var(--ef-rule, rgba(26, 24, 21, 0.08));
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1rem 0;
  }
  .code-block code {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--ef-text, #1a1815);
    white-space: pre;
  }
  .planes-table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9375rem;
  }
  .planes-table th, .planes-table td {
    text-align: left;
    padding: 0.625rem 0.75rem;
    border-bottom: 1px solid var(--ef-rule, rgba(26, 24, 21, 0.08));
  }
  .planes-table th {
    font-family: var(--spec-font-mono, monospace);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ef-text-3, #8a8478);
  }
  .mono { font-family: var(--spec-font-mono, monospace); font-size: 0.85em; }
  .next {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--ef-rule, rgba(26, 24, 21, 0.08));
  }
</style>
