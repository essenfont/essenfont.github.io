---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadStats } from '../../lib/stats';
import { formatBytes, formatNumber } from '../../lib/ssr';
import ReadingLayout from '../../components/ReadingLayout.vue';

const stats = loadStats();

const stages = [
  {
    step: '01',
    name: 'Read donors',
    what: `Open each of the ${stats.donorCount} donor files via fontisan's FontLoader.`,
    why: 'Each donor declares its license, its sha256, and the codepoint ranges it covers. The build refuses anything outside the OFL-compatible policy before a single glyph is read. Donors arrive in many shapes — TTF, OTF, TTC, WOFF2, even CBDT color-bitmap — so the loader normalizes them all into a single in-memory representation.',
  },
  {
    step: '02',
    name: 'Build the codepoint map (CpMap)',
    what: 'For every assigned Unicode 17 codepoint, decide which donor owns it.',
    why: "ucode's universal-set manifest is the authoritative per-codepoint donor assignment. The build filters out PUA, surrogate, and reserved codepoints, then backfills C0/C1 control and Cf format codepoints as .notdef entries so cmap parsers don't choke. CBDT-only color-bitmap donors (Noto Color Emoji) are kept out of the outline map so empty bitmaps don't pollute the outline glyph slots.",
  },
  {
    step: '03',
    name: 'Partition by plane',
    what: `Group the ${formatNumber(stats.unicode.assignedCodepointCount)} codepoints into named subfonts, each under the 65,535-glyph cap.`,
    why: "OpenType glyph IDs are 16-bit. One face physically cannot hold all assigned codepoints. The partitioner groups codepoints by Unicode plane — BMP, SMP, SIP, TIP, SSP — which is MECE, stable across Unicode version bumps, and discoverable in O(1) via `cp >> 16`. If a future Unicode version balloons a plane past the cap, the partitioner sub-splits by block; no block is ever torn across two subfonts.",
  },
  {
    step: '04',
    name: 'Stitch subfonts',
    what: "Copy each donor's outline glyphs into the right subfont via fontisan's Stitcher.",
    why: "Outlines are stitched first, so cmap.build's first-wins policy binds codepoints to real outline GIDs instead of empty placeholders. CBDT/CBLC color-bitmap tables are propagated afterward via raw-byte table_data reads — BinData round-trips don't preserve CFF2 cleanly, so the build reads tables as bytes and splices them. Each subfont gets its own name table (family, subfamily, PostScript name) from a single Naming module so the TTC's five faces are consistent.",
  },
  {
    step: '05',
    name: 'Pack the collection',
    what: 'Pass the compiled subfonts to Collection::Builder, which writes the TTC.',
    why: 'Tables are deduplicated by SHA256 across the five faces (the OS/2, head, hhea, name, post tables are nearly identical between planes). After writing, Fontisan::Collection::Reader opens the file back up and asserts face count, per-face glyph count ≤ 65,535, and cmap union size ≥ 99% of the input — any regression fails the build before it ships.',
  },
];

const planes = [
  { sym: ':plane_0', name: 'BMP', range: 'U+0000–U+FFFF', carries: 'World scripts — Latin, Cyrillic, Greek, Arabic, Hebrew, CJK ideographs, common symbols' },
  { sym: ':plane_1', name: 'SMP', range: 'U+10000–U+1FFFF', carries: 'Historical scripts, emoji, music, math symbols, alchemical symbols' },
  { sym: ':plane_2', name: 'SIP', range: 'U+20000–U+2FFFF', carries: 'CJK Unified Ideographs Extensions B / C / D / E / F / I' },
  { sym: ':plane_3', name: 'TIP', range: 'U+30000–U+3FFFF', carries: 'CJK Extension C + J, Tangut, Khitan Small Script' },
  { sym: ':plane_14', name: 'SSP', range: 'U+E0000–U+EFFFF', carries: 'Language tags (~100 codepoints)' },
];
---
<BaseLayout
  title="Build pipeline — Engineering — Essenfont"
  description="The five-stage assembly pipeline that turns X donor fonts into one Essenfont TTC: read donors, build the codepoint map, partition by plane, stitch subfonts, pack the collection."
  canonical="/docs/pipeline"
>
  <ReadingLayout client:visible>
    <article class="pipeline-page">
      <header class="page-head">
      <h1>The build pipeline</h1>
      <p class="lede">
        Essenfont is assembled, not drawn. Five stages take
        {stats.donorCount} donor fonts and produce one TrueType Collection
        with five plane subfonts, all reproducible from the committed
        manifest in <code>essenfont/essenfont</code>.
      </p>
    </header>

    <section class="prose" data-reading-article>
      <h2>The whole pipeline at a glance</h2>
      <pre class="flow"><code>   donor fonts (TTF / OTF / TTC / WOFF2 / CBDT)
            │
            ▼  Fontisan::FontLoader
   CpMap  ─── per-codepoint &#123; donor_label, gid &#125; ─── ucode's universal-set manifest
            │
            ▼  Essenfont::Otc::PlanePartitioner
   Blueprint ── 5 Partitions (BMP / SMP / SIP / TIP / SSP), each ≤ 65,484 glyphs
            │
            ▼  Essenfont::Otc::StitcherSession + Fontisan::Stitcher
   5 stitched subfonts (outlines + propagated CBDT/CBLC)
            │
            ▼  Fontisan::Collection::Builder  (table dedup by SHA256)
   Essenfont-Regular.ttc  ── validated by Fontisan::Collection::Reader</code></pre>

      <h2>The five stages, in detail</h2>
      <ol class="stages">
        {stages.map(s => (
          <li>
            <h3><span class="step">{s.step}</span> {s.name}</h3>
            <p class="what"><strong>What:</strong> {s.what}</p>
            <p class="why"><strong>Why:</strong> {s.why}</p>
          </li>
        ))}
      </ol>

      <h2>Why partition by plane: the 65,535-glyph cap</h2>
      <p>
        TrueType and OpenType address glyphs by a 16-bit ID, so a single face can hold at most 65,535 glyphs (one of which is reserved for <code>.notdef</code>). Unicode 17 has {formatNumber(stats.unicode.assignedCodepointCount)} assigned codepoints — nearly 2.5× the cap. There is no way around this: a single-face Essenfont is physically impossible.
      </p>
      <p>
        The partitioner splits the codepoint space across five subfonts,
        one per Unicode plane that carries assigned characters:
      </p>
      <table class="plane-table">
        <thead><tr><th>Subfont</th><th>Range</th><th>Carries</th></tr></thead>
        <tbody>
          {planes.map(p => (
            <tr>
              <td><code>{p.sym}</code> ({p.name})</td>
              <td>{p.range}</td>
              <td>{p.carries}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <p>
        Why planes (not script families, not blocks)?
      </p>
      <ul>
        <li>
          <strong>MECE.</strong> Every codepoint lives in exactly one plane. Planes tile the codepoint space without gaps and without overlap, so the partition is provably correct.
        </li>
        <li>
          <strong>Stable.</strong> Plane assignment never changes under a Unicode version bump — a codepoint's plane is fixed by its top 16 bits. Script-family boundaries drift; planes don't.
        </li>
        <li>
          <strong>O(1) lookup.</strong> <code>cp &gt;&gt; 16</code> gives the plane number directly. No table walks, no ambiguity.
        </li>
        <li>
          <strong>Semantically meaningful.</strong> BMP is world scripts, SMP/TIP is rare historical, SSP is tags. Each plane is a coherent unit to ship in one face.
        </li>
      </ul>
      <p>
        The default cap is <code>PlanePartitioner::DEFAULT_CAP = 65,484</code> (65,535 − 1 for <code>.notdef</code> − 50 safety margin). Today no plane exceeds it. If a future Unicode version balloons one — SIP is the most likely, as CJK grows — the partitioner falls back to a block-by-block sub-split: <code>plane_2_a</code>, <code>plane_2_b</code>, … never tearing a Unicode block across two subfonts.
      </p>

      <h2>Outline format: glyf vs CFF2</h2>
      <p>
        OpenType supports two outline formats:
      </p>
      <ul>
        <li>
          <strong>glyf (TrueType)</strong> — quadratic Béziers, hinting instructions, universally supported. The default <code>Essenfont-Regular.ttc</code> ships glyf subfonts.
        </li>
        <li>
          <strong>CFF2 (OpenType 1.8+)</strong> — cubic Béziers, variation stores, smaller files via subroutinization. The <code>Essenfont-CFF2-Regular.ttc</code> variant is ~35% smaller for the same coverage.
        </li>
      </ul>
      <p>
        CFF1 (the older <code>CFF&nbsp;</code> table) is not shipped — CFF2 strictly dominates it (variation support, smaller files, mixed-mode tables). The build picks the format with a single CLI flag: <code>--format=ttc</code> (canonical glyf TTC).
      </p>

      <h2>How color emoji survives into the TTC</h2>
      <p>
        Noto Color Emoji is the donor for emoticons, transport-and-map symbols, and other color-emoji blocks. Its glyphs are CBDT/CBLC (color bitmaps), not outlines. Two problems had to be solved:
      </p>
      <ul>
        <li>
          <strong>Don't let CBDT donors pollute the outline map.</strong> Noto Color Emoji's cmap entries initially leaked into the outline CpMap, planting empty <code>.notdef</code> placeholders in every face. The build now filters CBDT-only donors out of the outline map and propagates their tables separately.
        </li>
        <li>
          <strong>Don't lose CFF2 on round-trip.</strong> Reading CFF2 tables through BinData returned nil, so the CBDT propagation path silently dropped CFF2 from every face. The build now reads table bytes raw (<code>table_data</code>) and splices them directly, preserving both outline and bitmap tables.
        </li>
      </ul>
      <p>
        Per-block WOFF2 subsetting for this website cannot yet carry CBDT (the fontisan subsetter drops tables it doesn't recognize), so the color-emoji blocks render in monochrome Noto Emoji on the site even though the TTC has them in full color. See <a href="/docs/coverage">/docs/coverage</a>.
      </p>

      <h2>Reproducibility</h2>
      <p>
        The whole pipeline is reproducible from the committed manifest:
      </p>
      <pre><code>git clone https://github.com/essenfont/essenfont
cd essenfont
bundle install
bundle exec ucode fetch fonts                 # auto-download most donors

# FSung must be downloaded manually from F.G. Wang's Google Drive
# (see sources/README.md) and placed in references/input-fonts/

bundle exec ruby scripts/build.rb --format=ttc           # canonical TTC
bundle exec ruby scripts/build.rb --format=ttf-per-plane # five standalone TTFs

bundle exec ruby scripts/verify.rb Essenfont-Regular.ttc # round-trip validation</code></pre>
      <p>
        Donor binaries are <strong>never committed to git</strong>. Each donor's sha256 is recorded in <code>sources/manifest.yml</code> and verified before use, so reproducing the build at a later date produces byte-identical output (modulo compilation timestamps, which the build stamps explicitly to keep <code>head.modified</code> outside Chrome's OTS rejection window — see <a href="/docs/coverage">/docs/coverage</a>).
      </p>

      <p class="next">
        Next: <a href="/docs/sources">where the glyphs come from</a> — donor strategy, the Tier 1/2/3 sourcing model, and why Full-Sung is the CJK donor.
      </p>
    </section>
  </article>
  </ReadingLayout>
</BaseLayout>

<style>
.pipeline-page { max-width: 760px; margin: 0 auto; padding: 4rem 1.5rem 6rem; }
.page-head { margin-bottom: 3rem; }



h1 {
  font-family: var(--spec-font-display);
  font-size: clamp(1.75rem, 4.5vw, 2.5rem);
  line-height: 1.15;
  margin: 0 0 1rem;
  color: var(--ef-text);
}
.lede {
  font-size: 1.1rem;
  line-height: 1.6;
  color: var(--ef-text);
  opacity: 0.85;
}
.prose h2 {
  font-family: var(--spec-font-display);
  font-size: 1.6rem;
  margin: 2.5rem 0 1rem;
}
.prose p, .prose li {
  margin-bottom: 1.25rem;
  font-size: 1.0625rem;
  line-height: 1.75;
  color: var(--ef-text);
}
.prose a {
  color: var(--ef-rose, #bf4e6a);
  text-decoration: underline;
  text-underline-offset: 3px;
}
.prose code {
  font-family: var(--spec-font-mono);
  background: rgba(0,0,0,0.05);
  padding: 0.1em 0.4em;
  border-radius: 3px;
  font-size: 0.9em;
}
.prose pre {
  background: rgba(0,0,0,0.05);
  padding: 1rem 1.25rem;
  border-radius: 4px;
  overflow-x: auto;
  font-family: var(--spec-font-mono);
  font-size: 0.82rem;
  line-height: 1.75;
}
.prose pre code { background: none; padding: 0; }
.flow { white-space: pre; font-size: 0.72rem; line-height: 1.6; }

ol.stages {
  list-style: none;
  padding: 0;
  margin: 1.5rem 0;
}
ol.stages > li {
  position: relative;
  padding: 1.25rem 0 1.25rem 3.5rem;
  border-bottom: 1px solid rgba(128,128,128,0.18);
}
ol.stages > li:last-child { border-bottom: none; }
ol.stages h3 {
  font-family: var(--spec-font-display);
  font-size: 1.15rem;
  margin: 0 0 0.5rem;
  font-weight: 600;
}
.step {
  display: inline-block;
  position: absolute;
  left: 0;
  top: 1.4rem;
  width: 2.5rem;
  text-align: center;
  font-family: var(--spec-font-mono);
  font-size: 0.8rem;
  color: var(--ef-rose, #bf4e6a);
}
.what, .why { margin: 0.35rem 0; font-size: 0.95rem; line-height: 1.6; }
.what strong, .why strong { color: var(--ef-rose, #bf4e6a); font-weight: 600; }

.plane-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.9rem;
  margin: 1rem 0 1.5rem;
}
.plane-table th, .plane-table td {
  text-align: left;
  padding: 0.55rem 0.75rem;
  border-bottom: 1px solid rgba(128,128,128,0.2);
  vertical-align: top;
}
.plane-table thead th {
  font-family: var(--spec-font-mono);
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--ef-text);
  opacity: 0.7;
}
.plane-table td code { font-size: 0.85em; }

.next {
  margin-top: 3rem !important;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(128,128,128,0.2);
  font-size: 0.95rem !important;
}
</style>
