---
import BaseLayout from '../../layouts/BaseLayout.astro';

const cards = [
  { num: 'I',   slug: 'usage',        title: 'How to use',    desc: 'Which format to grab, when to use each, and what to watch out for. Decision matrix and six use-case plates.', primary: true },
  { num: 'II',  slug: 'install',      title: 'Install',       desc: 'CLI commands for Fontist, npm, and direct download. The exact syntax per platform.' },
  { num: 'III', slug: 'css',          title: 'CSS',           desc: '@font-face, unicode-range, fallback chains, self-hosting, CORS, font-display.' },
  { num: 'IV',  slug: 'api',          title: 'API',           desc: 'The essenfont npm package. TypeScript types for every export.' },
];

const engineering = [
  { num: 'V',   slug: 'pipeline',       title: 'Build pipeline',     desc: 'How 160k glyphs from 38 donors become one OTC — the assembly line, plane partitioning, and why no glyph is ever hand-drawn.' },
  { num: 'VI',  slug: 'sources',         title: 'Where the glyphs come from', desc: 'The donor strategy: OFL-compatible donors, the Tier 1/2/3 sourcing model, code-chart SVG extraction, and why Full-Sung is the CJK donor.' },
  { num: 'VII', slug: 'formats',         title: 'Output formats & distribution', desc: 'Why OTC not TTF, why OTC over TTC, why both WOFF and WOFF2. Plus the release pipeline.' },
  { num: 'VIII',slug: 'specification',   title: 'Font specification', desc: 'The internal structure of Essenfont-Regular.otc — faces, UPM strategy, per-face vertical metrics, and donor attribution.' },
  { num: 'IX',  slug: 'coverage',        title: 'Coverage, gaps & roadmap', desc: 'What works today, what is blocked on upstream fontisan fixes, what Chrome\'s OpenType Sanitizer enforces, and what is next.' },
];
---
<BaseLayout
  title="Docs — Essenfont"
  description="Which Essenfont format to use, when to use each, and how to wire it in — plus install, CSS, API, and architecture reference docs."
  canonical="/docs"
>
  <section class="container docs-page">
    <header class="docs-head">
      <h1>How to use Essenfont</h1>
      <p class="lede">
        Start with <a href="/docs/usage">How to use</a> — it walks you through which format fits your situation (OS install, web embed, app bundle, PDF, fleet, npm package), then links to the syntax reference below.
      </p>
    </header>

    <nav class="docs-grid">
      {cards.map(c => (
        <a href={`/docs/${c.slug}`} class={'docs-card' + (c.primary ? ' docs-card--primary' : '')}>
          <span class="docs-num">{c.num}</span>
          <h2 class="docs-title">{c.title}</h2>
          <p class="docs-desc">{c.desc}</p>
          <span class="docs-cta mono">{c.primary ? 'start here →' : 'read →'}</span>
        </a>
      ))}
    </nav>

    <h2 class="docs-section-head">How it's built</h2>
    <nav class="docs-grid">
      {engineering.map(c => (
        <a href={`/docs/${c.slug}`} class="docs-card">
          <span class="docs-num">{c.num}</span>
          <h2 class="docs-title">{c.title}</h2>
          <p class="docs-desc">{c.desc}</p>
          <span class="docs-cta mono">read →</span>
        </a>
      ))}
    </nav>
  </section>
</BaseLayout>

<style>
  .docs-page { max-width: 960px; padding: 3rem 1.5rem 6rem; }
  .docs-head { margin-bottom: 3rem; }
  
  h1 {
    font-family: var(--spec-font-display, Spectral, serif);
    font-size: clamp(2rem, 5vw, 3rem); margin: 0;
  }
  .lede { margin-top: 1rem; font-size: 1.125rem; max-width: 56ch; line-height: 1.6; opacity: 0.85; }
  .lede a { color: var(--ef-accent); text-decoration: underline; text-underline-offset: 3px; }
  .docs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .docs-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.75rem 1.5rem 1.5rem;
    border: 1px solid rgba(26, 24, 21, 0.16);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s;
    background: transparent;
  }
  .docs-card:hover {
    border-color: var(--ef-accent);
    transform: translateY(-2px);
  }
  .docs-card--primary {
    background: rgba(191, 78, 106, 0.06);
    border: 1px solid rgba(191, 78, 106, 0.4);
    border-left: 3px solid var(--ef-accent);
  }
  .docs-card--primary .docs-cta { color: var(--ef-accent); font-weight: 600; }
  .docs-num {
    font-family: var(--spec-font-mono, monospace);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--ef-accent);
  }
  .docs-title {
    font-family: var(--spec-font-display, Spectral, serif);
    font-size: 1.5rem;
    margin: 0;
  }
  .docs-desc {
    flex: 1;
    font-size: 0.9375rem;
    line-height: 1.55;
    opacity: 0.85;
  }
  .docs-cta {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--ef-accent);
    text-transform: uppercase;
    margin-top: 0.5rem;
    font-family: var(--spec-font-mono, monospace);
  }
.docs-section-head {
  font-family: var(--spec-font-display);
  font-size: 1.5rem;
  font-weight: 600;
  margin: 3rem 0 1rem;
  padding-top: 2rem;
  border-top: 1px solid var(--ef-rule);
}
</style>
