---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TTCAnatomy from '../../components/diagrams/TTCAnatomy.astro';
import DonorAttribution from '../../components/diagrams/DonorAttribution.astro';
import BuildPipeline from '../../components/diagrams/BuildPipeline.astro';
import UPMNormalization from '../../components/diagrams/UPMNormalization.astro';
import { loadStats } from '../../lib/stats';
import { formatBytes, formatNumber } from '../../lib/ssr';
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const PUBLIC = path.resolve(__dirname, '..', '..', '..', '..', 'public');
const stats = loadStats();

// Load face table for the data-driven table section
interface FaceData {
  index: number;
  plane: string;
  glyphCount: number;
  cmapEntries: number;
  upm: number;
  head: { xMin: number; yMin: number; xMax: number; yMax: number };
  hhea: { ascent: number; descent: number; lineGap: number };
  os2: { sTypoAscender: number; sTypoDescender: number; usWinAscent: number; usWinDescent: number };
}

let faces: FaceData[] = [];
try {
  const data = JSON.parse(fs.readFileSync(path.join(PUBLIC, 'face-table.json'), 'utf-8'));
  faces = data.faces || [];
} catch {
  // not yet generated
}
---
<BaseLayout
  title="Font Specification — Engineering — Essenfont"
  description="The internal structure of Essenfont-Regular.ttc — faces, UPM strategy, vertical metrics, and donor attribution. Data-driven from the actual TTC."
  canonical="/docs/specification"
>
  <article class="spec-page">
    <header class="page-head">
      <p class="eyebrow"><a href="/docs">Engineering</a> · Specification</p>
      <h1>Font specification</h1>
      <p class="lede">
        The internal structure of <code>Essenfont-Regular.ttc</code> — how the TTC
        is partitioned into faces, why every face is at <code>unitsPerEm = 1000</code>,
        how vertical metrics are computed, and where every glyph comes from.
        All data on this page is read from the actual TTC file — no hardcoded values.
      </p>
    </header>

    {/* ── 1. TTC anatomy ── */}
    <section class="section">
      <h2><span class="num">1</span> TTC anatomy</h2>
      <p>
        A TTC (TrueType Collection) is a container file holding multiple
        independent OpenType faces. Essenfont ships one face per Unicode
        plane that carries assigned characters: BMP, SMP, SIP, TIP, SSP.
        Each face has its own <code>head</code>, <code>hhea</code>,
        <code>OS/2</code>, <code>glyf</code>, and <code>cmap</code> tables —
        they share table data where bytes are identical (deduplicated by SHA256).
      </p>
      <div class="diagram-wrap">
        <TTCAnatomy />
      </div>
    </section>

    {/* ── 2. Face table ── */}
    <section class="section">
      <h2><span class="num">2</span> Face table</h2>
      <p>
        Auto-generated from <code>Essenfont-Regular.ttc</code> at build time.
        Glyph counts, UPM, and metrics reflect the actual file — not
        hand-maintained.
      </p>
      {faces.length > 0 ? (
        <table class="face-table">
          <thead>
            <tr>
              <th>Face</th>
              <th>Plane</th>
              <th>Glyphs</th>
              <th>cmap</th>
              <th>UPM</th>
              <th>head bbox</th>
              <th>hhea asc/desc</th>
              <th>OS/2 sTypo</th>
            </tr>
          </thead>
          <tbody>
            {faces.map(face => (
              <tr>
                <td class="mono">{face.index}</td>
                <td class="mono"><strong>{face.plane}</strong></td>
                <td class="mono">{face.glyphCount.toLocaleString()}</td>
                <td class="mono">{face.cmapEntries.toLocaleString()}</td>
                <td class="mono">{face.upm}</td>
                <td class="mono small">
                  {face.head.xMin},{face.head.yMin} →
                  {face.head.xMax},{face.head.yMax}
                </td>
                <td class="mono">{face.hhea.ascent} / {face.hhea.descent}</td>
                <td class="mono">{face.os2.sTypoAscender} / {face.os2.sTypoDescender}</td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <p class="empty">Face table not generated yet. Run <code>node scripts/gen-face-table.mjs</code>.</p>
      )}
    </section>

    {/* ── 3. UPM strategy ── */}
    <section class="section">
      <h2><span class="num">3</span> UPM strategy</h2>
      <p>
        Every face uses <code>unitsPerEm = 1000</code> (PostScript convention).
        {formatNumber(stats.donorCount)} donor fonts ship at varying native
        UPMs. The build normalizes each donor to 1000-upm via per-donor
        uniform scaling — every glyph from one donor gets the same scale
        factor, preserving the donor's internal design proportions.
      </p>
      <div class="diagram-wrap">
        <UPMNormalization />
      </div>
      <p class="caption">
        Donors at native 1000-upm (the majority) need zero scaling.
        FSung at 1024-upm scales ×0.9766. Egyptian/TaiYo/Emoji donors at
        2048-upm scale ×0.4883. Lentariso at 2400-upm scales ×0.4167.
      </p>
    </section>

    {/* ── 4. Vertical metrics ── */}
    <section class="section">
      <h2><span class="num">4</span> Vertical metrics</h2>
      <p>
        After stitching, <code>Essenfont::Otc::MetricsPass</code> walks each
        face's glyphs and recomputes <code>head.bbox</code>,
        <code>hhea.ascent/descent</code>, and <code>OS/2</code> fields from
        the actual glyph extents. Latin-heavy faces (BMP, SSP) keep tight
        metrics (~800/-200). Faces with tall scripts (SMP, SIP, TIP) grow
        to accommodate their tallest glyphs.
      </p>
      <p>
        This is the Noto Sans model: each face's metrics match its script's
        extents, so renderers don't clip glyphs at the wrong boundary.
      </p>
    </section>

    {/* ── 5. Donor attribution ── */}
    <section class="section">
      <h2><span class="num">5</span> Donor attribution</h2>
      <p>
        Which donor font contributes how many glyphs to each face. The
        bubble chart below shows the top 20 donors. Circle radius is
        proportional to √(codepoint count). Colors indicate donor family.
      </p>
      <div class="diagram-wrap">
        <DonorAttribution />
      </div>
      <p class="caption">
        FSung (warm rose) dominates SIP and TIP with ~61k and ~13k CJK
        ideographs. Noto Sans (blue) fills BMP's world scripts.
        UniHieroglyphica (gold) covers SMP's Egyptian Hieroglyphs blocks.
      </p>
    </section>

    {/* ── 6. Partitioning ── */}
    <section class="section">
      <h2><span class="num">6</span> Partitioning strategy</h2>
      <p>
        Codepoints are partitioned by Unicode plane. This is:
      </p>
      <ul>
        <li><strong>MECE</strong> — every codepoint lives in exactly one plane</li>
        <li><strong>Stable</strong> — plane assignment never changes across Unicode versions</li>
        <li><strong>O(1) lookup</strong> — <code>cp &gt;&gt; 16</code> gives the plane directly</li>
        <li><strong>Under the cap</strong> — each plane fits in one face's 65,535-glyph limit</li>
      </ul>
      <p>
        If a future Unicode version balloons a plane past the glyph cap,
        the partitioner sub-splits by block. No block is ever torn across
        two faces.
      </p>
    </section>

    {/* ── 7. Build pipeline ── */}
    <section class="section">
      <h2><span class="num">7</span> Build pipeline</h2>
      <p>
        Seven stages from manifest to verified TTC. Stages 2 (UFO
        normalization) and 6 (MetricsPass) are new in v0.2.9.
      </p>
      <div class="diagram-wrap">
        <BuildPipeline />
      </div>
      <p class="caption">
        Every donor is converted to UFO and normalized before stitching.
        After stitch, MetricsPass recomputes each face's metrics from
        actual glyph extents.
      </p>
    </section>

    {/* ── 8. See also ── */}
    <section class="see-also">
      <p>
        For the code architecture (module guide, data flow, design decisions),
        see <a href="https://github.com/essenfont/essenfont/blob/main/docs/architecture.md" target="_blank" rel="noopener">
        <code>docs/architecture.md</code></a> in the build repo.
        For output formats and download options, see
        <a href="/docs/formats">/docs/formats</a>.
        For the build pipeline in detail, see
        <a href="/docs/pipeline">/docs/pipeline</a>.
      </p>
    </section>
  </article>
</BaseLayout>

<style>
.spec-page {
  max-width: 920px;
  margin: 0 auto;
  padding: 4rem 1.5rem 6rem;
}
.page-head { margin-bottom: 3rem; }
.eyebrow {
  font-family: var(--spec-font-mono, monospace);
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ef-accent, #2a5c8a);
  margin: 0 0 0.5rem;
}
.eyebrow a { color: inherit; text-decoration: none; }
h1 {
  font-family: var(--spec-font-display, serif);
  font-weight: 600;
  font-size: clamp(2rem, 5vw, 2.75rem);
  letter-spacing: -0.02em;
  margin: 0 0 1rem;
}
.lede {
  font-size: 1.05rem;
  line-height: 1.6;
  color: var(--ef-text-2, #555);
  max-width: 700px;
}
.lede code, p code, li code {
  font-family: var(--spec-font-mono, monospace);
  font-size: 0.88em;
  background: rgba(0,0,0,0.05);
  padding: 0.1em 0.35em;
  border-radius: 3px;
}

.section { margin-top: 3rem; }
.section h2 {
  font-family: var(--spec-font-display, serif);
  font-weight: 600;
  font-size: 1.5rem;
  letter-spacing: -0.015em;
  margin: 0 0 1rem;
  display: flex;
  align-items: baseline;
  gap: 0.6rem;
}
.section h2 .num {
  font-family: var(--spec-font-mono, monospace);
  font-size: 0.7rem;
  font-weight: 700;
  color: var(--ef-accent, #2a5c8a);
  background: var(--ef-accent-muted, rgba(42,92,138,0.08));
  padding: 0.2rem 0.5rem;
  border-radius: 4px;
}
.section p {
  font-size: 0.95rem;
  line-height: 1.65;
  color: var(--ef-text, #1a1a1a);
  margin: 0 0 1rem;
  max-width: 700px;
}
.section p a {
  color: var(--ef-accent, #2a5c8a);
  text-decoration: underline;
  text-underline-offset: 3px;
}
.section ul {
  font-size: 0.95rem;
  line-height: 1.65;
  max-width: 700px;
  padding-left: 1.5rem;
}
.section li { margin-bottom: 0.4rem; }

.diagram-wrap {
  margin: 1.5rem 0;
  padding: 1rem;
  background: var(--ef-surface, #f5f3ef);
  border: 1px solid var(--ef-rule, rgba(0,0,0,0.08));
  border-radius: 8px;
  overflow-x: auto;
}
.caption {
  font-family: var(--spec-font-mono, monospace);
  font-size: 0.78rem;
  color: var(--ef-text-3, #888);
  line-height: 1.5;
}

.face-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.82rem;
  margin: 1rem 0;
}
.face-table th, .face-table td {
  padding: 0.5rem 0.6rem;
  text-align: left;
  border-bottom: 1px solid var(--ef-rule, rgba(0,0,0,0.08));
}
.face-table th {
  font-family: var(--spec-font-mono, monospace);
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--ef-text-3, #888);
  background: var(--ef-surface, #f5f3ef);
}
.mono {
  font-family: var(--spec-font-mono, monospace);
  font-size: 0.82rem;
}
.mono.small {
  font-size: 0.72rem;
  color: var(--ef-text-2, #555);
}

.empty {
  font-style: italic;
  color: var(--ef-text-3, #888);
}

.see-also {
  margin-top: 3rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--ef-rule, rgba(0,0,0,0.08));
}
.see-also p {
  font-family: var(--spec-font-display, serif);
  font-style: italic;
  font-size: 0.9rem;
  color: var(--ef-text-2, #555);
  max-width: 700px;
}
.see-also a {
  color: var(--ef-accent, #2a5c8a);
  text-decoration: underline;
}
</style>
