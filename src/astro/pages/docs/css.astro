---
import BaseLayout from '../../layouts/BaseLayout.astro';

const CDN_SNIPPET = `<link rel="stylesheet" href="https://essenfont.github.io/fonts.css">

<style>
  body {
    font-family: "Essenfont", "Noto Sans", sans-serif;
  }
</style>`;

const RANGE_SNIPPET = `@font-face {
  font-family: "Essenfont";
  src: url("/fonts/cjk-unified-ideographs.woff2") format("woff2");
  unicode-range: U+4E00-9FFF;
  font-display: swap;
}`;

const SELF_HOST_SNIPPET = `/* one @font-face per subset you want to serve */
@font-face {
  font-family: "Essenfont";
  src: url("/fonts/basic-latin.woff2") format("woff2");
  unicode-range: U+0000-007F;
  font-display: swap;
}
/* the browser only fetches subsets it actually needs */`;
---
<BaseLayout
  title="CSS — Docs — Essenfont"
  description="Embed Essenfont in a stylesheet via CDN, per-block unicode-range, or self-host."
  canonical="/docs/css"
>
  <section class="container docs-page">
    <header class="docs-head">
      <h1>CSS integration</h1>
    </header>

    <p>
      Essenfont ships as 200+ per-block WOFF2 subsets, each declared
      with its own <code>@font-face</code> and <code>unicode-range</code>.
      The browser only fetches subsets for codepoints the page actually
      uses — you can embed the full catalog for free and pay only for
      what renders.
    </p>

    <h2 id="cdn">Option A · CDN</h2>
    <p>
      The simplest path. One <code>&lt;link&gt;</code> pulls the catalog
      stylesheet from this site's <code>/fonts.css</code>. The browser
      downloads WOFF2 subsets lazily.
    </p>
    <pre class="code-block"><code>{CDN_SNIPPET}</code></pre>

    <h2 id="self-host">Option B · Self-host</h2>
    <p>
      Clone the <code>public/fonts/</code> directory from this repo into your own site. Each block lives in its own file; copy the matching <code>@font-face</code> block from <code>fonts.css</code>.
    </p>
    <pre class="code-block"><code>{SELF_HOST_SNIPPET}</code></pre>

    <h2 id="range">Per-block unicode-range</h2>
    <p>
      Use <code>unicode-range</code> to scope a single @font-face to a
      specific Unicode block. The browser will only consider that source
      for codepoints inside the range — and will only fetch the file if
      the page actually renders one of those codepoints.
    </p>
    <pre class="code-block"><code>{RANGE_SNIPPET}</code></pre>

    <h2 id="fallbacks">Fallback chain</h2>
    <p>
      Always pair <code>"Essenfont"</code> with a fallback. If a visitor hasn't installed the font locally and your page hasn't embedded the matching subset, the browser falls back to <code>"Noto Sans"</code> (or whatever you list next).
    </p>
    <pre class="code-block"><code>font-family: "Essenfont", "Noto Sans", system-ui, sans-serif;</code></pre>

    <h2 id="font-display">font-display: swap</h2>
    <p>
      Always set <code>font-display: swap</code>. Without it, the browser
      blocks text rendering until the font loads, which on slow networks
      can be seconds. With swap, the fallback renders immediately and
      the page swaps to Essenfont when the subset arrives.
    </p>

    <p class="next">
      Next: <a href="/docs/api">API reference →</a>
    </p>
  </section>
</BaseLayout>

<style>
  .docs-page { max-width: 760px; padding: 3rem 1.5rem 6rem; }
  .docs-head { margin-bottom: 2.5rem; }
  
  h1 {
    font-family: var(--spec-font-display);
    font-size: clamp(2rem, 5vw, 3rem); margin: 0;
  }
  p { line-height: 1.65; margin: 1rem 0; }
  h2 {
    font-family: var(--spec-font-display);
    font-size: 1.5rem;
    margin: 2.5rem 0 0.75rem;
    border-bottom: 1px solid var(--ef-rule, rgba(26, 24, 21, 0.08));
    padding-bottom: 0.5rem;
  }
  code {
    font-family: var(--spec-font-mono, monospace);
    font-size: 0.875em;
    background: var(--ef-surface, #f2efe9);
    padding: 0.1em 0.4em;
    border-radius: 2px;
  }
  .code-block {
    background: var(--ef-surface, #f2efe9);
    border: 1px solid var(--ef-rule, rgba(26, 24, 21, 0.08));
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1rem 0;
  }
  .code-block code {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--ef-text, #1a1815);
    white-space: pre;
  }
  .next {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--ef-rule, rgba(26, 24, 21, 0.08));
  }
</style>
