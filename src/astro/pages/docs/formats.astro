---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadStats } from '../../lib/stats';
import { formatBytes, formatNumber } from '../../lib/ssr';
import ReadingLayout from '../../components/ReadingLayout.vue';

const stats = loadStats();

const formats = [
  {
    file: 'Essenfont-Regular.otc',
    desc: 'OpenType Collection, CFF2 outlines (cubic Bézier charstrings). Five plane faces sharing one container. Canonical artifact since v0.3.0 — carries CBDT/CBLC color bitmaps and is variable-font-ready.',
    size: formatBytes(stats.fontBinaries.otcSizeBytes),
    use: 'Canonical install',
    tag: 'OTC',
  },
  {
    file: 'Essenfont-Regular.ttc',
    desc: 'TrueType Collection, glyf outlines (quadratic Bézier). Same five faces, streamlined to pure glyf. Fallback for PDF generators and embedded engines that predate CFF2 parsing.',
    size: formatBytes(stats.fontBinaries.ttcSizeBytes),
    use: 'Legacy + PDF',
    tag: 'TTC',
  },
  {
    file: 'Essenfont-Regular.otf',
    desc: 'Single-face OpenType, CFF outlines. BMP-only — one sfnt face is capped at 65,535 glyphs, so only the BMP fits. Legacy convenience format for tools that want one OTF file rather than a collection.',
    size: formatBytes(stats.fontBinaries.otfSizeBytes),
    use: 'Legacy single-face',
    tag: 'OTF',
  },
  {
    file: 'Essenfont-{BMP,SMP,SIP,TIP,SSP}.ttf',
    desc: 'Five standalone TrueType fonts, one per plane, glyf outlines. Each file stays under the 65,535-glyph cap. For clients that enumerate fonts by direct file reads and cannot open a collection container.',
    size: 'Per plane',
    use: 'Legacy + PDF',
    tag: 'TTF',
  },
  {
    file: 'Essenfont-{BMP,SMP,SIP,TIP,SSP}.woff',
    desc: 'Per-plane WOFF 1.0, zlib-compressed per table. Wider legacy support (IE 9+, old embedded WebViews). Larger than WOFF2 but the only option for environments that predate Brotli.',
    size: '~30% smaller than TTF',
    use: 'Legacy web embed',
    tag: 'WOFF',
  },
  {
    file: 'Essenfont-{BMP,SMP,SIP,TIP,SSP}.woff2',
    desc: 'Per-plane WOFF 2.0, Brotli-compressed per table. ~50% smaller than WOFF for the same outlines. The default @font-face embed — every modern browser ships support (Chrome 36+, Firefox 39+, Safari 12+).',
    size: '~50% smaller than TTF',
    use: 'Whole-plane web embed',
    tag: 'WOFF2',
  },
  {
    file: 'Per-block WOFF2 subsets (this site)',
    desc: `${stats.websiteSubsets.woff2Count} small WOFF2s — one per Unicode block — subset from the canonical collection. Wired to unicode-range in public/fonts.css so a visitor reading one block downloads only that block.`,
    size: formatBytes(stats.websiteSubsets.woff2TotalBytes) + ' total',
    use: 'Per-page web embed',
    tag: 'WOFF2',
  },
];

// Code blocks live as string constants so curly braces in shell/ASCII art
// are not parsed as JSX expressions.
const releaseFlow = `┌──────────────────────────────────────────────────────┐
│ essenfont/essenfont  (build repo)                    │
│                                                      │
│  maintainer pushes tag v0.3.6                        │
│              │                                       │
│              ▼                                       │
│  release.yml (tag trigger)                           │
│    • set up Ruby 3.2 + bundler-cache                 │
│    • ucode fetch fonts (most Noto donors)            │
│    • download FSung files (Google Drive, see sources) │
│    • bundle exec ruby scripts/build.rb --format=otc-cff2  │
│    • bundle exec ruby scripts/build.rb --format=otc       │
│    • bundle exec ruby scripts/build.rb --format=ttf-per-plane │
│    • fontisan convert Essenfont-{PLANE}.ttf --to woff,woff2 │
│    • bundle exec ruby scripts/emit_coverage_manifest.rb     │
│    • upload all artifacts to GH Release v0.3.6        │
│    • npm publish essenfont@0.3.6 → npm registry       │
│    • repository_dispatch → essenfont.github.io        │
└──────────────────────┬───────────────────────────────┘
                       │
                       ▼
┌──────────────────────────────────────────────────────┐
│ essenfont/essenfont.github.io  (this site)           │
│                                                      │
│  site.yml (repository_dispatch + 6h schedule)        │
│    • download latest Essenfont-Regular.otc           │
│    • bundle exec ruby scripts/subset-fonts.rb        │
│      → public/fonts/*.woff2 (per-block subsets)      │
│    • npm ci + npm run build (Astro SSG, 160k routes) │
│    • deploy to GitHub Pages                          │
└──────────────────────────────────────────────────────┘`;

const reproCommands = `# Build the font (canonical OTC + TTC fallback + per-plane TTFs)
git clone https://github.com/essenfont/essenfont
cd essenfont && bundle install
bundle exec ucode fetch fonts
bundle exec ruby scripts/build.rb --format=otc-cff2   # Essenfont-Regular.otc
bundle exec ruby scripts/build.rb --format=otc        # Essenfont-Regular.ttc
bundle exec ruby scripts/build.rb --format=ttf-per-plane

# Encode per-plane WOFF + WOFF2 for the web
for plane in BMP SMP SIP TIP SSP; do
  fontisan convert Essenfont-\${plane}.ttf --to woff,woff2
done

# Subset for the web (this site)
git clone https://github.com/essenfont/essenfont.github.io
cd essenfont.github.io && bundle install && npm ci
ESSENFONT_OTC=../essenfont/Essenfont-Regular.otc bundle exec ruby scripts/subset-fonts.rb
npm run build`;
---

<BaseLayout
  title="Output formats & distribution — Engineering — Essenfont"
  description="Six output shapes from one UFO-normalized source: OTC (CFF2), TTC (glyf), OTF, TTF, WOFF, WOFF2 — plus the TTC-compatibility story and the release pipeline."
  canonical="/docs/formats"
>
  <ReadingLayout client:visible>
    <article class="formats-page">
    <header class="page-head">
      <h1>Output formats & distribution</h1>
      <p class="lede">
        One UFO-normalized source, six output shapes — each tuned for a different audience: canonical install, legacy + PDF, single-face convenience, and two tiers of web embed. If you landed here looking for install commands or CSS embedding patterns, see the <a href="/docs/usage">How to use</a> guide.
      </p>
    </header>

    <section class="prose" data-reading-article>
      <h2>Why a collection, not one font</h2>
      <p>
        A single OpenType face can address at most 65,535 glyphs (16-bit glyph IDs). Unicode 17 has {formatNumber(stats.unicode.assignedCodepointCount)} assigned codepoints — roughly 2.5× the cap. No single TTF or OTF can cover every codepoint, full stop. The solution is an <strong>OpenType Collection</strong>: one file holding multiple faces, each under the glyph-ID cap. Essenfont partitions codepoints by Unicode plane (BMP, SMP, SIP, TIP, SSP) so each face maps to exactly one plane.
      </p>

      <h2>The six output shapes</h2>
      <div class="format-grid">
        {formats.map(f => (
          <div class="format-card">
            <div class="format-head">
              <code class="format-file">{f.file}</code>
              <span class="format-tag">{f.tag}</span>
            </div>
            <p class="format-desc">{f.desc}</p>
            <div class="format-foot">
              <span class="format-size">{f.size}</span>
              <span class="format-use">{f.use}</span>
            </div>
          </div>
        ))}
      </div>

      <h2>OTC vs TTC — same container, different outlines</h2>
      <p>
        Both <code>.otc</code> and <code>.ttc</code> use the same collection container format (the <code>ttcf</code> header with a shared table directory). The extension signals which <em>outline</em> format lives inside each face:
      </p>
      <ul>
        <li>
          <strong>TTC</strong> faces carry <code>glyf</code> tables — quadratic Bézier curves, the TrueType outline format. Universally accepted by PDF generators, legacy font engines, and embedded systems.
        </li>
        <li>
          <strong>OTC</strong> faces carry <code>CFF2</code> tables — cubic Bézier charstrings with subroutinization, the modern PostScript outline format. Smaller outline data per glyph; required for variable fonts.
        </li>
      </ul>
      <p>
        CFF2 charstrings are roughly 35% smaller than equivalent glyf data for the same outline coverage. But Essenfont's OTC also carries color-bitmap tables (<code>CBDT</code>/<code>CBLC</code>) for emoji and certain scripts that the glyf-only TTC streamlines away — so the total OTC ({formatBytes(stats.fontBinaries.otcSizeBytes)}) is larger than the TTC ({formatBytes(stats.fontBinaries.ttcSizeBytes)}) despite smaller outlines. Both are published in every release; the OTC is canonical.
      </p>

      <h2>OTF vs TTF — single-face fonts</h2>
      <p>
        OTF and TTF are <strong>single-face</strong> fonts (one <code>sfnt</code> resource, not a collection). The difference mirrors the OTC/TTC split — it is purely the outline format:
      </p>
      <table class="compare-table">
        <thead>
          <tr><th></th><th>OTF</th><th>TTF</th></tr>
        </thead>
        <tbody>
          <tr>
            <td>Outline table</td>
            <td><code>CFF</code> / <code>CFF2</code> (cubic Bézier)</td>
            <td><code>glyf</code> (quadratic Bézier)</td>
          </tr>
          <tr>
            <td>Typical size</td>
            <td>Smaller (subroutinization shares curve data)</td>
            <td>Larger (each glyph stores its own nodes)</td>
          </tr>
          <tr>
            <td>Hinting</td>
            <td>CFF hints (coarser, declarative)</td>
            <td>TrueType instructions (bytecode, fine-grained grid-fitting)</td>
          </tr>
          <tr>
            <td>Layout tables</td>
            <td colspan="2">Identical — both use the same <code>GSUB</code>, <code>GPOS</code>, <code>cmap</code>, <code>name</code> machinery. The OpenType feature engine does not care which outline format is underneath.</td>
          </tr>
          <tr>
            <td>Legacy support</td>
            <td>Some older PDF readers reject CFF</td>
            <td>Universally accepted</td>
          </tr>
        </tbody>
      </table>
      <p>
        Because a single face is capped at 65,535 glyphs, Essenfont's standalone OTF is <strong>BMP-only</strong> ({formatBytes(stats.fontBinaries.otfSizeBytes)}). The per-plane TTFs split coverage across five files to reach every plane. Neither single-face format can match a collection's full coverage in one file — that is why the OTC/TTC exist.
      </p>

      <h2>TTC compatibility: why UFO normalization matters</h2>
      <p>
        A collection deduplicates shared tables across faces by SHA256 — identical <code>cmap</code> fragments, name records, or outline data are stored once. For this to work, every face must speak the <em>same</em> outline language. You cannot stitch a glyph extracted from a glyf donor and a glyph extracted from a CFF donor into one face's outline table — the curves are fundamentally different data structures.
      </p>
      <p>
        Essenfont's donors arrive in both flavors:
      </p>
      <ul>
        <li><strong>glyf / TrueType</strong> — Noto Sans, FSung (CJK), most <code>.ttf</code> donors</li>
        <li><strong>CFF / CFF2</strong> — Noto Serif Tangut, many <code>.otf</code> donors, CBDT color-bitmap donors</li>
      </ul>
      <p>
        This is the "incompatible source glyphs" problem. The build resolves it by routing <em>every</em> donor through a UFO normalization pass before stitching:
      </p>
      <ol>
        <li>
          <code>Fontisan::Ufo::Convert::FromBinData.convert(font)</code> reads the donor (regardless of its native outline format) and emits a UFO where every glyph contour is a cubic Bézier stored in GLIF format.
        </li>
        <li>
          <code>Essenfont::Ufo::Normalization.apply!(ufo, target_upm: 1000)</code> scales every coordinate to a uniform 1000-upm grid.
        </li>
      </ol>
      <p>
        After normalization, donors are no longer "glyf donors" or "CFF donors" — they are all UFO glyphs on the same grid. From this common source, fontisan's compiler emits whichever target the build requests:
      </p>
      <ul>
        <li><strong>CFF2 charstrings</strong> (cubic → cubic, direct) → packed into the OTC</li>
        <li><strong>glyf outlines</strong> (cubic → quadratic conversion) → packed into the TTC</li>
      </ul>
      <p>
        So yes — because the build compiles from UFO source, it <em>does</em> generate both compatible outputs from one set of donors. The UFO normalization pass <strong>is</strong> the compatibility layer. Without it, the mixed-outline donors could not share a collection; with it, the same normalized glyphs flow into both the CFF2 OTC and the glyf TTC.
      </p>

      <h2>WOFF vs WOFF2 — web containers</h2>
      <p>
        Browsers cannot <code>@font-face</code> a collection container directly — neither <code>.otc</code> nor <code>.ttc</code> is accepted. The build wraps each per-plane TTF in a web-friendly container:
      </p>
      <ul>
        <li>
          <strong>WOFF2</strong> — Brotli-compressed per table. ~50% smaller than WOFF. Supported by every modern browser (Chrome 36+, Firefox 39+, Safari 12+, Edge 14+). The default web embed.
        </li>
        <li>
          <strong>WOFF</strong> — zlib-compressed per table. Larger than WOFF2 but predates Brotli, so it reaches Internet Explorer 9–11 and legacy embedded WebViews that WOFF2 cannot. Published per-plane for enterprise and regulated environments that explicitly need it.
        </li>
      </ul>
      <p>
        WOFF2 alone covers &gt;99% of today's web traffic. WOFF is included as a no-surprises fallback for environments locked out of Brotli (regulated industries, old device farms, certain kiosk firmwares).
      </p>

      <h2>Release pipeline</h2>
      <p>
        Essenfont ships via tag-triggered GitHub Actions in two repos:
      </p>
      <pre class="release-flow"><code set:html={releaseFlow}></code></pre>
      <p>
        The site polls every 6 hours for new releases and redeploys automatically — so when a new Essenfont tag is cut, this website's per-block WOFF2s and coverage numbers update without any manual intervention.
      </p>

      <h2>Reproducibility</h2>
      <p>
        The full distribution chain — donor binaries → UFO normalization → collection → per-plane TTFs → WOFF/WOFF2 → per-block subsets — is reproducible from the committed manifests in two repos:
      </p>
      <pre><code set:html={reproCommands}></code></pre>
      <p>
        The build never writes binaries to git. Donors come from <code>ucode fetch fonts</code> (Noto and similar) or manual download (Full-Sung from F.G. Wang's Google Drive). The resulting collection and its subsets live in GitHub Releases and the npm package <code>essenfont</code>; this site serves per-block WOFF2 from GitHub Pages.
      </p>

      <p>
        For install + CSS + embedding patterns (the user-facing "how do I use it" questions), see the <a href="/docs/usage">/docs/usage</a> guide. For a per-component technical reference, see <a href="/docs/architecture">/docs/architecture</a>.
      </p>

      <p class="next">
        Next: <a href="/docs/coverage">coverage, gaps, and roadmap</a> — what works today, what's blocked on upstream fontisan fixes, and the lessons learned getting WOFF2 past Chrome's OpenType Sanitizer.
      </p>
    </section>
  </article>
  </ReadingLayout>
</BaseLayout>

<style>
.formats-page { max-width: 800px; margin: 0 auto; padding: 4rem 1.5rem 6rem; }
.page-head { margin-bottom: 3rem; }

h1 {
  font-family: var(--spec-font-display, Spectral, serif);
  font-size: clamp(1.75rem, 4.5vw, 2.5rem);
  line-height: 1.15;
  margin: 0 0 1rem;
  color: var(--ef-text, #1c1a18);
}
.lede {
  font-size: 1.1rem;
  line-height: 1.6;
  color: var(--ef-text, #1c1a18);
  opacity: 0.85;
}
.lede a {
  color: var(--ef-accent);
  text-decoration: underline;
  text-underline-offset: 3px;
}
.prose h2 {
  font-family: var(--spec-font-display, Spectral, serif);
  font-size: 1.6rem;
  margin: 2.5rem 0 1rem;
}
.prose p, .prose li {
  font-size: 1rem;
  line-height: 1.7;
  color: var(--ef-text, #1c1a18);
}
.prose a {
  color: var(--ef-accent);
  text-decoration: underline;
  text-underline-offset: 3px;
}
.prose code {
  font-family: var(--spec-font-mono, 'IBM Plex Mono', monospace);
  background: rgba(0,0,0,0.05);
  padding: 0.1em 0.4em;
  border-radius: 3px;
  font-size: 0.9em;
}
.prose pre {
  background: rgba(0,0,0,0.05);
  padding: 1rem 1.25rem;
  border-radius: 4px;
  overflow-x: auto;
  font-family: var(--spec-font-mono, 'IBM Plex Mono', monospace);
  font-size: 0.82rem;
  line-height: 1.7;
}
.prose pre code { background: none; padding: 0; }
.release-flow { font-size: 0.68rem; line-height: 1.55; white-space: pre; }

.format-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.75rem;
  margin: 1.5rem 0;
}
.format-card {
  padding: 1rem 1.25rem;
  border: 1px solid rgba(128,128,128,0.25);
  border-radius: 4px;
  border-left: 3px solid var(--ef-accent);
}
.format-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 0.4rem;
}
.format-file {
  font-family: var(--spec-font-mono, 'IBM Plex Mono', monospace);
  font-size: 0.85rem;
  background: rgba(0,0,0,0.05);
  padding: 0.15em 0.5em;
  border-radius: 3px;
  word-break: break-all;
}
.format-tag {
  font-family: var(--spec-font-mono, 'IBM Plex Mono', monospace);
  font-size: 0.7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--ef-accent);
  background: rgba(191, 78, 106, 0.08);
  padding: 0.15em 0.5em;
  border-radius: 3px;
  white-space: nowrap;
}
.format-desc { font-size: 0.92rem; line-height: 1.55; margin: 0; }
.format-foot {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-top: 0.5rem;
}
.format-size {
  font-family: var(--spec-font-mono, 'IBM Plex Mono', monospace);
  font-size: 0.75rem;
  opacity: 0.6;
}
.format-use {
  font-family: var(--spec-font-mono, 'IBM Plex Mono', monospace);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--ef-text, #1c1a18);
  opacity: 0.55;
}

.compare-table {
  width: 100%;
  border-collapse: collapse;
  margin: 1rem 0;
  font-size: 0.9rem;
}
.compare-table th,
.compare-table td {
  text-align: left;
  padding: 0.5rem 0.75rem;
  border-bottom: 1px solid rgba(128,128,128,0.2);
  line-height: 1.5;
  vertical-align: top;
}
.compare-table thead th {
  font-family: var(--spec-font-mono, 'IBM Plex Mono', monospace);
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--ef-accent);
  border-bottom: 2px solid rgba(128,128,128,0.3);
}
.compare-table td:first-child {
  font-weight: 600;
  white-space: nowrap;
}
.compare-table td[colspan] {
  font-style: italic;
  opacity: 0.8;
}

.next {
  margin-top: 3rem !important;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(128,128,128,0.2);
  font-size: 0.95rem !important;
}
</style>
