---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadDonors } from '../../lib/donors';

const donors = loadDonors();
---
<BaseLayout title="Donors — Essenfont" description="The donor fonts that contribute glyphs to the Essenfont universal Unicode 17 typeface." canonical="/donors">
  <div class="donors-page">
    <header class="page-head">
      <p class="eyebrow">Donor Registry</p>
      <h1>{donors.length} donor fonts</h1>
      <p>Every glyph in Essenfont is vector-extracted from an OFL-licensed donor font.</p>
    </header>
    <div class="donor-grid">
      {donors.map(d => (
        <a href={`/donors/${d.slug}`} class="donor-card">
          <span class="donor-family">{d.family}</span>
          <span class="donor-meta">{d.license} · {d.covers_count} blocks · {d.role}</span>
          <span class="donor-author">{d.vendor}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
<style>
.donors-page { max-width: 900px; margin: 0 auto; padding: 3rem 1.5rem 6rem; }
.page-head { margin-bottom: 2rem; }
.eyebrow { font-family: var(--spec-font-mono); font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ef-rose, #bf4e6a); margin: 0 0 0.5rem; }
h1 { font-family: var(--spec-font-display); font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; }
.donor-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 0.75rem; }
.donor-card { display: flex; flex-direction: column; padding: 1rem; border: 1px solid rgba(128,128,128,0.2); border-radius: 4px; text-decoration: none; color: inherit; transition: border-color 0.1s; }
.donor-card:hover { border-color: var(--ef-rose, #bf4e6a); }
.donor-family { font-weight: 600; font-size: 0.95rem; }
.donor-meta { font-family: var(--spec-font-mono); font-size: 0.7rem; opacity: 0.6; margin-top: 0.25rem; }
.donor-author { font-size: 0.75rem; opacity: 0.5; margin-top: 0.25rem; }
</style>
