---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadDonors, donorLogo } from '../../lib/donors';
import { loadStats } from '../../lib/stats';
import { formatNumber } from '../../lib/ssr';

const donors = loadDonors();
const stats = loadStats();

const ROLE_META: Record<string, { label: string; blurb: string }> = {
  primary: { label: 'Primary', blurb: 'Cover the largest codepoint ranges — full CJK, Egyptian, Latin.' },
  secondary: { label: 'Secondary', blurb: "Fill in scripts the primary donors don't cover." },
  specialist: { label: 'Specialist', blurb: 'Single-script experts — historical, minority, and revived writing systems.' },
  contributor: { label: 'Contributor', blurb: 'Smaller contributions — format controls, symbols, punctuation.' },
};

const roleOrder = ['primary', 'secondary', 'specialist', 'contributor'];
const byRole = donors.reduce((acc, d) => {
  const role = d.role || 'contributor';
  (acc[role] ||= []).push(d);
  return acc;
}, {} as Record<string, typeof donors>);
const roles = roleOrder.filter(r => byRole[r]);
---

<BaseLayout title="Donors — Essenfont" description="The donor fonts that contribute glyphs to the Essenfont universal Unicode 17 typeface." canonical="/donors">
  <div class="donors">
    <header class="dn-hero">
      <span class="dn-eyebrow">{donors.length} donor fonts</span>
      <h1>Every glyph has<br/>a lineage.</h1>
      <p class="dn-lede">
        Essenfont doesn't draw a single outline. Every one of its
        <strong>{formatNumber(stats.coverage?.totals?.covered ?? 0)}</strong> glyphs is
        extracted from an existing OFL-licensed font — curated, normalized, and
        stitched into one universal typeface.
      </p>
    </header>

    <div class="dn-stats">
      <div class="dn-stat">
        <span class="dn-stat-num">{donors.length}</span>
        <span class="dn-stat-label">donor fonts</span>
      </div>
      <div class="dn-stat">
        <span class="dn-stat-num">{formatNumber(stats.coverage?.totals?.covered ?? 0)}</span>
        <span class="dn-stat-label">glyphs contributed</span>
      </div>
      <div class="dn-stat">
        <span class="dn-stat-num">{stats.unicode?.blockCount ?? 0}</span>
        <span class="dn-stat-label">Unicode blocks</span>
      </div>
      <div class="dn-stat">
        <span class="dn-stat-num">OFL</span>
        <span class="dn-stat-label">all open-licensed</span>
      </div>
    </div>

    {roles.map(role => (
      <section class="dn-role-section">
        <div class="dn-role-header">
          <h2>{ROLE_META[role]?.label ?? role}</h2>
          <p>{ROLE_META[role]?.blurb ?? ''}</p>
        </div>
        <div class="dn-donor-grid">
          {byRole[role].map(d => {
            const logo = donorLogo(d.family, d.vendor);
            const donorHref = `/donors/${d.slug}`;
            return (
              <a href={donorHref} class="dn-card">
                <div class="dn-card-head">
                  {logo ? (
                    logo.srcDark ? (
                      <Fragment>
                        <img src={logo.src} alt={logo.alt} class="dn-logo donor-logo--light" width="32" height="32" loading="lazy" />
                        <img src={logo.srcDark} alt={logo.alt} class="dn-logo donor-logo--dark" width="32" height="32" loading="lazy" />
                      </Fragment>
                    ) : (
                      <img src={logo.src} alt={logo.alt} class="dn-logo" width="32" height="32" loading="lazy" />
                    )
                  ) : (
                    <span class="dn-logo dn-logo--placeholder">{d.family.charAt(0)}</span>
                  )}
                  <span class="dn-license">{d.license}</span>
                </div>
                <h3 class="dn-family">{d.family}</h3>
                {d.vendor && <p class="dn-vendor">{d.vendor}</p>}
                <div class="dn-card-stats">
                  <span class="dn-stat-cp">{formatNumber(d.covers_count)} blocks</span>
                  {d.author && <span class="dn-author">{d.author}</span>}
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ))}

    <div class="dn-provenance-cta">
      <p>Want to trace exactly which codepoints come from which donor?</p>
      <a href="/provenance" class="btn btn-ghost">View provenance manifest →</a>
    </div>
  </div>
</BaseLayout>

<style>
  .donors { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

  .dn-hero { text-align: center; margin-bottom: 3rem; padding-top: 1rem; }
  .dn-eyebrow {
    font-family: var(--spec-font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--ef-accent);
    display: block;
    margin-bottom: 0.75rem;
  }
  .dn-hero h1 {
    font-family: var(--spec-font-display);
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 600;
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0 0 1.25rem;
  }
  .dn-lede {
    font-size: 1.1rem;
    line-height: 1.6;
    max-width: 560px;
    margin: 0 auto;
    color: var(--ef-text-2);
  }
  .dn-lede strong { color: var(--ef-text); font-weight: 600; }

  .dn-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
    margin-bottom: 4rem;
    padding: 1.5rem;
    background: var(--ef-surface);
    border: 1px solid var(--ef-rule);
    border-radius: var(--ef-radius);
  }
  .dn-stat { text-align: center; }
  .dn-stat-num {
    display: block;
    font-family: var(--spec-font-display);
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 600;
    color: var(--ef-accent);
    line-height: 1;
  }
  .dn-stat-label {
    display: block;
    margin-top: 0.3rem;
    font-family: var(--spec-font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ef-text-3);
  }

  .dn-role-section { margin-bottom: 3rem; }
  .dn-role-header { margin-bottom: 1rem; }
  .dn-role-header h2 {
    font-family: var(--spec-font-display);
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
    color: var(--ef-text);
  }
  .dn-role-header p {
    font-size: 0.85rem;
    color: var(--ef-text-2);
    margin: 0;
  }

  .dn-donor-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
  }

  .dn-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    border: 1px solid var(--ef-rule);
    border-radius: var(--ef-radius-sm);
    background: var(--ef-raised);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
  }
  .dn-card:hover {
    border-color: var(--ef-accent);
    transform: translateY(-3px);
    box-shadow: var(--ef-shadow-md);
  }

  .dn-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .dn-logo {
    width: 32px;
    height: 32px;
    object-fit: contain;
    flex-shrink: 0;
  }
  .dn-logo--placeholder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--ef-accent);
    color: white;
    font-family: var(--spec-font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    border-radius: 6px;
  }
  .dn-license {
    font-family: var(--spec-font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ef-text-3);
    padding: 0.15rem 0.4rem;
    border: 1px solid var(--ef-rule-strong);
    border-radius: 3px;
  }

  .dn-family {
    font-family: var(--spec-font-display);
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
    color: var(--ef-text);
    line-height: 1.2;
  }
  .dn-vendor {
    font-size: 0.78rem;
    color: var(--ef-text-2);
    margin: 0;
  }
  .dn-card-stats {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid var(--ef-rule);
  }
  .dn-stat-cp {
    font-family: var(--spec-font-mono);
    font-size: 0.7rem;
    color: var(--ef-accent);
    font-weight: 600;
  }
  .dn-author {
    font-size: 0.7rem;
    color: var(--ef-text-3);
    text-align: right;
  }

  .dn-provenance-cta {
    text-align: center;
    margin-top: 3rem;
    padding: 2rem;
    border: 1px solid var(--ef-rule);
    border-radius: var(--ef-radius);
    background: var(--ef-surface);
  }
  .dn-provenance-cta p {
    font-family: var(--spec-font-display);
    font-size: 1.1rem;
    color: var(--ef-text-2);
    margin: 0 0 1rem;
    font-style: italic;
  }

  @media (max-width: 640px) {
    .dn-stats { gap: 1.5rem; }
  }
</style>
