---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadDonors } from '../../lib/donors';
import { loadStats } from '../../lib/stats';
import { formatNumber } from '../../lib/ssr';

const donors = loadDonors();
const stats = loadStats();

// Group donors by role for the editorial layout
const byRole = donors.reduce((acc, d) => {
  const role = d.role || 'contributor';
  (acc[role] ||= []).push(d);
  return acc;
}, {} as Record<string, typeof donors>);

const roleOrder = ['primary', 'secondary', 'specialist', 'contributor']
  .filter(r => byRole[r])
  .concat(Object.keys(byRole).filter(r => !['primary', 'secondary', 'specialist', 'contributor'].includes(r)));
---

<BaseLayout
  title="Makers — Essenfont"
  description={`The ${donors.length} OFL-licensed donor fonts whose outlines Essenfont gathers into one universal typeface.`}
  canonical="/donors"
  active="makers"
>
  <section class="section makers-head">
    <div class="container">
      <div class="makers-head-grid">
        <div class="makers-meta rise-1">
          <p class="eyebrow">§ Makers</p>
          <p class="folio" style="margin-top: 1rem;">No. {donors.length} donors</p>
        </div>
        <div class="makers-pitch rise-2">
          <h1>Assembled,<br/><em class="text-ochre">not designed</em>.</h1>
          <p class="lede" style="margin-top: 2rem;">
            Essenfont draws no glyphs of its own. Every character is
            vector-extracted from the canonical OFL-licensed donor for its
            script — Noto for Latin, FSung for the rare CJK Extensions,
            NotoColorEmoji for color bitmaps, and {formatNumber(donors.length - 3)} others.
            Each donor is named, credited, and traceable.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section makers-roster">
    <div class="container">
      <div class="roster-head reveal">
        <p class="eyebrow">The roster</p>
        <h2 style="margin-top: 1rem;">All {donors.length} donors</h2>
      </div>

      {roleOrder.map(role => (
        <div class="role-block reveal">
          <h3 class="role-title">
            <span class="role-name">{role}</span>
            <span class="role-count mono">{byRole[role].length}</span>
          </h3>
          <ul class="donor-table">
            {byRole[role].map(d => (
              <li>
                <a href={`/donors/${d.slug}`} class="donor-row">
                  <span class="donor-family">{d.family}</span>
                  <span class="donor-vendor">{d.vendor}</span>
                  <span class="donor-coverage mono">{formatNumber(d.parsed_coverage_count || d.covers_count)} cp</span>
                  <span class="donor-license mono">{d.license}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="section makers-provenance">
    <div class="container">
      <div class="grid">
        <div class="reveal" style="grid-column: span 4;">
          <p class="eyebrow">Provenance</p>
        </div>
        <div class="reveal" style="grid-column: span 7 / -1;">
          <h3>Every glyph, traceable to its source.</h3>
          <p class="lede" style="margin-top: 1rem;">
            Essenfont ships with a per-codepoint provenance manifest: for
            each codepoint, the donor that supplied its outline, the donor's
            GID, and the donor's license. The build pipeline (fontisan's
            Stitcher + Collection::Builder) is itself open source.
          </p>
          <p style="margin-top: 1.5rem; max-width: 60ch;" class="text-ink-2">
            The donor registry, license terms, and per-codepoint attribution
            live alongside the source repo. If a donor updates, the build
            regenerates Essenfont with the new outlines — and the provenance
            manifest updates with it.
          </p>
          <div style="margin-top: 2.5rem; display: flex; gap: 1rem; flex-wrap: wrap;">
            <a href="/provenance" class="btn btn-ghost btn-arrow">Full provenance manifest</a>
            <a href="/engineering" class="btn btn-ghost btn-arrow">Read the engineering</a>
            <a href="/license" class="btn btn-ghost btn-arrow">License terms</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .makers-head { padding-block: clamp(3rem, 8vw, 5rem); }
  .makers-head-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: clamp(1rem, 3vw, 2.5rem);
  }
  .makers-meta { grid-column: 1 / span 2; }
  .makers-pitch { grid-column: 4 / span 9; padding-top: 1rem; }
  .makers-pitch h1 {
    font-family: var(--font-display);
    font-weight: 300;
    font-variation-settings: "opsz" 144, "SOFT" 40;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.035em;
  }
  .makers-pitch h1 em {
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
  }

  /* Roster */
  .roster-head { margin-bottom: 3rem; max-width: 60ch; }
  .role-block { margin-bottom: 3rem; }
  .role-title {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid var(--ef-rule-2);
    margin-bottom: 0;
  }
  .role-name {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ef-ochre);
  }
  .role-count {
    font-size: 0.6875rem;
    letter-spacing: 0.15em;
    color: var(--ef-ink-3);
  }
  .donor-table {
    list-style: none;
  }
  .donor-table li { border-bottom: 1px solid var(--ef-rule); }
  .donor-row {
    display: grid;
    grid-template-columns: 1.4fr 1.1fr 0.6fr 0.6fr;
    gap: 1rem;
    align-items: baseline;
    padding-block: 0.875rem;
    text-decoration: none;
    color: var(--ef-ink);
    border: none;
    transition: color 0.2s, padding-left 0.2s;
  }
  .donor-row:hover {
    color: var(--ef-ochre);
    padding-left: 0.5rem;
  }
  .donor-family {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.0625rem;
  }
  .donor-vendor {
    font-size: 0.875rem;
    color: var(--ef-ink-2);
  }
  .donor-coverage {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--ef-ink-3);
  }
  .donor-license {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    color: var(--ef-ink-3);
    text-transform: uppercase;
    text-align: right;
  }
  .donor-row:hover .donor-family { color: var(--ef-ochre); }

  /* Provenance */
  .makers-provenance { background: var(--ef-paper-2); }

  @media (max-width: 900px) {
    .makers-meta, .makers-pitch { grid-column: 1 / span 12; }
    .donor-row { grid-template-columns: 1fr 1fr; gap: 0.25rem 1rem; }
    .donor-license { text-align: left; }
  }
</style>
