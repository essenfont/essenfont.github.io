---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadDonors } from '../../lib/donors';

export async function getStaticPaths() {
  const donors = loadDonors();
  return donors.map(d => ({ params: { slug: d.slug }, props: { donor: d } }));
}
const { donor } = Astro.props;
---
<BaseLayout title={`${donor.family} — Donor — Essenfont`} description={`${donor.family}: ${donor.role} donor covering ${donor.covers_count} Unicode blocks.`} canonical={`/donors/${donor.slug}`}>
  <article class="donor-detail">
    <p class="eyebrow"><a href="/donors">← Donors</a></p>
    <h1>{donor.family}</h1>
    <dl class="props">
      <dt>License</dt><dd>{donor.license}</dd>
      <dt>Role</dt><dd>{donor.role}</dd>
      <dt>Source type</dt><dd>{donor.source_type}</dd>
      <dt>Blocks covered</dt><dd>{donor.covers_count}</dd>
      <dt>File count</dt><dd>{donor.file_count}</dd>
      <dt>First block</dt><dd>{donor.first_cover}</dd>
    </dl>
    <p class="author">{donor.author}</p>
  </article>
</BaseLayout>
<style>
.donor-detail { max-width: 640px; margin: 0 auto; padding: 3rem 1.5rem 6rem; }
.eyebrow { font-family: var(--mono-font, monospace); font-size: 0.75rem; opacity: 0.6; }
.eyebrow a { color: var(--ef-rose, #bf4e6a); text-decoration: none; }
h1 { font-family: var(--display-font, Spectral, serif); font-size: 2rem; margin: 0.5rem 0 1.5rem; }
.props { display: grid; grid-template-columns: max-content 1fr; gap: 0.5rem 1.5rem; margin: 0 0 1.5rem; }
dt { font-family: var(--mono-font, monospace); font-size: 0.75rem; text-transform: uppercase; opacity: 0.5; }
dd { margin: 0; }
.author { font-size: 0.875rem; opacity: 0.7; line-height: 1.5; }
</style>
