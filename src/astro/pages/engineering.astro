---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadStats } from '../lib/stats';
import { formatBytes, formatNumber } from '../lib/ssr';

const stats = loadStats();

type Fix = {
  title: string;
  repo: string;
  pr: string;
  body: string;
};

const FIXES: Fix[] = [
  {
    title: 'head.modified = Time.now, not created + 1 second',
    repo: 'fontist/fontisan',
    pr: '102',
    body: "Chrome's OTS rejects WOFF2 fonts whose head.modified is within ~1 hour of head.created. The previous \"bump by 1 second\" heuristic was inside that rejection window.",
  },
  {
    title: 'WOFF2 file padded to 4-byte boundary',
    repo: 'fontist/fontisan',
    pr: '102',
    body: "Chrome's OTS rejects WOFF2 files whose total length is not divisible by 4. fontTools pads; we didn't. Now we do.",
  },
  {
    title: 'Single source of truth for 255UInt16 encoding',
    repo: 'fontist/fontisan',
    pr: 'earlier',
    body: 'Three copies of encode_255_uint16 had the code-byte mapping inverted. Extracted a UInt255 module so all three call sites agree.',
  },
  {
    title: 'Brotli mode = :font actually plumbed through',
    repo: 'fontist/fontisan',
    pr: 'earlier',
    body: 'Brotli.deflate(data, quality: 11) silently dropped the mode: argument. WOFF2 needs font mode per spec. Now explicit.',
  },
  {
    title: 'Glyph padding to 4-byte boundary per glyph',
    repo: 'fontist/fontisan',
    pr: 'earlier',
    body: "fontTools' _normaliseGlyfAndLoca(padding=4) pads each glyph so the decoder can reconstruct. We didn't. Now we do, via GlyfCanonicalizer.",
  },
  {
    title: 'CFF2 IndexBuilder 3-byte offset pack',
    repo: 'fontist/fontisan',
    pr: '103',
    body: 'pack("C3") on a single Integer raised ArgumentError. CFF2 INDEXes over 64 KB need offSize=3, so the OTC build crashed immediately. Manual byte split fixes it.',
  },
  {
    title: 'Stitcher: outline-first so cmap prefers real outlines',
    repo: 'fontist/fontisan',
    pr: '104',
    body: 'add_all_cbdt_glyphs ran before the outline-bindings loop. Cmap.build uses first-wins, so empty CBDT placeholders won. Stitch outlines first now.',
  },
  {
    title: 'propagate_cbdt_tables preserves all raw tables',
    repo: 'fontist/fontisan',
    pr: '103',
    body: 'Reading CFF2 via BinData returned nil (round-trip bug), so the propagation path dropped CFF2 from every face. Now reads raw bytes from table_data.',
  },
  {
    title: 'CpMap excludes CBDT-only donors from outline cp_map',
    repo: 'essenfont/essenfont',
    pr: '29',
    body: "NotoColorEmoji's cmap entries got into the outline cp_map and pollinated every face with empty .notdef slots. CBDT data now propagates separately via propagate_cbdt_tables.",
  },
  {
    title: 'UFO compiler enforces .notdef at GID 0',
    repo: 'fontist/fontisan',
    pr: '103',
    body: 'OpenType requires GID 0 to be .notdef. Without it, the alphabetically-first glyph landed at GID 0 and the cmap parser silently dropped its codepoint. Reproducible: Enclosed Ideographic Supplement lost U+1F200.',
  },
  {
    title: 'face_lookup picks the face with real outlines',
    repo: 'essenfont/essenfont.github.io',
    pr: '10',
    body: "Website's face_lookup used ||= (first-face-wins). For SMP codepoints whose outline donor put glyphs only in face 8, it picked face 0's empty cmap slots. Now scores per-cp by non-empty glyf count.",
  },
  {
    title: 'Noto Emoji (monochrome) as Emoticons donor for TTC',
    repo: 'essenfont/essenfont',
    pr: '29',
    body: "NotoColorEmoji is CBDT-only; the TTC fallback can't carry bitmaps. Added NotoEmoji (glyf) as the TTC Emoticons donor; NotoColorEmoji remains for the OTC.",
  },
  {
    title: 'Code-chart synthetic donors for unregistered blocks',
    repo: 'essenfont/essenfont',
    pr: '29',
    body: 'Ideographic Symbols and Punctuation (12 cps) and Enclosed Ideographic Supplement (64 cps) had no OFL donor. Generated synthetic TTFs from ucode\'s code-chart PDF extractor.',
  },
];
---
<BaseLayout
  title="Engineering — Essenfont"
  description="How Essenfont made Chrome accept every per-block WOFF2 subset, switched to a canonical CFF2 OTC, and stitched 38 donor fonts into one universal Unicode 17 typeface."
  canonical="/engineering"
>
  <article class="engineering">
    <header class="page-head">
      <p class="eyebrow">Engineering</p>
      <h1>How we got every WOFF2 subset past Chrome's OTS</h1>
      <p class="lede">
        Essenfont serves {stats.websiteSubsets.woff2Count} per-block WOFF2 subsets. When we started this push, only
        <strong>199 of 211</strong> loaded in Chrome — the rest were silently rejected by
        Chrome's OpenType Sanitizer with a useless "network error". This page documents
        the {FIXES.length} fixes across three repos that took acceptance to
        <strong>{stats.websiteSubsets.woff2Count}/{stats.websiteSubsets.woff2Count}</strong>
        and produced a canonical OTC.
      </p>
    </header>

    <section class="stats-grid">
      <div class="stat">
        <div class="stat-num">{formatNumber(stats.unicode.assignedCodepointCount)}</div>
        <div class="stat-cap">Assigned Unicode {stats.unicode.version} codepoints</div>
      </div>
      <div class="stat">
        <div class="stat-num">{stats.unicode.blockCount}</div>
        <div class="stat-cap">Unicode blocks covered</div>
      </div>
      <div class="stat">
        <div class="stat-num">{stats.donorCount}</div>
        <div class="stat-cap">OFL-licensed donor fonts assembled</div>
      </div>
      <div class="stat">
        <div class="stat-num">{formatBytes(stats.fontBinaries.otcSizeBytes)}</div>
        <div class="stat-cap">Canonical OTC (CFF2 + CBDT)</div>
      </div>
      <div class="stat">
        <div class="stat-num">{stats.websiteSubsets.woff2Count}</div>
        <div class="stat-cap">Per-block WOFF2 subsets on this site</div>
      </div>
      <div class="stat">
        <div class="stat-num">{formatBytes(stats.websiteSubsets.woff2TotalBytes)}</div>
        <div class="stat-cap">Total WOFF2 payload</div>
      </div>
    </section>

    <section class="prose">
      <h2>The problem</h2>
      <p>
        Chrome's OpenType Sanitizer (OTS) silently rejects fonts it doesn't like. The
        browser console shows nothing useful — the network tab shows the file downloaded
        with HTTP 200, then <code>document.fonts.load()</code> rejects with
        <em>"A network error occurred."</em> The only signal is a missing glyph where a
        real one should be.
      </p>
      <p>
        Our website had 12 such blocks: emoticons, Tangut, ideographic symbols,
        transport and map symbols, and others. All had donor glyphs. None reached the
        browser.
      </p>

      <h2>The fixes</h2>
      <p>
        Thirteen named commits across <code>fontist/fontisan</code>,
        <code>essenfont/essenfont</code>, and <code>essenfont/essenfont.github.io</code>.
        Each one closed a specific OTS rejection or build-pipeline gap.
      </p>

      <ol class="fixes">
        {FIXES.map((fix, i) => (
          <li>
            <h3>
              <a href={`https://github.com/${fix.repo}/pull/${fix.pr}`} target="_blank" rel="noopener">
                {fix.title}
              </a>
              <span class="fix-meta">{fix.repo} · #{fix.pr}</span>
            </h3>
            <p>{fix.body}</p>
          </li>
        ))}
      </ol>

      <h2>The result</h2>
      <p>
        Every per-block WOFF2 subset now loads in Chrome. The canonical
        <code>Essenfont-Regular.otc</code> carries CFF2 outlines for the donor fonts
        that the legacy TTC (glyf-only) couldn't represent — Tangut (Noto Serif
        Tangut), Ideographic Symbols (synthetic from code charts), Enclosed Ideographic
        Supplement (synthetic), and color emoji bitmaps (NotoColorEmoji via CBDT/CBLC
        passthrough).
      </p>
      <p>
        <a href="/download">Download the OTC</a> or
        <a href="/unicode">browse every codepoint</a>.
      </p>

      <h2>What's next</h2>
      <ul>
        <li>
          <strong>Color emoji in WOFF2.</strong> The OTC has CBDT/CBLC; the per-block
          WOFF2 subsets don't yet preserve them (fontisan subsetter strips tables it
          doesn't recognize). Tracked in <code>TODO.emoji/</code>.
        </li>
        <li>
          <strong>Tangut on the website.</strong> Donor is CFF-only; the TTC fallback
          can't carry CFF. Once the website switches to subsetting from the OTC
          (blocked on fontisan's CFF2 subsetter support), Tangut goes live.
        </li>
        <li>
          <strong>Astro migration.</strong> Plan in <code>TODO.astro/</code>. Faster
          builds, MDX changelog, smaller JS payload.
        </li>
      </ul>
    </section>
  </article>
</BaseLayout>

<style>
.engineering {
  max-width: 720px;
  margin: 0 auto;
  padding: 4rem 1.5rem 6rem;
}
.page-head { margin-bottom: 3rem; }
.eyebrow {
  font-family: var(--mono-font, 'IBM Plex Mono', monospace);
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--ef-rose, #bf4e6a);
  margin: 0 0 0.5rem;
}
h1 {
  font-family: var(--display-font, Spectral, serif);
  font-size: clamp(2rem, 5vw, 3rem);
  line-height: 1.1;
  margin: 0 0 1rem;
  color: var(--spec-ink, #1c1a18);
}
.lede {
  font-size: 1.125rem;
  line-height: 1.6;
  color: var(--spec-ink, #1c1a18);
  opacity: 0.85;
}
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 1.5rem;
  margin: 3rem 0;
  padding: 2rem 0;
  border-top: 1px solid var(--spec-ink, #1c1a18);
  border-bottom: 1px solid var(--spec-ink, #1c1a18);
}
.stat { text-align: left; }
.stat-num {
  font-family: var(--display-font, Spectral, serif);
  font-size: 2.5rem;
  line-height: 1;
  color: var(--ef-rose, #bf4e6a);
}
.stat-cap {
  font-size: 0.875rem;
  margin-top: 0.5rem;
  color: var(--spec-ink, #1c1a18);
  opacity: 0.7;
}
.prose h2 {
  font-family: var(--display-font, Spectral, serif);
  font-size: 1.75rem;
  margin: 2.5rem 0 1rem;
}
.prose p, .prose li {
  font-size: 1rem;
  line-height: 1.7;
  color: var(--spec-ink, #1c1a18);
}
.prose code {
  font-family: var(--mono-font, 'IBM Plex Mono', monospace);
  background: rgba(0,0,0,0.05);
  padding: 0.1em 0.4em;
  border-radius: 3px;
  font-size: 0.9em;
}
ol.fixes {
  list-style: none;
  padding: 0;
  counter-reset: fix;
}
ol.fixes li {
  counter-increment: fix;
  position: relative;
  padding-left: 3rem;
  margin-bottom: 2rem;
}
ol.fixes li::before {
  content: counter(fix, decimal-leading-zero);
  position: absolute;
  left: 0;
  top: 0;
  font-family: var(--mono-font, 'IBM Plex Mono', monospace);
  font-size: 0.875rem;
  color: var(--ef-rose, #bf4e6a);
  opacity: 0.7;
}
ol.fixes h3 {
  font-size: 1.1rem;
  margin: 0 0 0.5rem;
  font-weight: 600;
}
ol.fixes h3 a {
  color: var(--spec-ink, #1c1a18);
  text-decoration: underline;
  text-decoration-color: var(--ef-rose, #bf4e6a);
  text-underline-offset: 3px;
}
.fix-meta {
  display: block;
  font-family: var(--mono-font, 'IBM Plex Mono', monospace);
  font-size: 0.75rem;
  color: var(--spec-ink, #1c1a18);
  opacity: 0.6;
  margin-top: 0.25rem;
}
</style>
