---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteSearch from '../components/SiteSearch.vue';
---
<BaseLayout
  title="Search — Essenfont"
  description="Search every Unicode 17 block, character, and donor in the Essenfont."
  canonical="/search"
>
  <div class="search-page container">
    <header class="page-head">
      <h1>Find a character</h1>
      <p class="search-help">
        Type a block name, a codepoint (<code>U+0041</code>, <code>0041</code>, or <code>41</code>),
        a decimal value, or a single character. Donor families by name too.
        Use <kbd>↑</kbd>/<kbd>↓</kbd> to move, <kbd>Enter</kbd> to go, <kbd>Esc</kbd> to clear.
      </p>
    </header>

    <SiteSearch client:load />
  </div>
</BaseLayout>

<style>
  .search-page { max-width: 760px; padding: 3rem 1.5rem 6rem; }
  .page-head { margin-bottom: 2rem; }
  
  h1 {
    font-family: var(--spec-font-display);
    font-size: clamp(2rem, 5vw, 3rem); margin: 0;
  }
  .search-help {
    margin-top: 1rem;
    font-size: 0.9375rem;
    color: var(--ef-text-2, #4a4540);
    line-height: 1.6;
    max-width: 56ch;
  }
  .search-help code, .search-help kbd {
    font-family: var(--spec-font-mono, monospace);
    font-size: 0.875em;
    background: var(--ef-surface, #f2efe9);
    padding: 0.1em 0.4em;
    border-radius: 2px;
  }
</style>
