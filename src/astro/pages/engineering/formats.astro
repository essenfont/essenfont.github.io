---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadStats } from '../../lib/stats';
import { formatBytes } from '../../lib/ssr';

const stats = loadStats();

const formats = [
  {
    file: 'Essenfont-Regular.ttc',
    desc: 'TrueType Collection, glyf outlines, 5 plane subfonts. Canonical install form emitted by Collection::Builder with table-dedup by SHA256 across the five faces. v0.2.x ships this as the only TTC variant.',
    size: formatBytes(stats.fontBinaries.ttcSizeBytes),
    use: 'Desktop + website source',
  },
  {
    file: 'Essenfont-{BMP,SMP,SIP,TIP,SSP}.ttf',
    desc: 'Five standalone TTFs, one per plane. Written from fontisan.Stitcher.write_to per partition. Useful for clients that cannot enumerate TTC faces.',
    size: 'Per plane',
    use: 'Legacy + PDF',
  },
  {
    file: 'Essenfont-{BMP,SMP,SIP,TIP,SSP}.woff2',
    desc: 'Per-plane WOFF2s encoded via fontisan.Pipeline.OutputWriter (Brotli compression of each table). For @font-face whole-plane web embeds.',
    size: '~50% smaller than TTF',
    use: 'Whole-plane web embed',
  },
  {
    file: 'Per-block WOFF2 subsets (this site)',
    desc: `${stats.websiteSubsets.woff2Count} small WOFF2s — one per Unicode block — subset from the canonical TTC by scripts/subset-fonts.rb using fontisan's Ruby API. Wired to unicode-range in public/fonts.css so a visitor reading one block downloads only that block.`,
    size: formatBytes(stats.websiteSubsets.woff2TotalBytes) + ' total',
    use: 'Per-page web embed',
  },
];
---
<BaseLayout
  title="Output formats & distribution — Engineering — Essenfont"
  description="How the build produces output shapes from one TTC, plus the release pipeline (tag → CI → GitHub Release → website) and reproducibility recipe."
  canonical="/engineering/formats"
>
  <article class="formats-page">
    <header class="page-head">
      <p class="eyebrow"><a href="/engineering">Engineering</a> · Where · users</p>
      <h1>Output formats & distribution</h1>
      <p class="lede">
        One build, six shapes — each tuned for a different audience: desktop install, modern desktop, legacy tooling, per-plane TTF/WOFF2, and the per-block WOFF2 subsets this site serves. If you landed here looking for install commands or CSS embedding patterns, see the new <a href="/docs/usage">How to use</a> guide.
      </p>
    </header>

    <section class="prose">
      <h2>The six output formats</h2>
      <div class="format-grid">
        {formats.map(f => (
          <div class="format-card">
            <div class="format-head">
              <code class="format-file">{f.file}</code>
              <span class="format-use">{f.use}</span>
            </div>
            <p class="format-desc">{f.desc}</p>
            <p class="format-size">{f.size}</p>
          </div>
        ))}
      </div>

      <h2>Release pipeline</h2>
      <p>
        Essenfont ships via tag-triggered GitHub Actions in two repos:
      </p>
      <pre class="release-flow"><code>┌──────────────────────────────────────────────────────┐
│ essenfont/essenfont  (build repo)                    │
│                                                      │
│  maintainer pushes tag v0.2.8                        │
│              │                                       │
│              ▼                                       │
│  release.yml (tag trigger)                           │
│    • set up Ruby 3.2 + bundler-cache                 │
│    • ucode fetch fonts (most Noto donors)            │
│    • download FSung files (Google Drive, see sources) │
│    • bundle exec ruby scripts/build.rb --format=ttc  │
│    • bundle exec ruby scripts/build.rb --format=ttf-per-plane │
│    • bundle exec ruby scripts/encode-woff.rb  (×5 planes)     │
│    • bundle exec ruby scripts/emit_coverage_manifest.rb       │
│    • upload all artifacts to GH Release v0.2.8        │
│    • npm publish essenfont@0.2.8 → npm registry      │
│    • repository_dispatch → essenfont.github.io        │
└──────────────────────┬───────────────────────────────┘
                       │
                       ▼
┌──────────────────────────────────────────────────────┐
│ essenfont/essenfont.github.io  (this site)           │
│                                                      │
│  site.yml (repository_dispatch + 6h schedule)        │
│    • download latest Essenfont-Regular.ttc           │
│    • bundle exec ruby scripts/subset-fonts.rb        │
│      → public/fonts/*.woff2 (per-block subsets)      │
│    • npm ci + npm run build (Astro SSG, 160k routes) │
│    • deploy to GitHub Pages                          │
└──────────────────────────────────────────────────────┘</code></pre>
      <p>
        The site polls every 6 hours for new releases and redeploys automatically — so when a new Essenfont tag is cut, this website's per-block WOFF2s and coverage numbers update without any manual intervention.
      </p>

      <h2>Reproducibility</h2>
      <p>
        The full distribution chain — donor binaries → TTC → per-plane TTFs → WOFF2s → per-block subsets — is reproducible from the committed manifests in two repos:
      </p>
      <pre><code># Build the font
git clone https://github.com/essenfont/essenfont
cd essenfont &amp;&amp; bundle install
bundle exec ucode fetch fonts
bundle exec ruby scripts/build.rb --format=ttc

# Subset for the web (this site)
git clone https://github.com/essenfont/essenfont.github.io
cd essenfont.github.io &amp;&amp; bundle install &amp;&amp; npm ci
ESSENFONT_TTC=../essenfont/Essenfont-Regular.ttc bundle exec ruby scripts/subset-fonts.rb
npm run build</code></pre>
      <p>
        The build never writes binaries to git. Donors come from <code>ucode fetch fonts</code> (Noto and similar) or manual download (Full-Sung from F.G. Wang's Google Drive). The resulting TTC and its subsets live in GitHub Releases and the npm package <code>essenfont</code>; this site serves per-block WOFF2 from GitHub Pages.
      </p>

      <p>
        For install + CSS + embedding patterns (the user-facing "how do I use it" questions), see the new <a href="/docs/usage">/docs/usage</a> guide. For a per-component technical reference, see <a href="/docs/architecture">/docs/architecture</a>.
      </p>

      <p class="next">
        Next: <a href="/engineering/coverage">coverage, gaps, and roadmap</a> — what works today, what's blocked on upstream fontisan fixes, and the lessons learned getting WOFF2 past Chrome's OpenType Sanitizer.
      </p>
    </section>
  </article>
</BaseLayout>

<style>
.formats-page { max-width: 800px; margin: 0 auto; padding: 4rem 1.5rem 6rem; }
.page-head { margin-bottom: 3rem; }
.eyebrow {
  font-family: var(--spec-font-mono, 'IBM Plex Mono', monospace);
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--ef-rose, #bf4e6a);
  margin: 0 0 0.5rem;
}
.eyebrow a { color: inherit; text-decoration: none; }
.eyebrow a:hover { text-decoration: underline; }
h1 {
  font-family: var(--spec-font-display, Spectral, serif);
  font-size: clamp(1.75rem, 4.5vw, 2.5rem);
  line-height: 1.15;
  margin: 0 0 1rem;
  color: var(--spec-ink, #1c1a18);
}
.lede {
  font-size: 1.1rem;
  line-height: 1.6;
  color: var(--spec-ink, #1c1a18);
  opacity: 0.85;
}
.lede a {
  color: var(--ef-rose, #bf4e6a);
  text-decoration: underline;
  text-underline-offset: 3px;
}
.prose h2 {
  font-family: var(--spec-font-display, Spectral, serif);
  font-size: 1.6rem;
  margin: 2.5rem 0 1rem;
}
.prose p, .prose li {
  font-size: 1rem;
  line-height: 1.7;
  color: var(--spec-ink, #1c1a18);
}
.prose a {
  color: var(--ef-rose, #bf4e6a);
  text-decoration: underline;
  text-underline-offset: 3px;
}
.prose code {
  font-family: var(--spec-font-mono, 'IBM Plex Mono', monospace);
  background: rgba(0,0,0,0.05);
  padding: 0.1em 0.4em;
  border-radius: 3px;
  font-size: 0.9em;
}
.prose pre {
  background: rgba(0,0,0,0.05);
  padding: 1rem 1.25rem;
  border-radius: 4px;
  overflow-x: auto;
  font-family: var(--spec-font-mono, 'IBM Plex Mono', monospace);
  font-size: 0.82rem;
  line-height: 1.7;
}
.prose pre code { background: none; padding: 0; }
.release-flow { font-size: 0.68rem; line-height: 1.55; white-space: pre; }

.format-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.75rem;
  margin: 1.5rem 0;
}
.format-card {
  padding: 1rem 1.25rem;
  border: 1px solid rgba(128,128,128,0.25);
  border-radius: 4px;
  border-left: 3px solid var(--ef-rose, #bf4e6a);
}
.format-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 0.4rem;
}
.format-file {
  font-family: var(--spec-font-mono, 'IBM Plex Mono', monospace);
  font-size: 0.85rem;
  background: rgba(0,0,0,0.05);
  padding: 0.15em 0.5em;
  border-radius: 3px;
  word-break: break-all;
}
.format-use {
  font-family: var(--spec-font-mono, 'IBM Plex Mono', monospace);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--ef-rose, #bf4e6a);
}
.format-desc { font-size: 0.92rem; line-height: 1.55; margin: 0; }
.format-size {
  font-family: var(--spec-font-mono, 'IBM Plex Mono', monospace);
  font-size: 0.75rem;
  opacity: 0.6;
  margin: 0.4rem 0 0;
}

.next {
  margin-top: 3rem !important;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(128,128,128,0.2);
  font-size: 0.95rem !important;
}
</style>
