---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SPECIMEN_PANELS } from '../lib/specimen';
import RandomCodepoint from '../components/RandomCodepoint.vue';

// Deterministic "today's codepoint" — rotates daily across all featured
// codepoints in SPECIMEN_PANELS. No DB needed.
const allFeatured = SPECIMEN_PANELS.flatMap((p) => p.codepoints);
const day = Math.floor(Date.now() / 86_400_000);
const todayCp = allFeatured[day % allFeatured.length];
const todayHex = todayCp.toString(16).toUpperCase().padStart(4, '0');
---

<BaseLayout
  title="404 — Not found — Essenfont"
  description="That codepoint is unassigned, or this page doesn't exist."
>
  <article class="nf">
    <div class="nf-panels">
      <div class="nf-panel nf-panel--broken">
        <span class="nf-tag mono">without essenfont</span>
        <div class="nf-tofu" aria-hidden="true">
          <span class="nf-tofu-box">▢</span>
          <span class="nf-tofu-cp mono">U+0404</span>
        </div>
        <p class="nf-cap">a missing codepoint shows as tofu</p>
      </div>

      <div class="nf-arrow" aria-hidden="true">
        <span class="mono">install →</span>
        <svg width="80" height="20" viewBox="0 0 80 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <path d="M2 10 H75 M68 4 L75 10 L68 16"/>
        </svg>
      </div>

      <div class="nf-panel nf-panel--fixed">
        <span class="nf-tag mono">today's codepoint</span>
        <a class="nf-glyph" href={`/unicode/char/${todayHex}`}>
          {String.fromCodePoint(todayCp)}
        </a>
        <span class="nf-cp mono">U+{todayHex}</span>
        <p class="nf-cap">Unicode 17 has plenty of beautiful ones</p>
      </div>
    </div>

    <h1 class="nf-head">That codepoint is unassigned, or this page doesn't exist.</h1>
    <p class="nf-sub">
      The page you wanted isn't here. Try one of these instead:
    </p>

    <nav class="nf-nav" aria-label="Get back on track">
      <a href="/" class="nf-link">Home</a>
      <a href="/unicode" class="nf-link">Browse unicode</a>
      <a href="/docs/usage" class="nf-link">How to use</a>
      <a href="/search" class="nf-link">Search</a>
    </nav>
    <div class="nf-surprise"><RandomCodepoint client:idle /></div>
  </article>
</BaseLayout>

<style>
  .nf {
    max-width: 880px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
    text-align: center;
  }
  .nf-panels {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }
  @media (max-width: 640px) {
    .nf-panels { grid-template-columns: 1fr; gap: 1.5rem; }
    .nf-arrow { transform: rotate(90deg); }
  }
  .nf-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.75rem 1.25rem;
    border: 1px solid var(--ef-rule-strong, rgba(26,24,21,0.16));
    border-radius: 8px;
    min-height: 220px;
    justify-content: center;
    gap: 0.6rem;
  }
  .nf-panel--broken { background: rgba(0,0,0,0.02); }
  .nf-panel--fixed {
    background: rgba(42, 92, 138, 0.04);
    border-color: rgba(42, 92, 138, 0.25);
  }
  .nf-tag {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ef-text-3);
  }
  .nf-tofu-box {
    font-size: 4.5rem;
    line-height: 1;
    color: var(--ef-text-3);
    opacity: 0.6;
  }
  .nf-tofu-cp {
    font-size: 0.78rem;
    color: var(--ef-text-3);
    margin-top: -0.25rem;
  }
  .nf-glyph {
    font-family: var(--spec-font-glyph, "Essenfont"), "Noto Sans", sans-serif;
    font-size: 5rem;
    line-height: 1;
    text-decoration: none;
    color: var(--ef-text);
    transition: transform 0.2s ease;
  }
  .nf-glyph:hover { transform: scale(1.08); color: var(--ef-accent); }
  .nf-cp {
    font-size: 0.78rem;
    color: var(--ef-accent);
  }
  .nf-cap {
    font-size: 0.82rem;
    opacity: 0.7;
    margin: 0.5rem 0 0;
    font-style: italic;
  }
  .nf-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--ef-accent);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .nf-head {
    font-family: var(--spec-font-display);
    font-weight: 600;
    font-size: clamp(1.4rem, 3vw, 1.85rem);
    line-height: 1.25;
    margin: 0 0 0.5rem;
    color: var(--ef-text);
  }
  .nf-sub {
    font-size: 1rem;
    opacity: 0.78;
    margin: 0 0 2rem;
  }
  .nf-nav {
    display: flex;
    gap: 0.6rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .nf-link {
    padding: 0.65rem 1.25rem;
    border: 1px solid var(--ef-rule-strong, rgba(26,24,21,0.16));
    border-radius: 6px;
    text-decoration: none;
    color: var(--ef-text);
    font-family: var(--spec-font-mono);
    font-size: 0.78rem;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  .nf-link:hover {
    border-color: var(--ef-accent);
    color: var(--ef-accent);
    background: rgba(42, 92, 138, 0.04);
  }
  .mono { font-family: var(--spec-font-mono); }
  .nf-surprise { margin-top: 1.5rem; }
</style>
