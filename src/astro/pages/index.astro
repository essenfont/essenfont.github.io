  .install-snippets {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 768px) { .install-snippets { grid-template-columns: 1fr; } }
  .snippet {
    background: var(--ef-paper);
    border: 1px solid var(--ef-rule);
  }
  .snippet-tab {
    display: flex;
    justify-content: space-between;
    align-items: center;
