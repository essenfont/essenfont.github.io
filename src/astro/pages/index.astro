    border-bottom: 1px solid var(--ef-rule);
    background: var(--ef-paper-3);
  }
  .snippet-copy {
    background: none;
    border: 1px solid var(--ef-rule-2);
    color: var(--ef-ink-3);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.625rem;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  .snippet-copy:hover { color: var(--ef-ochre); border-color: var(--ef-ochre); }
