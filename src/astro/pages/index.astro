---
import BaseLayout from '../layouts/BaseLayout.astro';
import TypeTester from '../components/TypeTester.vue';
import BrandMark from '../components/BrandMark.astro';
import SpecimenTile from '../components/SpecimenTile.astro';
import AutoTypingHeadline from '../components/AutoTypingHeadline.vue';
import CountUp from '../components/CountUp.vue';
import { loadAllBlocks, loadUnicodeVersion } from '../lib/unicode';
import { loadStats } from '../lib/stats';
import { formatBytes, formatNumber } from '../lib/ssr';
import { SPECIMEN_PANELS, verifyPanelsForBuild } from '../lib/specimen';

const blocks = loadAllBlocks();
const version = loadUnicodeVersion();
const stats = loadStats();
// Build-time verification — surfaces broken feature glyphs loudly.
verifyPanelsForBuild();

function slugify(name: string): string {
  return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

// Hand-picked specimens spanning the planes — each tells a story.
const featured = [
  { cp: 0x0041,   name: 'Latin A',          plane: 'BMP', note: 'The first letter. Where every font begins.' },
  { cp: 0x4E00,   name: 'CJK 一',           plane: 'BMP', note: 'CJK Unified Ideograph — ten thousand.' },
  { cp: 0x1F4A9,  name: 'Pile of Poo',      plane: 'SMP', note: 'Color bitmap glyph from NotoColorEmoji.' },
  { cp: 0x1D11E,  name: 'Musical G clef',   plane: 'SMP', note: 'One staff position. Drawn by Noto Sans.' },
  { cp: 0x2000B,  name: 'CJK Ext B',        plane: 'SIP', note: 'A rare ideograph — 4,192 in this plane alone.' },
  { cp: 0x30F4D,  name: 'CJK Ext G',        plane: 'TIP', note: 'Recovered. 4,939 codepoints, was 1,022.' },
  { cp: 0x12BAD,  name: 'Cuneiform',        plane: 'SMP', note: 'A wedge of Sumero-Akkadian history.' },
  { cp: 0x13000,  name: 'Egyptian Hieroglyph', plane: 'SMP', note: 'Gardiner sign list. First dynasty onwards.' },
  { cp: 0xE0001,  name: 'Language Tag',     plane: 'SSP', note: 'Tags — invisible but defined.' },
];
---

<BaseLayout
  title="Essenfont — Universal Unicode 17 Font"
  description="One redistributable OpenType font covering every assigned Unicode 17 codepoint. Real outlines for ~160,000 characters, drawn from canonical OFL-licensed donor fonts."
  canonical="/"
  active="specimen"
>
  <section class="hero" id="hero">
    <div class="hero-logo" id="hero-logo">
      <BrandMark size="hero" animated={true} interactive={true} alt="Essenfont" />
    </div>
    <div class="hero-content">
      <h1 class="display">
        <AutoTypingHeadline client:visible words={[
          'Essenfont',
          '美食フォント',
          'فونت إسن',
          '𓆎𓃭𓅓𓂻𓈖',
          'Essenfont',
        ]} />
      </h1>
      <p class="lede">
        One redistributable TrueType Collection covering every assigned Unicode {version.version} codepoint —
        {formatNumber(version.charCount)} characters across {version.blockCount} blocks.
        Built from {stats.donorCount} canonical OFL-licensed donor fonts.
      </p>
      <div class="cta-row">
        <a href="/download" class="btn-primary">Download ({formatBytes(stats.fontBinaries.otcSizeBytes)})</a>
        <a href="/docs/usage" class="btn-ghost">How to use</a>
        <a href="/unicode" class="btn-ghost">Browse Unicode</a>
      </div>
      <p class="hero-foot">
        Latest release:
        {stats.release?.tag && <strong class="hero-version">{stats.release.tag}</strong>}
        {stats.release?.date && <span> · {new Date(stats.release.date).toISOString().slice(0, 10)}</span>}
        {' · '}
        <a href="https://github.com/essenfont/essenfont/releases" target="_blank" rel="noopener">all releases</a>
        {' · '}
        <a href="https://www.npmjs.com/package/essenfont" target="_blank" rel="noopener">npm</a>
      </p>
    </div>
  </section>

  <section class="tester-section">
    <div class="container tester-wrap">
      <TypeTester client:visible />
    </div>
  </section>

  <section class="stats-grid">
    <div class="stat">
      <div class="stat-num"><CountUp client:visible value={version.charCount} duration={2000} /></div>
      <div class="stat-cap">Assigned Unicode {version.version} codepoints</div>
    </div>
    <div class="stat">
      <div class="stat-num"><CountUp client:visible value={version.blockCount} duration={1500} /></div>
      <div class="stat-cap">Unicode blocks covered</div>
    </div>
    <div class="stat">
      <div class="stat-num"><CountUp client:visible value={stats.donorCount} duration={1200} /></div>
      <div class="stat-cap">OFL-licensed donor fonts</div>
    </div>
    <div class="stat">
      <div class="stat-num"><CountUp client:visible value={Math.round((stats.fontBinaries.otcSizeBytes ?? 0) / 1024 / 1024)} duration={1400} /> MB</div>
      <div class="stat-cap">Canonical OTC (5 planes)</div>
    </div>
    <div class="stat">
      <div class="stat-num"><CountUp client:visible value={stats.websiteSubsets.woff2Count} duration={1500} /></div>
      <div class="stat-cap">Per-block WOFF2 subsets</div>
    </div>
    <div class="stat">
      <div class="stat-num"><CountUp client:visible value={Math.round(stats.websiteSubsets.woff2TotalBytes / 1024 / 1024)} duration={1600} /> MB</div>
      <div class="stat-cap">Total WOFF2 payload</div>
    </div>
  </section>

  <section class="specimen-section">
    <h2>Unicode 17, in six panels</h2>
    <p>From world scripts to extinct ones. Each glyph below is rendered in Essenfont, sourced from its canonical donor font.</p>
    <div class="specimen-grid">
      {SPECIMEN_PANELS.map(panel => <SpecimenTile panel={panel} />)}
    </div>
    <a href="/unicode" class="see-all">Browse all {version.blockCount} blocks →</a>
  </section>

  <script>
    // Mouse parallax — the hero logo tilts in 3D toward the cursor.
    // Subtle (max 10°), smoothed via requestAnimationFrame.
    const hero = document.getElementById('hero');
    const logo = document.getElementById('hero-logo');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (hero && logo && !reduceMotion) {
      let targetX = 0, targetY = 0, currentX = 0, currentY = 0;
      let rafId: number | null = null;
      const MAX_TILT = 10;

      function tick() {
        currentX += (targetX - currentX) * 0.12;
        currentY += (targetY - currentY) * 0.12;
        logo.style.setProperty('--tilt-x', `${currentY.toFixed(2)}deg`);
        logo.style.setProperty('--tilt-y', `${currentX.toFixed(2)}deg`);
        if (Math.abs(targetX - currentX) > 0.01 || Math.abs(targetY - currentY) > 0.01) {
          rafId = requestAnimationFrame(tick);
        } else {
          rafId = null;
        }
      }
      function scheduleTick() {
        if (rafId === null) rafId = requestAnimationFrame(tick);
      }

      hero.addEventListener('mousemove', (e) => {
        const rect = hero.getBoundingClientRect();
        const nx = ((e.clientX - rect.left) / rect.width - 0.5) * 2;   // -1..1
        const ny = ((e.clientY - rect.top) / rect.height - 0.5) * 2;
        targetX = nx * MAX_TILT;
        targetY = ny * MAX_TILT;
        scheduleTick();
      });
      hero.addEventListener('mouseleave', () => {
        targetX = 0;
        targetY = 0;
        scheduleTick();
      });

      // Click — quick 360° spin as a playful acknowledgment.
      const mark = logo.querySelector('.brand-mark');
      if (mark) {
        logo.addEventListener('click', () => {
          mark.classList.remove('is-spinning');
          // force reflow so the animation restarts.
          void (mark as HTMLElement).offsetWidth;
          mark.classList.add('is-spinning');
        });
      }
    }
  </script>
</BaseLayout>

<style>
.hero {
  padding: 5rem 0 3rem;
  text-align: center;
  perspective: 1200px;
}
.hero-logo {
  margin-bottom: 2.5rem;
  display: flex;
  justify-content: center;
  --tilt-x: 0deg;
  --tilt-y: 0deg;
  transform: perspective(900px) rotateX(var(--tilt-x)) rotateY(var(--tilt-y));
  transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  will-change: transform;
  cursor: pointer;
}
.hero-logo .brand-mark.is-spinning {
  animation: bm-spin-once 0.7s cubic-bezier(0.2, 0.8, 0.2, 1);
}
@keyframes bm-spin-once {
  from { transform: rotate3d(0, 1, 0, 0deg); }
  to   { transform: rotate3d(0, 1, 0, 360deg); }
}
.tester-section {
  padding: 2rem 0;
}
.tester-wrap {
  max-width: 920px;
  margin: 0 auto;
}
.hero-content {
  max-width: 720px;
  margin: 0 auto;
}

.display {
  font-family: var(--spec-font-display);
  font-weight: 600;
  font-size: clamp(3rem, 10vw, 6rem);
  line-height: 1;
  letter-spacing: -0.03em;
  margin: 0.5rem 0 1.5rem;
}
.lede {
  font-size: 1.125rem;
  line-height: 1.6;
  opacity: 0.85;
  margin-bottom: 2rem;
}
.cta-row {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
}
.hero-foot {
  font-family: var(--spec-font-mono);
  font-size: 0.78rem;
  color: var(--ef-text-3);
  margin: 1.25rem 0 0;
}
.hero-foot a { color: var(--ef-accent); text-decoration: none; }
.hero-foot a:hover { text-decoration: underline; }
.hero-version { color: var(--ef-accent); font-family: var(--spec-font-mono); font-weight: 600; }
.hero-foot a:hover { text-decoration: underline; }
.btn-primary, .btn-ghost {
  padding: 0.75rem 1.5rem;
  border-radius: 4px;
  font-weight: 600;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}
.btn-primary {
  background: var(--ef-accent);
  color: white;
}
.btn-ghost {
  border: 1px solid currentColor;
  color: var(--ef-text);
}
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 1.5rem;
  padding: 3rem 0;
  border-top: 1px solid var(--ef-rule);
  border-bottom: 1px solid var(--ef-rule);
  margin: 3rem 0;
}
.stat-num {
  font-family: var(--spec-font-display);
  font-weight: 600;
  font-size: 2.75rem;
  line-height: 1;
  letter-spacing: -0.02em;
  color: var(--ef-accent);
}
.stat-cap {
  font-size: 0.875rem;
  margin-top: 0.5rem;
  opacity: 0.7;
}
.specimen-section {
  padding: 2rem 0 4rem;
}
.specimen-section h2 {
  font-family: var(--spec-font-display);
  font-weight: 600;
  font-size: 1.75rem;
  margin-bottom: 0.5rem;
}
.specimen-section > p {
  font-size: 0.95rem;
  opacity: 0.78;
  margin-bottom: 1rem;
}
.specimen-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1rem;
  margin: 2rem 0;
}
.see-all {
  display: inline-block;
  margin-top: 1rem;
  color: var(--ef-accent);
  text-decoration: none;
}
</style>

<script>
  // Live type tester — render the input through the Essenfont web font
  // (loaded via the CDN's basic-latin subset), with graceful fallback.
  const input = document.getElementById('tester-input') as HTMLTextAreaElement;
  const output = document.getElementById('tester-output') as HTMLDivElement;
  const folio = document.getElementById('tester-folio');
  const sizeInput = document.getElementById('tester-size-input') as HTMLInputElement;
  const sizeValue = document.getElementById('tester-size-value');

  if (input && output) {
    const render = () => {
      const text = input.value;
      output.textContent = text;
      if (folio) {
        const chars = [...text].length;
        const codepoints = text.length;
        folio.textContent = `${chars} char${chars === 1 ? '' : 's'} · ${codepoints} code unit${codepoints === 1 ? '' : 's'}`;
      }
    };
    const resize = () => {
      const px = `${sizeInput.value}px`;
      output.style.fontSize = px;
      if (sizeValue) sizeValue.textContent = px;
    };
    input.addEventListener('input', render);
    sizeInput.addEventListener('input', resize);
    render();
    resize();
  }

  // Copy-to-clipboard for install snippets
  document.querySelectorAll<HTMLButtonElement>('.snippet-copy').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.copy;
      const target = id ? document.getElementById(id) : null;
      if (target) {
        const text = target.innerText;
        navigator.clipboard?.writeText(text).then(() => {
          const original = btn.textContent;
          btn.textContent = 'copied';
          setTimeout(() => { btn.textContent = original; }, 1500);
        });
      }
    });
  });
</script>
