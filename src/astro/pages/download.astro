---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadStats } from '../lib/stats';
import { formatBytes } from '../lib/ssr';

const stats = loadStats();
---

<BaseLayout
  title="Install — Essenfont"
  description="Install Essenfont via Fontist, npm, CDN, or download the canonical OTC directly."
  canonical="/download"
  active="install"
>
  <section class="section install-hero">
    <div class="container">
      <div class="install-hero-grid">
        <div class="install-meta rise-1">
          <p class="eyebrow">§ Take it home</p>
          <p class="folio" style="margin-top: 1rem;">No. {stats.donorCount} donors</p>
        </div>
        <div class="install-pitch rise-2">
          <h1>One font.<br/><em class="text-ochre">Every</em> system.</h1>
          <p class="lede" style="margin-top: 2rem;">
            Pick the format that matches your stack. The full OTC covers
            every codepoint locally; per-block WOFF2 subsets load only what
            a browser needs; Fontist handles versioning for you.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section install-options">
    <div class="container">
      <ol class="options-list">
        <li class="option-row reveal" id="otc">
          <div class="option-num">
            <span class="option-index mono">01</span>
          </div>
          <div class="option-body">
            <h3 class="option-name">Canonical OTC</h3>
            <p class="option-format mono">CFF2 outlines · CBDT color bitmaps · {formatBytes(stats.fontBinaries.otcSizeBytes)}</p>
            <p class="option-desc">
              The full universal font. Every assigned Unicode {stats.unicode.version} codepoint,
              real outlines from {stats.donorCount} donors. Redistribution-friendly under OFL 1.1.
            </p>
            <a
              href="https://github.com/essenfont/essenfont/releases/latest"
              class="btn btn-primary btn-arrow"
              target="_blank"
              rel="noopener"
            >
              Download from GitHub Releases
            </a>
          </div>
        </li>

        <li class="option-row reveal" id="fontist">
          <div class="option-num">
            <span class="option-index mono">02</span>
          </div>
          <div class="option-body">
            <h3 class="option-name">Fontist · package manager</h3>
            <p class="option-format mono">Ruby · ~105 MB download · auto-updates</p>
            <p class="option-desc">
              The canonical way to install Essenfont. Fontist handles
              download, version pinning, and license acknowledgement.
              Pairs well with any tool in the Fontist ecosystem.
            </p>
            <div class="option-snippet">
              <div class="snippet-tab">
                <span class="folio">install</span>
                <button class="snippet-copy" data-copy="fontist-cmd">copy</button>
              </div>
              <pre id="fontist-cmd" class="snippet-code"><code set:html={`$ gem install fontist
$ fontist install "Essenfont"
# → ~/.fontist/fonts/Essenfont-Regular.otc`} /></pre>
            </div>
          </div>
        </li>

        <li class="option-row reveal" id="npm">
          <div class="option-num">
            <span class="option-index mono">03</span>
          </div>
          <div class="option-body">
            <h3 class="option-name">npm · for build pipelines</h3>
            <p class="option-format mono">Node · @essenfont/essenfont</p>
            <p class="option-desc">
              The same OTC, packaged for npm. Pull it into any frontend
              build (Vite, Astro, Next.js, esbuild) and let the bundler
              do the work.
            </p>
            <div class="option-snippet">
              <div class="snippet-tab">
                <span class="folio">install</span>
                <button class="snippet-copy" data-copy="npm-cmd">copy</button>
              </div>
              <pre id="npm-cmd" class="snippet-code"><code set:html={`$ npm install @essenfont/essenfont
# → node_modules/@essenfont/essenfont/Essenfont-Regular.otc`} /></pre>
            </div>
          </div>
        </li>

        <li class="option-row reveal" id="cdn">
          <div class="option-num">
            <span class="option-index mono">04</span>
          </div>
          <div class="option-body">
            <h3 class="option-name">CDN · per-block WOFF2</h3>
            <p class="option-format mono">{stats.websiteSubsets.woff2Count} subsets · {formatBytes(stats.websiteSubsets.woff2TotalBytes)} total · unicode-range aware</p>
            <p class="option-desc">
              The browser-friendly path. The CDN serves a WOFF2 subset per
              Unicode block; the browser only fetches the ones your page
              actually uses, thanks to <code class="mono">unicode-range</code>.
            </p>
            <div class="option-snippet">
              <div class="snippet-tab">
                <span class="folio">HTML</span>
                <button class="snippet-copy" data-copy="cdn-cmd">copy</button>
              </div>
              <pre id="cdn-cmd" class="snippet-code"><code set:html={`<link rel="stylesheet" href="https://cdn.essenfont.org/fonts.css">
<style>
  body { font-family: "Essenfont", "Noto Sans", sans-serif; }
</style>`} /></pre>
            </div>
          </div>
        </li>

        <li class="option-row reveal" id="ttc">
          <div class="option-num">
            <span class="option-index mono">05</span>
          </div>
          <div class="option-body">
            <h3 class="option-name">TTC fallback · glyf outlines</h3>
            <p class="option-format mono">TrueType · {formatBytes(stats.fontBinaries.ttcSizeBytes)} · for tools without CFF2 support</p>
            <p class="option-desc">
              Some legacy tooling can't read CFF2 outlines. The TTC
              fallback re-encodes the same glyphs as TrueType <code class="mono">glyf</code>
              data. Same cmap, same codepoint coverage.
            </p>
            <a
              href="https://github.com/essenfont/essenfont/releases/latest"
              class="btn btn-ghost btn-arrow"
              target="_blank"
              rel="noopener"
            >
              Download TTC fallback
            </a>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <section class="section install-fineprint">
    <div class="container">
      <div class="grid">
        <div style="grid-column: span 4;" class="reveal">
          <p class="eyebrow">Fineprint</p>
        </div>
        <div style="grid-column: span 7 / -1;" class="reveal">
          <h3>License &amp; redistribution</h3>
          <p class="lede" style="margin-top: 1rem;">
            Essenfont is SIL Open Font License 1.1. The assembled font
            inherits the most restrictive term across its donors; the
            LICENSE-SOURCES.md manifest in the source repo documents every
            donor's contribution.
          </p>
          <p style="margin-top: 1.5rem; max-width: 60ch;" class="text-ink-2">
            Embedding Essenfont in apps, PDFs, web pages, or other
            redistributable artifacts is explicitly permitted. Bundling
            the full OTC in commercial products is permitted. The only
            requirement is preserving the license and copyright notices.
          </p>
          <div style="margin-top: 2.5rem; display: flex; gap: 1rem; flex-wrap: wrap;">
            <a href="/license" class="btn btn-ghost btn-arrow">Full license</a>
            <a href="/provenance" class="btn btn-ghost btn-arrow">Donor provenance</a>
            <a href="/changelog" class="btn btn-ghost btn-arrow">Release history</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .install-hero { padding-block: clamp(3rem, 8vw, 5rem); }
  .install-hero-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: clamp(1rem, 3vw, 2.5rem);
  }
  .install-meta { grid-column: 1 / span 2; }
  .install-pitch { grid-column: 4 / span 9; padding-top: 1rem; }
  .install-pitch h1 {
    font-family: var(--font-display);
    font-weight: 300;
    font-variation-settings: "opsz" 144, "SOFT" 40;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.035em;
  }
  .install-pitch h1 em {
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
  }

  /* Options list */
  .options-list {
    list-style: none;
    counter-reset: opt;
  }
  .option-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
    padding-block: clamp(2rem, 5vw, 3.5rem);
    border-top: 1px solid var(--ef-rule);
    counter-increment: opt;
  }
  .option-row:last-child { border-bottom: 1px solid var(--ef-rule); }
  .option-index {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    color: var(--ef-ink-3);
    padding-top: 0.5rem;
  }
  .option-name {
    font-family: var(--font-display);
    font-weight: 350;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ef-ink);
  }
  .option-format {
    margin-top: 0.5rem;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--ef-ochre);
    text-transform: uppercase;
  }
  .option-desc {
    margin-top: 1.25rem;
    font-size: 1rem;
    color: var(--ef-ink-2);
    max-width: 62ch;
    line-height: 1.65;
  }
  .option-desc code {
    font-size: 0.875em;
    color: var(--ef-ink);
    background: var(--ef-paper-3);
    padding: 0.1em 0.4em;
  }
  .option-snippet {
    margin-top: 1.75rem;
    max-width: 720px;
  }

  /* Fineprint */
  .install-fineprint { background: var(--ef-paper-2); }

  @media (max-width: 768px) {
    .install-meta, .install-pitch { grid-column: 1 / span 12; }
    .option-row { grid-template-columns: 1fr; gap: 0.5rem; }
    .option-num { padding-top: 0; }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.snippet-copy').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.copy;
      const target = id ? document.getElementById(id) : null;
      if (target) {
        const text = target.innerText;
        navigator.clipboard?.writeText(text).then(() => {
          const original = btn.textContent;
          btn.textContent = 'copied';
          setTimeout(() => { btn.textContent = original; }, 1500);
        });
      }
    });
  });
</script>
