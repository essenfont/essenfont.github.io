---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadReleases } from '../../lib/donors';

const releases = loadReleases();
---
<BaseLayout title="Changelog — Essenfont" description="Release history for the Essenfont universal Unicode 17 font." canonical="/changelog">
  <div class="changelog">
    <header class="page-head">
      <p class="eyebrow">Changelog</p>
      <h1>Release history</h1>
    </header>
    {releases.length === 0 ? (
      <p class="empty">No releases yet. The first release is coming soon.</p>
    ) : (
      <ul class="release-list">
        {releases.map(r => (
          <li>
            <a href={`/changelog/${r.tag}`} class="release-tag">{r.tag}</a>
            <span class="release-name">{r.name}</span>
            <time>{r.date}</time>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>
<style>
.changelog { max-width: 640px; margin: 0 auto; padding: 3rem 1.5rem 6rem; }
.page-head { margin-bottom: 2rem; }
.eyebrow { font-family: var(--mono-font, monospace); font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ef-rose, #bf4e6a); }
h1 { font-family: var(--display-font, Spectral, serif); font-size: 2rem; }
.empty { opacity: 0.6; }
.release-list { list-style: none; padding: 0; }
.release-list li { display: flex; align-items: baseline; gap: 1rem; padding: 0.75rem 0; border-bottom: 1px solid rgba(128,128,128,0.1); }
.release-tag { font-family: var(--mono-font, monospace); font-weight: 600; color: var(--ef-rose, #bf4e6a); text-decoration: none; }
.release-name { flex: 1; font-size: 0.875rem; opacity: 0.7; }
time { font-family: var(--mono-font, monospace); font-size: 0.75rem; opacity: 0.5; }
</style>
