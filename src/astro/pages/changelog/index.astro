---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadReleases } from '../../lib/donors';

const releases = loadReleases();
const GH_RELEASES_URL = 'https://github.com/essenfont/essenfont/releases';
const GH_NPM_URL = 'https://www.npmjs.com/package/essenfont';
---
<BaseLayout title="Changelog — Essenfont" description="Release history for the Essenfont universal Unicode 17 font." canonical="/changelog">
  <div class="changelog">
    <header class="page-head">
      <p class="eyebrow">Changelog</p>
      <h1>Release history</h1>
      <p class="subtitle">
        Every release is published simultaneously on GitHub Releases and npm.
        Subscribe to
        <a href={GH_RELEASES_URL} target="_blank" rel="noopener">essenfont/essenfont/releases</a>
        or watch the
        <a href={GH_NPM_URL} target="_blank" rel="noopener"><code>essenfont</code> npm package</a>
        for updates.
      </p>
    </header>
    {releases.length === 0 ? (
      <p class="empty">No releases yet. The first release is coming soon.</p>
    ) : (
      <ul class="release-list">
        {releases.map(r => (
          <li class:list={["release-row", { 'release-latest': r.isLatest }]}>
            <a href={`/changelog/${r.tag}`} class="release-tag">
              {r.tag}
              {r.isLatest && <span class="release-pill">latest</span>}
            </a>
            <span class="release-name">{r.name}</span>
            <time>{r.date}</time>
          </li>
        ))}
      </ul>
    )}
    <div class="external-links">
      <a href={GH_RELEASES_URL} target="_blank" rel="noopener" class="external-cta">
        View all releases on GitHub →
      </a>
    </div>
  </div>
</BaseLayout>
<style>
.changelog { max-width: 720px; margin: 0 auto; padding: 3rem 1.5rem 6rem; }
.page-head { margin-bottom: 2.5rem; }
.eyebrow {
  font-family: var(--spec-font-mono);
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--ef-accent);
  margin: 0 0 0.5rem;
}
h1 {
  font-family: var(--spec-font-display);
  font-weight: 600;
  font-size: clamp(2rem, 5vw, 2.75rem);
  letter-spacing: -0.02em;
  margin: 0 0 0.75rem;
}
.subtitle {
  font-size: 0.95rem;
  color: var(--ef-text-2);
  max-width: 600px;
  line-height: 1.55;
  margin: 0;
}
.subtitle a { color: var(--ef-accent); text-decoration: none; }
.subtitle a:hover { text-decoration: underline; }
.subtitle code { font-family: var(--spec-font-mono); font-size: 0.85em; }
.empty { opacity: 0.6; }
.release-list { list-style: none; padding: 0; margin: 0 0 2rem; }
.release-row {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--ef-rule);
}
.release-row.release-latest {
  background: var(--ef-accent-soft);
  padding-left: 0.75rem;
  padding-right: 0.75rem;
  border-radius: var(--ef-radius-sm);
  margin: 0 -0.75rem;
}
.release-tag {
  display: inline-flex;
  align-items: baseline;
  gap: 0.4rem;
  font-family: var(--spec-font-mono);
  font-weight: 700;
  color: var(--ef-accent);
  text-decoration: none;
  font-size: 0.95rem;
}
.release-tag:hover { text-decoration: underline; }
.release-pill {
  font-family: var(--spec-font-mono);
  font-size: 0.55rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  background: var(--ef-accent);
  color: white;
  padding: 0.1rem 0.35rem;
  border-radius: 3px;
}
.release-name { flex: 1; font-size: 0.9rem; color: var(--ef-text-2); }
time {
  font-family: var(--spec-font-mono);
  font-size: 0.75rem;
  color: var(--ef-text-3);
}
.external-links { margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--ef-rule); }
.external-cta {
  display: inline-block;
  font-family: var(--spec-font-mono);
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--ef-accent);
  text-decoration: none;
  padding: 0.6rem 1.2rem;
  border: 1px solid var(--ef-accent);
  border-radius: 999px;
  transition: background 0.15s, color 0.15s;
}
.external-cta:hover {
  background: var(--ef-accent);
  color: white;
  text-decoration: none;
}
</style>
