---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadReleases } from '../../lib/donors';

export async function getStaticPaths() {
  return loadReleases().map(r => ({ params: { tag: r.tag }, props: { release: r } }));
}
const { release } = Astro.props;
---
<BaseLayout title={`${release.tag} — ${release.name} — Essenfont`} description={`Release ${release.tag}: ${release.name}`} canonical={`/changelog/${release.tag}`}>
  <article class="release-detail">
    <p class="eyebrow"><a href="/changelog">← Changelog</a></p>
    <h1>{release.tag}</h1>
    <p class="release-name">{release.name}</p>
    <time class="release-date">{release.date}</time>
    {release.otc_url && (
      <p><a href={release.otc_url} class="btn-primary">Download</a></p>
    )}
    <p><a href={release.url} target="_blank" rel="noopener">View on GitHub →</a></p>
  </article>
</BaseLayout>
<style>
.release-detail { max-width: 640px; margin: 0 auto; padding: 3rem 1.5rem 6rem; }
.eyebrow { font-family: var(--mono-font, monospace); font-size: 0.75rem; opacity: 0.6; }
.eyebrow a { color: var(--ef-rose, #bf4e6a); text-decoration: none; }
h1 { font-family: var(--display-font, Spectral, serif); font-size: 2rem; margin: 0.5rem 0 0.5rem; }
.release-name { font-size: 1.125rem; opacity: 0.8; margin: 0 0 0.5rem; }
.release-date { font-family: var(--mono-font, monospace); font-size: 0.875rem; opacity: 0.5; }
.btn-primary { display: inline-block; padding: 0.6rem 1.2rem; border-radius: 4px; background: var(--ef-rose, #bf4e6a); color: white; font-weight: 600; text-decoration: none; font-size: 0.875rem; }
</style>
