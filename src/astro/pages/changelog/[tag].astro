---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadReleases } from '../../lib/donors';
import { formatBytes } from '../../lib/ssr';

export async function getStaticPaths() {
  return loadReleases().map(r => ({ params: { tag: r.tag }, props: { release: r } }));
}
const { release } = Astro.props;

const downloadLinks: Array<{ label: string; href: string; tag?: string }> = [];
if (release.ttc_url) downloadLinks.push({ label: 'Download TTC', href: release.ttc_url, tag: 'primary' });
if (release.npm_url) downloadLinks.push({ label: 'View on npm', href: release.npm_url });
if (release.coverage_url) downloadLinks.push({ label: 'Coverage report', href: release.coverage_url });
---
<BaseLayout
  title={`${release.tag} — ${release.name} — Essenfont`}
  description={`Release ${release.tag}: ${release.name}`}
  canonical={`/changelog/${release.tag}`}
>
  <article class="release-detail">
    <h1>{release.tag}</h1>
    <p class="release-name">{release.name}</p>
    <time class="release-date">{release.date}</time>

    {release.notes && <p class="release-notes">{release.notes}</p>}

    {release.stats && (
      <dl class="release-stats">
        {release.stats.codepoints != null && (
          <>
            <dt>Codepoints covered</dt>
            <dd>{release.stats.codepoints.toLocaleString()}</dd>
          </>
        )}
        {release.stats.pct != null && (
          <>
            <dt>Coverage</dt>
            <dd>{release.stats.pct}% of Unicode 17</dd>
          </>
        )}
        {release.stats.planes != null && (
          <>
            <dt>Planes</dt>
            <dd>{release.stats.planes}</dd>
          </>
        )}
      </dl>
    )}

    {downloadLinks.length > 0 && (
      <div class="release-actions">
        {downloadLinks.map(l => (
          <a href={l.href} target="_blank" rel="noopener" class:list={["release-btn", { primary: l.tag === 'primary' }]}>
            {l.label} ↗
          </a>
        ))}
      </div>
    )}

    <p><a href={release.url} target="_blank" rel="noopener">View on GitHub →</a></p>
  </article>
</BaseLayout>
<style>
.release-detail { max-width: 720px; margin: 0 auto; padding: 3rem 1.5rem 6rem; }


h1 {
  font-family: var(--spec-font-display);
  font-weight: 600;
  font-size: clamp(2rem, 5vw, 3rem);
  margin: 0 0 0.25rem;
  letter-spacing: -0.02em;
}
.release-name {
  font-family: var(--spec-font-display);
  font-size: 1.25rem;
  color: var(--ef-text-2);
  font-style: italic;
  margin: 0 0 0.5rem;
}
.release-date {
  font-family: var(--spec-font-mono);
  font-size: 0.8rem;
  color: var(--ef-text-3);
}
.release-notes {
  font-size: 0.95rem;
  line-height: 1.6;
  color: var(--ef-text-2);
  margin: 2rem 0;
  padding: 1rem 1.25rem;
  background: var(--ef-surface);
  border-left: 3px solid var(--ef-accent);
  border-radius: var(--ef-radius-sm);
}
.release-stats {
  display: grid;
  grid-template-columns: max-content 1fr;
  gap: 0.4rem 1.5rem;
  margin: 2rem 0;
  font-size: 0.9rem;
}
.release-stats dt {
  font-family: var(--spec-font-mono);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--ef-text-3);
}
.release-stats dd { margin: 0; }
.release-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin: 2rem 0;
}
.release-btn {
  display: inline-block;
  padding: 0.6rem 1.2rem;
  border-radius: var(--ef-radius-sm);
  border: 1px solid var(--ef-accent);
  color: var(--ef-accent);
  font-family: var(--spec-font-mono);
  font-size: 0.85rem;
  font-weight: 600;
  text-decoration: none;
}
.release-btn.primary {
  background: var(--ef-accent);
  color: white;
}
.release-btn:hover {
  text-decoration: none;
  background: var(--ef-accent);
  color: white;
}
</style>
