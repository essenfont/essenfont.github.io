---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;

const allDocs = (await getCollection('docs')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={`${title} — Essenfont Docs`} description={description} canonical={canonical}>
  <div class="docs-layout">
    <aside class="docs-nav">
      <nav>
        <p class="docs-nav-label">Getting started</p>
        {allDocs.filter(d => d.data.order <= 4).map(doc => (
          <a href={`/docs/${doc.id}`} class:list={[{ active: title === doc.data.title }]}>{doc.data.title}</a>
        ))}
        <p class="docs-nav-label">Under the hood</p>
        {allDocs.filter(d => d.data.order > 4).map(doc => (
          <a href={`/docs/${doc.id}`} class:list={[{ active: title === doc.data.title }]}>{doc.data.title}</a>
        ))}
      </nav>
    </aside>
    <main class="docs-main prose">
      <slot />
    </main>
  </div>
</BaseLayout>

<style>
  .docs-layout {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2rem;
    padding: 2rem 1.5rem 4rem;
  }
  .docs-nav {
    position: sticky;
    top: 80px;
    align-self: start;
  }
  .docs-nav nav {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .docs-nav-label {
    font-family: var(--spec-font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ef-text-3);
    margin: 1rem 0 0.4rem;
  }
  .docs-nav-label:first-child { margin-top: 0; }
  .docs-nav a {
    font-size: 0.82rem;
    color: var(--ef-text-2);
    text-decoration: none;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    transition: background 0.12s, color 0.12s;
  }
  .docs-nav a:hover { color: var(--ef-text); background: var(--ef-accent-muted); }
  .docs-nav a.active { color: var(--ef-accent); font-weight: 600; }

  .docs-main { max-width: 760px; }
  .docs-main :global(h1) {
    font-family: var(--spec-font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    margin: 0 0 1rem;
  }
  .docs-main :global(h2) {
    font-family: var(--spec-font-display);
    font-size: 1.4rem;
    font-weight: 600;
    margin: 2.5rem 0 0.75rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--ef-rule);
  }
  .docs-main :global(h3) {
    font-family: var(--spec-font-display);
    font-size: 1.1rem;
    font-weight: 600;
    margin: 1.75rem 0 0.5rem;
  }
  .docs-main :global(p) {
    font-size: 1rem;
    line-height: 1.7;
    margin: 0 0 1rem;
    color: var(--ef-text);
  }
  .docs-main :global(ul),
  .docs-main :global(ol) {
    margin: 0 0 1rem 1.5rem;
  }
  .docs-main :global(li) {
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 0.4rem;
  }
  .docs-main :global(code) {
    font-family: var(--spec-font-mono);
    font-size: 0.85em;
    background: var(--ef-accent-muted);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }
  .docs-main :global(pre) {
    background: var(--ef-surface);
    border: 1px solid var(--ef-rule);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1.25rem 0;
  }
  .docs-main :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.82rem;
    line-height: 1.6;
  }
  .docs-main :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.25rem 0;
    font-size: 0.9rem;
  }
  .docs-main :global(th),
  .docs-main :global(td) {
    text-align: left;
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--ef-rule);
  }
  .docs-main :global(thead th) {
    font-family: var(--spec-font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ef-text-3);
    border-bottom: 2px solid var(--ef-rule-strong);
  }
  .docs-main :global(blockquote) {
    margin: 1.25rem 0;
    padding: 0.5rem 0 0.5rem 1rem;
    border-left: 3px solid var(--ef-accent);
    font-style: italic;
    color: var(--ef-text-2);
  }
  .docs-main :global(a) {
    color: var(--ef-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 768px) {
    .docs-layout { grid-template-columns: 1fr; }
    .docs-nav { display: none; }
  }
</style>
