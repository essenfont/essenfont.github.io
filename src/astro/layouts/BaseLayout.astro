---
import '../../styles/main.css';
import BrandMark from '../components/BrandMark.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const { title, description = 'Universal Unicode 17 font', canonical } = Astro.props;
const site = Astro.site ?? 'https://essenfont.github.io';
const canonicalURL = canonical ? new URL(canonical, site).href : undefined;
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png?v=20260709" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260709" />
    <link rel="shortcut icon" href="/favicon.ico?v=20260709" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=20260709" />
    <link rel="manifest" href="/site.webmanifest?v=20260709" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Hanken+Grotesk:wght@300..800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/fonts.css" />
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('theme');
        var prefersDark = matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <nav class="container nav">
        <a href="/" class="brand">
          <BrandMark size="sm" alt="Essenfont" />
          <span class="brand-text">Essenfont</span>
        </a>
        <div class="nav-right">
          <div class="nav-links">
            <a href="/unicode" class="nav-link">Unicode</a>
            <a href="/donors" class="nav-link">Donors</a>
            <a href="/download" class="nav-link">Download</a>
            <a href="/changelog" class="nav-link">Changelog</a>
            <a href="/engineering" class="nav-link">Engineering</a>
            <a href="/about" class="nav-link">About</a>
          </div>
          <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">
            <svg class="sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <circle cx="12" cy="12" r="4.5"/>
              <path d="M12 2v2.5M12 19.5V22M4.2 4.2l1.8 1.8M18 18l1.8 1.8M2 12h2.5M19.5 12H22M4.2 19.8l1.8-1.8M18 6l1.8-1.8"/>
            </svg>
            <svg class="moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/>
            </svg>
          </button>
        </div>
      </nav>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-left">
          <a href="https://github.com/essenfont/essenfont" target="_blank" rel="noopener" class="footer-gh" aria-label="GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12c0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 24 12c0-6.6-5.4-12-12-12z"/></svg>
          </a>
          <span class="footer-copy">&copy; {year} Ribose Inc.</span>
        </div>
        <div class="footer-right">
          <a href="/license">License</a>
          <a href="/provenance">Provenance</a>
          <a href="/search">Search</a>
        </div>
      </div>
    </footer>
    <script is:inline>
      var btn = document.getElementById('theme-toggle');
      if (btn) {
        btn.addEventListener('click', function() {
          var isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
      }
    </script>
  </body>
</html>

<style is:global>
  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--ef-rule);
    border-radius: var(--ef-radius-sm);
    background: var(--ef-surface);
    color: var(--ef-text-2);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    flex-shrink: 0;
  }
  .theme-toggle:hover {
    color: var(--ef-accent);
    border-color: var(--ef-accent);
  }
  .sun-icon { display: none; }
  .moon-icon { display: block; }
  html.dark .sun-icon { display: block; }
  html.dark .moon-icon { display: none; }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .footer-gh {
    display: flex;
    align-items: center;
    color: var(--ef-text-2);
    transition: color 0.15s;
  }
  .footer-gh:hover { color: var(--ef-accent); }
  .footer-copy {
    font-family: var(--spec-font-mono, monospace);
    font-size: 0.75rem;
    color: var(--ef-text-3);
  }
  .footer-right {
    display: flex;
    gap: 1rem;
  }
  .footer-right a {
    font-family: var(--spec-font-mono, monospace);
    font-size: 0.75rem;
    color: var(--ef-text-2);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-right a:hover { color: var(--ef-accent); }

  @media (max-width: 768px) {
    .footer-inner { flex-direction: column; gap: 0.75rem; }
  }
</style>
<style is:global>
  .brand-text {
    font-family: var(--spec-font-display);
    font-weight: 600;
    font-size: 1.25rem;
    letter-spacing: -0.02em;
    font-optical-sizing: auto;
    font-variation-settings: "opsz" 32;
    line-height: 1;
  }
</style>
