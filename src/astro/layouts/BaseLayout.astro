---
import '../../styles/main.css';
import '../styles/tailwind.css';
import { ClientRouter } from 'astro:transitions';
import BrandMark from '../components/BrandMark.astro';
import CommandPalette from '../components/CommandPalette.vue';
import SiteFooter from '../components/SiteFooter.astro';
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  /** Highlights the matching nav item. */
  active?: 'specimen' | 'browse' | 'install' | 'makers' | 'changelog';
}

const {
  title,
  description = 'One font. Every assigned Unicode 17 codepoint. Real outlines for ~160,000 characters, drawn from canonical OFL-licensed donor fonts.',
  canonical,
  active,
} = Astro.props;

const site = Astro.site ?? 'https://essenfont.github.io';
const canonicalURL = canonical ? new URL(canonical, site).href : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png?v=20260709" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260709" />
    <link rel="shortcut icon" href="/favicon.ico?v=20260709" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=20260709" />
    <link rel="manifest" href="/site.webmanifest?v=20260709" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;500;600;700&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;500;600;700&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" /></noscript>
    <link rel="stylesheet" href="/fonts.css" />
    <ClientRouter />
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('theme');
        var prefersDark = matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header" transition:persist>
      <nav class="container nav">
        <a href="/" class="brand">
          <BrandMark size="sm" alt="Essenfont" />
          <span class="brand-text">Essenfont</span>
        </a>
        <div class="nav-right">
          <div class="nav-links">
            <a href="/unicode" class="nav-link">Unicode</a>
            <a href="/donors" class="nav-link">Donors</a>
            <a href="/download" class="nav-link">Download</a>
            <a href="/docs" class="nav-link">Docs</a>
            <a href="/changelog" class="nav-link">Changelog</a>
            <a href="/about" class="nav-link">About</a>
          </div>
          <button class="cmdk-trigger" type="button" data-cmdk-trigger aria-label="Open search (Cmd+K)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="7"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <span class="cmdk-trigger-kbd" aria-hidden="true">⌘K</span>
          </button>
          <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">
            <svg class="sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <circle cx="12" cy="12" r="4.5"/>
              <path d="M12 2v2.5M12 19.5V22M4.2 4.2l1.8 1.8M18 18l1.8 1.8M2 12h2.5M19.5 12H22M4.2 19.8l1.8-1.8M18 6l1.8-1.8"/>
            </svg>
            <svg class="moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/>
            </svg>
          </button>
        </div>
      </nav>
    </header>
    <main class="container" transition:animate="fade">
      <slot />
    </main>
    <CommandPalette client:only="vue" />
    <SiteFooter transition:persist />
    <script>
      // Theme persistence + FOUC prevention.
      //
      // Two passes:
      //   1. The inline <head> script below runs synchronously on the
      //      FIRST page load and applies the saved theme before the
      //      body renders.
      //   2. After ViewTransitions: the body script below listens for
      //      astro:before-preparation, astro:before-swap, and
      //      astro:after-swap to re-apply the theme at every navigation
      //      boundary. The before-preparation hook paints the class on
      //      <html> BEFORE the new page's DOM is swapped in, so the
      //      transition itself is not a flash.
      function highlightNav(): void {
        const path = window.location.pathname;
        document.querySelectorAll<HTMLElement>('.nav-link').forEach(link => {
          const href = link.getAttribute('href') || '';
          const isActive = path === href || path.startsWith(href + '/');
          link.classList.toggle('active', isActive);
        });
      }

      function applyStoredTheme(): void {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = stored === 'dark' || (!stored && prefersDark);
        document.documentElement.classList.toggle('dark', isDark);
      }

      function bindToggle(): void {
        const btn = document.getElementById('theme-toggle');
        if (!btn || btn.dataset.bound === 'true') return;
        btn.dataset.bound = 'true';
        btn.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
      }

      applyStoredTheme();
      bindToggle();
      highlightNav();
      // Pre-paint hook for ViewTransitions: runs before the new page's
      // document is prepared, so the dark class is set on <html> before
      // any rendering. Eliminates the FOUC on every navigation.
      document.addEventListener('astro:before-preparation', applyStoredTheme);
      document.addEventListener('astro:before-swap', applyStoredTheme);
      document.addEventListener('astro:page-load', () => {
        applyStoredTheme();
        bindToggle();
        highlightNav();
      });
    </script>
  </body>
</html>

<style is:global>
  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .cmdk-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    height: 36px;
    padding: 0 0.7rem 0 0.55rem;
    border: 1px solid var(--ef-rule);
    border-radius: var(--ef-radius-sm);
    background: var(--ef-surface);
    color: var(--ef-text-2);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    font-family: var(--spec-font-mono);
    font-size: 0.75rem;
  }
  .cmdk-trigger:hover { border-color: var(--ef-accent); color: var(--ef-accent); }
  .cmdk-trigger-kbd {
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    opacity: 0.6;
  }
  @media (max-width: 640px) {
    .cmdk-trigger-kbd { display: none; }
    .cmdk-trigger { padding: 0 0.55rem; }
  }
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--ef-rule);
    border-radius: var(--ef-radius-sm);
    background: var(--ef-surface);
    color: var(--ef-text-2);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    flex-shrink: 0;
  }
  .theme-toggle:hover {
    color: var(--ef-accent);
    border-color: var(--ef-accent);
  }
  .sun-icon { display: none; }
  .moon-icon { display: block; }
  html.dark .sun-icon { display: block; }
  html.dark .moon-icon { display: none; }
</style>
<style is:global>
  .brand-text {
    font-family: var(--spec-font-display);
    font-weight: 600;
    font-size: 1.25rem;
    letter-spacing: -0.02em;
    font-optical-sizing: auto;
    font-variation-settings: "opsz" 32;
    line-height: 1;
  }
</style>
