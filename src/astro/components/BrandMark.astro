---
/**
 * BrandMark — the Essenfont logo.
 *
 * Two vector SVG variants; the right one is shown based on the `.dark`
 * class on <html> (manual toggle) OR prefers-color-scheme (OS setting).
 * Manual toggle takes priority.
 *
 * Sizes: `sm` (32, masthead) · `md` (48) · `lg` (96) · `xl` (192) · `hero` (240)
 */

export interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'hero';
  animated?: boolean;
  interactive?: boolean;
  alt?: string;
  class?: string;
}

const {
  size = 'sm',
  animated = false,
  interactive = true,
  alt = 'Essenfont',
  class: className = '',
} = Astro.props;

const sizeMap = { sm: 32, md: 48, lg: 96, xl: 192, hero: 240 };
const px = sizeMap[size];
---

<span
  class:list={['brand-mark', `brand-mark--${size}`, className, { animated, interactive }]}
  style={`--bm-size: ${px}px`}
  role="img"
  aria-label={alt}
  tabindex={interactive ? 0 : undefined}
>
  <img class="bm-img bm-light" src="/essenfont-logo_dark.svg" alt="" width={px} height={px} loading="eager" />
  <img class="bm-img bm-dark" src="/essenfont-logo_light.svg" alt="" width={px} height={px} loading="eager" />

  <span class="bm-halo" aria-hidden="true"></span>
</span>

<style>
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--bm-size);
    height: var(--bm-size);
    position: relative;
    flex-shrink: 0;
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  .bm-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: none;
    transform-origin: center;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Default (light mode): show dark-colored logo. */
  .bm-light { display: block; }
  .bm-dark  { display: none; }

  /* Manual dark mode (.dark class on <html>): show light-colored logo. */
  :global(html:not(.light)) .bm-light { display: none; }
  :global(html:not(.light)) .bm-dark  { display: block; }

  /* OS dark mode fallback (no manual override). */
  @media (prefers-color-scheme: dark) {
    .bm-light { display: none; }
    .bm-dark  { display: block; }
    /* Manual light override wins over OS dark. */
    :global(html.light) .bm-light { display: block; }
    :global(html.light) .bm-dark  { display: none; }
  }

  .brand-mark.interactive:hover,
  .brand-mark.interactive:focus-visible {
    transform: translateY(-2px) scale(1.03);
  }

  .bm-halo {
    position: absolute;
    inset: -10%;
    border-radius: 24%;
    background: radial-gradient(circle at center, rgba(73, 149, 205, 0.45) 0%, transparent 65%);
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    z-index: -1;
    filter: blur(10px);
  }
  .brand-mark.interactive:hover .bm-halo,
  .brand-mark.interactive:focus-visible .bm-halo {
    opacity: 0.55;
    transform: scale(1.1);
  }

  .brand-mark.animated {
    animation: bm-pulse 4.5s ease-in-out infinite, bm-float 6.5s ease-in-out infinite;
  }

  @keyframes bm-pulse {
    0%, 100% { filter: drop-shadow(0 0 0 transparent); }
    50%      { filter: drop-shadow(0 0 14px rgba(73, 149, 205, 0.3)); }
  }
  @keyframes bm-float {
    0%, 100% { translate: 0 0; }
    50%      { translate: 0 -6px; }
  }

  .brand-mark.is-spinning {
    animation: bm-spin-once 0.7s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  @keyframes bm-spin-once {
    from { transform: rotate3d(0, 1, 0, 0deg); }
    to   { transform: rotate3d(0, 1, 0, 360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-mark.animated,
    .brand-mark.is-spinning { animation: none !important; }
    .brand-mark { transition: none; }
    .brand-mark.interactive:hover,
    .brand-mark.interactive:focus-visible { transform: none; }
  }
</style>
