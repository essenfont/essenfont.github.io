---
/**
 * UnicodeTimeline — vertical waterfall chart of codepoints added per
 * Unicode version, 1.1 → 17.0.
 *
 * Each row is one version, drawn as a horizontal bar growing left→right
 * with width proportional to codepoints added that version. Bars stack
 * top→bottom chronologically, so the silhouette resembles a waterfall
 * (wider at the bottom for recent additions, narrower at the top for
 * v1.1).
 *
 * Vertical room means labels fit without truncation — version, year,
 * new codepoint count, and the names of new blocks all render inline.
 *
 * Pure SVG + native `<title>` tooltips; no client JS.
 */
import { loadVersionTimeline } from '../lib/unicode-history';

const timeline = loadVersionTimeline();
const MAX = Math.max(...timeline.map((v) => v.newCodepoints));

const ROW_H = 36;
const BAR_H = 18;
const PAD = 16;
const LABEL_W = 240;
const BAR_X = LABEL_W + 8;
const W = 920;
const innerW = W - BAR_X - PAD;
const H = timeline.length * ROW_H + PAD * 2;
---

<figure class="unicode-timeline">
  <figcaption>
    <div class="ut-cap-row">
      <span class="ut-label">Unicode growth, 1.1 → 17.0</span>
      <span class="ut-cap">Each row is one Unicode version. Bar width is proportional to codepoints added in that version. The waterfall makes recent additions (huge CJK / emoji blocks) visually dwarf the early ones.</span>
    </div>
    <span class="ut-sub mono">{timeline.length} versions · {timeline.reduce((s, v) => s + v.newCodepoints, 0).toLocaleString()} codepoints added</span>
  </figcaption>

  <svg class="ut-svg" viewBox={`0 0 ${W} ${H}`} role="img" aria-labelledby="ut-title">
    <title id="ut-title">Unicode growth chart, version 1.1 (1993) through {timeline[timeline.length - 1].version} ({timeline[timeline.length - 1].year})</title>
    <desc>Vertical waterfall: each row is one Unicode version with bar width proportional to codepoints added.</desc>

    {timeline.map((slice, i) => {
      const y = PAD + i * ROW_H + (ROW_H - BAR_H) / 2;
      const barW = Math.max((slice.newCodepoints / MAX) * innerW, 1);
      const cumulativePct = (slice.cumulative / timeline[timeline.length - 1].cumulative) * 100;
      const isBig = slice.newCodepoints > 1000;
      const fillOpacity = 0.3 + (i / timeline.length) * 0.6;
      return (
        <g class="ut-row">
          <text
            x={PAD}
            y={y + BAR_H / 2 + 3}
            font-family="IBM Plex Mono, monospace"
            font-size="11"
            font-weight="600"
            fill="var(--ef-text)"
          >v{slice.version}</text>
          <text
            x={PAD + 42}
            y={y + BAR_H / 2 + 3}
            font-family="IBM Plex Mono, monospace"
            font-size="10"
            fill="var(--ef-text-3)"
          >{slice.year}</text>
          <text
            x={PAD + 88}
            y={y + BAR_H / 2 + 3}
            font-family="IBM Plex Mono, monospace"
            font-size="10"
            fill="var(--ef-accent)"
          >+{slice.newCodepoints.toLocaleString()} cp</text>
          <rect
            x={BAR_X}
            y={y}
            width={barW}
            height={BAR_H}
            fill={`rgba(42, 92, 138, ${fillOpacity.toFixed(2)})`}
            class="ut-seg"
          />
          <title>v{slice.version} ({slice.year}) · +{slice.newCodepoints.toLocaleString()} codepoints · cumulative {slice.cumulative.toLocaleString()} ({cumulativePct.toFixed(1)}%) · {slice.newBlocks.length} new block{slice.newBlocks.length === 1 ? '' : 's'}</title>
          {isBig && (
            <text
              x={BAR_X + barW + 6}
              y={y + BAR_H / 2 + 3}
              font-family="IBM Plex Mono, monospace"
              font-size="9"
              fill="var(--ef-text-3)"
            >{slice.newBlocks.slice(0, 2).map((b) => b.name).join(', ')}{slice.newBlocks.length > 2 ? ' …' : ''}</text>
          )}
        </g>
      );
    })}
  </svg>
</figure>

<style>
  .unicode-timeline {
    margin: 2rem 0 1rem;
    padding: 1rem 1.25rem 0.75rem;
    border: 1px solid var(--ef-rule-strong, rgba(26,24,21,0.16));
    border-radius: 8px;
    background: var(--ef-bg, #faf8f5);
  }
  figcaption {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 0.85rem;
  }
  .ut-cap-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .ut-label {
    font-family: var(--spec-font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ef-text-3);
    white-space: nowrap;
  }
  .ut-cap {
    font-size: 0.82rem;
    color: var(--ef-text-2);
    line-height: 1.5;
    max-width: 640px;
  }
  .ut-sub { font-size: 0.7rem; opacity: 0.75; }
  .ut-svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .ut-row:hover .ut-seg { fill: var(--ef-accent); }
  .ut-seg { transition: fill 0.1s ease; }
</style>
