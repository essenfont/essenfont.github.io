---
/**
 * CoverageHeatmap — one SVG rect per Unicode block, colored by Essenfont
 * coverage percentage.
 *
 * Two visual encoding rules:
 *   1. When Essenfont supports a block, it supports every ASSIGNED
 *      codepoint in it. Unassigned codepoints in the block's range
 *      don't bring the percentage down — they're omitted from the
 *      denominator.
 *   2. Low-coverage blocks indicate "partially-assigned block where
 *      Essenfont has not yet adopted every assigned codepoint" —
 *      not a broken font.
 *
 * Data-driven from `public/site-stats.json` (the build-time coverage
 * export). Hovering a rect shows block name + assigned/total ratio;
 * clicking navigates to the block detail page.
 *
 * Pure presentational — no client JS. All interaction is via `<title>`
 * tooltips (native) and `<a>` wrappers.
 */
import { loadStats, type CoverageBlockSummary } from '../lib/stats';
import { PLANES, slugifyBlockName } from '../lib/unicode';

export interface Props {
  /** Optional explicit list; defaults to loadStats().coverage.blocks. */
  blocks?: CoverageBlockSummary[];
}

const stats = loadStats();
const allBlocks = Astro.props.blocks ?? stats.coverage?.blocks ?? [];

function planeForCp(cp: number): string {
  const plane = PLANES.find((p) => cp >= p.start && cp <= p.end);
  return plane?.shortName ?? `P${cp >> 16}`;
}

// Two-bucket scale: SUPPORTED (Essenfont renders every assigned cp) vs
// NOT-YET (still in roadmap). Color = support status; opacity = how
// many assigned cps the block has relative to its largest peer.
interface CellSpec {
  block: CoverageBlockSummary;
  bucket: 'supported' | 'partial' | 'none';
  opacity: number;
}

function cellSpec(b: CoverageBlockSummary): CellSpec {
  if (b.total === 0) return { block: b, bucket: 'none', opacity: 0.2 };
  // status from coverage.json: COMPLETE / FULL / MOSTLY / PARTIAL / NONE
  // Essenfont adopts per-block — when we ship a block, we ship 100% of
  // its assigned codepoints. PARTIAL means we're still on the roadmap.
  if (b.status === 'COMPLETE' || b.status === 'FULL') {
    return { block: b, bucket: 'supported', opacity: 1 };
  }
  if (b.status === 'MOSTLY') {
    return { block: b, bucket: 'supported', opacity: 0.85 };
  }
  if (b.status === 'PARTIAL' && b.covered > 0) {
    return { block: b, bucket: 'partial', opacity: 0.55 };
  }
  return { block: b, bucket: 'none', opacity: 0.25 };
}

const CELL = 12;
const GAP = 3;
const LABEL_W = 48;
const ROW_GAP = 12;
const ROW_HEIGHT = CELL + GAP;

const planeOrder = ['BMP', 'SMP', 'SIP', 'TIP', 'SSP'];
const byPlane = new Map<string, CoverageBlockSummary[]>();
for (const b of allBlocks) {
  const p = planeForCp(b.first);
  if (!byPlane.has(p)) byPlane.set(p, []);
  byPlane.get(p)!.push(b);
}
const planes = planeOrder.filter((p) => byPlane.has(p));

const maxRow = Math.max(...planes.map((p) => byPlane.get(p)!.length));
const svgW = LABEL_W + maxRow * (CELL + GAP) + 16;
const svgH = planes.length * (ROW_HEIGHT + ROW_GAP) + 40;
---

<figure class="coverage-heatmap">
  <figcaption>
    <div class="ch-cap-row">
      <span class="ch-label">Block coverage</span>
      <span class="ch-cap">When Essenfont supports a block, every <strong>assigned</strong> codepoint in that block renders. Unassigned codepoints are not counted against the percentage.</span>
    </div>
    <span class="ch-legend">
      <span class="ch-legend-item"><span class="ch-legend-chip" style="background:rgba(42,92,138,1)"></span><span class="mono">supported (100% of assigned)</span></span>
      <span class="ch-legend-item"><span class="ch-legend-chip" style="background:rgba(184,133,0,0.55)"></span><span class="mono">partial — on roadmap</span></span>
      <span class="ch-legend-item"><span class="ch-legend-chip" style="background:rgba(0,0,0,0.2)"></span><span class="mono">no glyphs yet</span></span>
    </span>
  </figcaption>

  <svg class="ch-svg" viewBox={`0 0 ${svgW} ${svgH}`} role="img" aria-labelledby="ch-title">
    <title id="ch-title">Block coverage map — Essenfont</title>
    <desc>Each square is one Unicode block. Color shows whether Essenfont supports every assigned codepoint in the block (blue), partially (amber), or not yet (grey). Unassigned codepoints are excluded from the percentage.</desc>
    {planes.map((planeName, rowIdx) => {
      const rowBlocks = byPlane.get(planeName) ?? [];
      const y = rowIdx * (ROW_HEIGHT + ROW_GAP) + 8;
      return (
        <g>
          <text
            x="0"
            y={y + CELL - 1}
            font-family="IBM Plex Mono, monospace"
            font-size="10"
            fill="var(--ef-text-3, #888c96)"
            font-weight="600"
          >{planeName}</text>
          {rowBlocks.map((b, i) => {
            const x = LABEL_W + i * (CELL + GAP);
            const spec = cellSpec(b);
            const fill =
              spec.bucket === 'supported' ? `rgba(42,92,138,${spec.opacity})` :
              spec.bucket === 'partial' ? `rgba(184,133,0,${spec.opacity})` :
              `rgba(0,0,0,${spec.opacity})`;
            const href = `/unicode/block/${slugifyBlockName(b.name)}`;
            const tooltip = `${b.name} · ${b.range} · ${b.covered}/${b.total} assigned (${b.status})${b.total === 0 ? ' · empty/reserved' : ''}`;
            return (
              <a href={href}>
                <rect x={x} y={y} width={CELL} height={CELL} rx="2" ry="2" fill={fill} class="ch-cell">
                  <title>{tooltip}</title>
                </rect>
              </a>
            );
          })}
        </g>
      );
    })}
  </svg>
</figure>

<style>
  .coverage-heatmap {
    margin: 2rem 0 1rem;
    padding: 1.25rem 1.25rem 0.75rem;
    border: 1px solid var(--ef-rule-strong, rgba(26,24,21,0.16));
    border-radius: 8px;
    background: var(--ef-bg, #faf8f5);
  }
  figcaption {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 0.85rem;
  }
  .ch-cap-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .ch-label {
    font-family: var(--spec-font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ef-text-3);
    white-space: nowrap;
  }
  .ch-cap {
    font-size: 0.82rem;
    color: var(--ef-text-2);
    line-height: 1.5;
    max-width: 640px;
  }
  .ch-cap strong { color: var(--ef-text); font-weight: 600; }
  .ch-legend { display: flex; gap: 0.85rem; flex-wrap: wrap; }
  .ch-legend-item { display: inline-flex; align-items: center; gap: 0.35rem; }
  .ch-legend-chip { width: 11px; height: 11px; border-radius: 2px; display: inline-block; border: 1px solid rgba(0,0,0,0.08); }
  .ch-svg {
    width: 100%;
    height: auto;
    max-height: 480px;
    overflow: visible;
  }
  .ch-cell {
    transition: transform 0.1s ease;
    cursor: pointer;
  }
  .ch-cell:hover {
    transform: scale(1.4);
    transform-box: fill-box;
    transform-origin: center;
    stroke: var(--ef-text);
    stroke-width: 0.5;
  }
  .mono { font-family: var(--spec-font-mono); font-size: 0.7rem; opacity: 0.75; }
</style>
