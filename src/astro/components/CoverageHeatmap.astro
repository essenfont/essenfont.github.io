---
/**
 * CoverageHeatmap — redesigned block coverage visualization.
 *
 * Each Unicode block is a large, readable tile colored by Essenfont
 * coverage. Tiles wrap into a responsive grid per plane — no more
 * single-row pinpoints.
 *
 * Coverage model:
 *   - Essenfont renders every ASSIGNED codepoint in Unicode 17.
 *   - Unassigned ranges (PUA, surrogates) are not counted — they're
 *     not "assigned" by the Unicode Standard, so there's nothing to cover.
 *   - Status: "covered" (blue) or "reserved" (muted) — no confusing
 *     "on roadmap" label.
 */
import { loadStats, type CoverageBlockSummary } from '../lib/stats';
import { PLANES, slugifyBlockName } from '../lib/unicode';

const stats = loadStats();
const allBlocks = Astro.props.blocks ?? stats.coverage?.blocks ?? [];

function planeForCp(cp: number): string {
  const plane = PLANES.find((p) => cp >= p.start && cp <= p.end);
  return plane?.shortName ?? `P${cp >> 16}`;
}

const isReserved = (b: CoverageBlockSummary) =>
  b.total === 0 || /Private Use|Surrogate|Specials/i.test(b.name);

const isCovered = (b: CoverageBlockSummary) =>
  b.status === 'COMPLETE' || b.status === 'FULL' || b.status === 'MOSTLY';

const planeOrder = ['BMP', 'SMP', 'SIP', 'TIP', 'SSP'];
const byPlane = new Map<string, CoverageBlockSummary[]>();
for (const b of allBlocks) {
  const p = planeForCp(b.first);
  if (!byPlane.has(p)) byPlane.set(p, []);
  byPlane.get(p)!.push(b);
}
const planes = planeOrder.filter((p) => byPlane.has(p));

const totalAssigned = allBlocks.reduce((s, b) => s + b.total, 0);
const totalCovered = allBlocks.reduce((s, b) => s + b.covered, 0);
const coveragePct = totalAssigned > 0 ? ((totalCovered / totalAssigned) * 100).toFixed(1) : '0';
const coveredBlocks = allBlocks.filter((b) => isCovered(b) && !isReserved(b)).length;
const totalNonReserved = allBlocks.filter((b) => !isReserved(b)).length;
---

<figure class="coverage-heatmap">
  <div class="ch-headline">
    <div class="ch-headline-num">{coveragePct}<span class="ch-pct">%</span></div>
    <div class="ch-headline-text">
      <span class="ch-headline-label">of all assigned Unicode 17 codepoints</span>
      <span class="ch-headline-sub mono">{totalCovered.toLocaleString()} / {totalAssigned.toLocaleString()} assigned codepoints · {coveredBlocks}/{totalNonReserved} blocks fully covered</span>
    </div>
  </div>

  <p class="ch-note">Private Use Areas and surrogates are <strong>not assigned</strong> by Unicode — they're excluded from this count.</p>

  {planes.map((planeName) => {
    const rowBlocks = byPlane.get(planeName) ?? [];
    const active = rowBlocks.filter((b) => !isReserved(b));
    const reserved = rowBlocks.filter((b) => isReserved(b));
    return (
      <div class="ch-plane-group">
        <div class="ch-plane-label">
          <span class="ch-plane-name">{planeName}</span>
          <span class="ch-plane-count mono">{active.length} blocks{reserved.length > 0 ? ` · ${reserved.length} reserved` : ''}</span>
        </div>
        <div class="ch-tile-grid">
          {active.map((b) => {
            const href = `/unicode/block/${slugifyBlockName(b.name)}`;
            const covered = isCovered(b);
            const pct = b.total > 0 ? Math.round((b.covered / b.total) * 100) : 0;
            return (
              <a href={href} class:list={["ch-tile", covered ? "ch-tile--covered" : "ch-tile--partial"]} title={`${b.name} · ${b.range} · ${b.covered}/${b.total} assigned (${pct}%)`}>
                <span class="ch-tile-name">{b.name}</span>
                <span class="ch-tile-bar">
                  <span class="ch-tile-fill" style={`width:${pct}%`}></span>
                </span>
                <span class="ch-tile-meta mono">{b.covered.toLocaleString()} cp</span>
              </a>
            );
          })}
          {reserved.map((b) => (
            <span class="ch-tile ch-tile--reserved" title={`${b.name} · reserved (not assigned by Unicode)`}>
              <span class="ch-tile-name">{b.name}</span>
              <span class="ch-tile-bar ch-tile-bar--reserved"></span>
              <span class="ch-tile-meta mono">reserved</span>
            </span>
          ))}
        </div>
      </div>
    );
  })}
</figure>

<style>
  .coverage-heatmap {
    margin: 0;
    padding: 1.5rem;
    border: 1px solid var(--ef-rule-strong);
    border-radius: var(--ef-radius);
    background: var(--ef-surface);
  }

  .ch-headline {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  .ch-headline-num {
    font-family: var(--spec-font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--ef-accent);
  }
  .ch-pct { font-size: 0.5em; }
  .ch-headline-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .ch-headline-label {
    font-size: 1rem;
    font-weight: 600;
    color: var(--ef-text);
  }
  .ch-headline-sub {
    font-size: 0.72rem;
    color: var(--ef-text-3);
    letter-spacing: 0.05em;
  }

  .ch-note {
    font-size: 0.8rem;
    color: var(--ef-text-2);
    margin: 0 0 1.5rem;
    line-height: 1.5;
  }
  .ch-note strong { color: var(--ef-text); font-weight: 600; }

  .ch-plane-group {
    margin-bottom: 1.5rem;
  }
  .ch-plane-group:last-child { margin-bottom: 0; }

  .ch-plane-label {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.6rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--ef-rule);
  }
  .ch-plane-name {
    font-family: var(--spec-font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--ef-text);
  }
  .ch-plane-count {
    font-size: 0.68rem;
    color: var(--ef-text-3);
  }

  .ch-tile-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: 0.5rem;
  }

  .ch-tile {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.55rem 0.7rem;
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.12s, box-shadow 0.12s;
    border: 1px solid transparent;
  }
  .ch-tile--covered {
    background: color-mix(in srgb, var(--ef-accent) 8%, var(--ef-raised));
    border-color: color-mix(in srgb, var(--ef-accent) 20%, transparent);
  }
  .ch-tile--covered:hover {
    transform: translateY(-2px);
    box-shadow: var(--ef-shadow-sm);
    border-color: var(--ef-accent);
  }
  .ch-tile--partial {
    background: color-mix(in srgb, #b88500 6%, var(--ef-raised));
    border-color: color-mix(in srgb, #b88500 18%, transparent);
  }
  .ch-tile--partial:hover {
    transform: translateY(-2px);
    box-shadow: var(--ef-shadow-sm);
    border-color: #b88500;
  }
  .ch-tile--reserved {
    background: transparent;
    border: 1px dashed var(--ef-rule-strong);
    opacity: 0.5;
  }

  .ch-tile-name {
    font-size: 0.72rem;
    font-weight: 500;
    line-height: 1.25;
    color: var(--ef-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ch-tile-bar {
    height: 3px;
    border-radius: 2px;
    background: var(--ef-rule-strong);
    overflow: hidden;
  }
  .ch-tile-fill {
    display: block;
    height: 100%;
    background: var(--ef-accent);
    border-radius: 2px;
    transition: width 0.3s;
  }
  .ch-tile--partial .ch-tile-fill { background: #b88500; }
  .ch-tile-bar--reserved { background: transparent; border-top: 1px dashed var(--ef-rule-strong); }

  .ch-tile-meta {
    font-size: 0.6rem;
    color: var(--ef-text-3);
    letter-spacing: 0.04em;
  }
  .ch-tile--reserved .ch-tile-meta { font-style: italic; }

  .mono { font-family: var(--spec-font-mono); }
</style>
