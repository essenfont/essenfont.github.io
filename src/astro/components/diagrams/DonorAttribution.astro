---
// DonorAttribution — data-driven bubble chart of donor × face glyph counts.
//
// Reads public/donor-attribution.json and renders a matrix where:
// - Rows = top N donors (sorted by total codepoint contribution)
// - Columns = 5 planes (BMP, SMP, SIP, TIP, SSP)
// - Cell = filled circle, radius proportional to √(codepoint count)
//
// All values from JSON — zero hardcoded numbers.

import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const PUBLIC = path.resolve(__dirname, '..', '..', '..', '..', 'public');

interface DonorRow {
  label: string;
  family: string;
  category: string;
  totalCodepoints: number;
  byPlane: Record<string, number>;
}

let donors: DonorRow[] = [];
try {
  const data = JSON.parse(fs.readFileSync(path.join(PUBLIC, 'donor-attribution.json'), 'utf-8'));
  donors = data.donors || [];
} catch {
  // not yet generated
}

const TOP_N = 20;
const PLANES = ['BMP', 'SMP', 'SIP', 'TIP', 'SSP'];

const CATEGORY_COLORS: Record<string, string> = {
  fsung: 'var(--diagram-donor-fsung, #b04040)',
  'noto-sans': 'var(--diagram-donor-noto-sans, #2a5c8a)',
  'noto-serif': 'var(--diagram-donor-noto-serif, #3d4e8a)',
  academic: 'var(--diagram-donor-academic, #c19a3e)',
  synthetic: 'var(--diagram-donor-synthetic, #3d8b5e)',
  other: 'var(--diagram-donor-other, #888888)',
};

const top = donors.slice(0, TOP_N);

// Layout
const LEFT_MARGIN = 160;
const COL_WIDTH = 90;
const ROW_HEIGHT = 32;
const HEADER_HEIGHT = 50;
const MAX_RADIUS = 28;

function maxValue(): number {
  let max = 1;
  for (const d of top) {
    for (const p of PLANES) {
      const v = d.byPlane[p] || 0;
      if (v > max) max = v;
    }
  }
  return max;
}

const maxVal = maxValue();
const radiusFor = (count: number): number => {
  if (count === 0) return 0;
  return Math.max(3, Math.sqrt(count / maxVal) * MAX_RADIUS);
};

const width = LEFT_MARGIN + PLANES.length * COL_WIDTH + 20;
const height = HEADER_HEIGHT + top.length * ROW_HEIGHT + 20;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox={`0 0 ${width} ${height}`}
  width="100%"
  role="img"
  aria-label="Donor attribution — which donor font contributes how many glyphs to each Unicode plane"
  style="max-width: {width}px;"
>
  <desc>
    Matrix showing {top.length} donors (rows) and {PLANES.length} planes (columns).
    Circle radius is proportional to the square root of the codepoint count.
    Colors indicate donor family.
  </desc>

  {/* Column headers */}
  {PLANES.map((plane, i) => {
    const cx = LEFT_MARGIN + i * COL_WIDTH + COL_WIDTH / 2;
    return (
      <text
        x={cx} y="28"
        text-anchor="middle"
        font-family="var(--spec-font-mono, monospace)"
        font-size="12" font-weight="700"
        fill="var(--ef-text-2, #555)"
      >{plane}</text>
    );
  })}

  {/* Rows */}
  {top.map((donor, ri) => {
    const y = HEADER_HEIGHT + ri * ROW_HEIGHT + ROW_HEIGHT / 2;
    const color = CATEGORY_COLORS[donor.category] || CATEGORY_COLORS.other;
    return (
      <g>
        {/* Donor label */}
        <title>{donor.label}: {donor.totalCodepoints.toLocaleString()} codepoints total</title>
        <text
          x={LEFT_MARGIN - 12} y={y + 4}
          text-anchor="end"
          font-family="var(--spec-font-mono, monospace)"
          font-size="11"
          fill="var(--ef-text, #1a1a1a)"
        >{donor.family}</text>
        <text
          x={LEFT_MARGIN - 12} y={y + 16}
          text-anchor="end"
          font-family="var(--spec-font-mono, monospace)"
          font-size="9"
          fill="var(--ef-text-3, #888)"
        >{donor.totalCodepoints.toLocaleString()} cp</text>

        {/* Cells */}
        {PLANES.map((plane, ci) => {
          const count = donor.byPlane[plane] || 0;
          const r = radiusFor(count);
          const cx = LEFT_MARGIN + ci * COL_WIDTH + COL_WIDTH / 2;
          return (
            <g>
              {count > 0 && (
                <>
                  <title>{donor.label} → {plane}: {count.toLocaleString()} codepoints</title>
                  <circle
                    cx={cx} cy={y} r={r}
                    fill={color} opacity="0.7"
                    stroke={color} stroke-width="1"
                  />
                </>
              )}
              {count > 0 && r >= 12 && (
                <text
                  x={cx} y={y + 4}
                  text-anchor="middle"
                  font-family="var(--spec-font-mono, monospace)"
                  font-size="9" font-weight="600"
                  fill="white"
                >{count >= 1000 ? `${(count / 1000).toFixed(0)}k` : count}</text>
              )}
            </g>
          );
        })}
      </g>
    );
  })}

  {/* Legend */}
  {donors.length === 0 && (
    <text x={width / 2} y={height / 2} text-anchor="middle" font-family="var(--spec-font-mono, monospace)" font-size="12" fill="var(--ef-text-3, #888)">
      donor-attribution.json not generated yet
    </text>
  )}
</svg>

<div class="legend">
  {Object.entries(CATEGORY_COLORS).map(([cat, color]) => (
    <span class="legend-item">
      <span class="legend-dot" style={`background: ${color}`}></span>
      {cat}
    </span>
  ))}
</div>

<style>
.legend {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-top: 1rem;
  font-family: var(--spec-font-mono, monospace);
  font-size: 0.72rem;
  color: var(--ef-text-3, #888);
}
.legend-item {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
}
.legend-dot {
  display: inline-block;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  opacity: 0.7;
}
</style>
