{
  "name": "essenfont-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/gen-releases.mjs && node scripts/gen-donors.mjs && node scripts/gen-coverage.mjs && node scripts/gen-site-stats.mjs && node scripts/gen-search-index.mjs && astro build",
    "preview": "astro preview",
    "gen-stats": "node scripts/gen-site-stats.mjs",
    "gen-releases": "node scripts/gen-releases.mjs",
    "gen-donors": "node scripts/gen-donors.mjs",
    "gen-coverage": "node scripts/gen-coverage.mjs",
    "gen-unicode": "node scripts/gen-unicode-data.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vue": "^7.0.1",
    "astro": "^7.0.6",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.1.10",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
