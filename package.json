{
  "name": "essenfont-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/gen-site-stats.mjs && node scripts/gen-ssg-routes.mjs && vite-ssg build",
    "gen-stats": "node scripts/gen-site-stats.mjs",
    "build:no-fetch": "vite-ssg build",
    "preview": "vite preview",
    "gen-routes": "node scripts/gen-ssg-routes.mjs",
    "gen-unicode": "node scripts/gen-unicode-data.mjs",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@unhead/vue": "^1.11.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.0",
    "vite-ssg": "^0.24.3"
  }
}